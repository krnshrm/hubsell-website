# ---- Plunk (form submissions) — set these in the Cloudflare Pages dashboard ----
PLUNK_SECRET_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional. Defaults to https://api.useplunk.com.
# If your Plunk dashboard shows next-api.useplunk.com, set that here instead.
PLUNK_API_BASE=https://api.useplunk.com

# ---- R2 asset migration — used ONLY by scripts/migrate-assets.mjs (run locally) ----
# These are NOT needed by the website at runtime. Do not add them to Pages.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=assets
R2_PUBLIC_BASE=https://assets.hubsell.com
