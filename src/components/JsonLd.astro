---
// ============================= LEARNING NOTES =============================
// The smallest component in the repo, and a good first read. One prop
// (`schema`), one line of template. JSON.stringify() turns a JavaScript
// object into JSON text; set:html injects it verbatim into a script tag.
// `Record<string, unknown>` is TypeScript for "an object with string keys
// and any values", and the `|` union accepts one schema or an array.
// ==========================================================================
// Renders a JSON-LD <script> for structured data (helps Google rich results and
// AI answer engines understand the page). Pass a schema object or an array of
// them. Astro leaves application/ld+json scripts inline and unbundled, so the
// JSON ships verbatim in the static HTML.
interface Props {
  schema: Record<string, unknown> | Record<string, unknown>[];
}
const { schema } = Astro.props;
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
