---
// Section 7 — Pricing (Paper). Section header + the real Webflow pricing embed
// (currency conversion, Platform/Data tabs, cards), rebranded in PricingTable.astro.
import PricingTable from './PricingTable.astro';
import { getHome } from '../data/home-i18n';
import { asLocale, localizedHref } from '../i18n/utils';
const L = asLocale(Astro.currentLocale);
const { s } = getHome(L);
const seeFull = L === 'de' ? 'Alle Preise und FAQ ansehen' : L === 'nl' ? 'Bekijk alle prijzen en FAQ' : 'See full pricing and FAQ';
---
<section id="pricing" class="sec sec--paper" aria-labelledby="pricing-title">
  <div class="wrap">
    <div class="sec-head is-center reveal">
      <p class="eyebrow is-accent">{s.pricing.eyebrow}</p>
      <h2 id="pricing-title" class="heading_primary" style="margin-top:8px">{s.pricing.titlePre}<span class="accent">{s.pricing.titleAccent}</span>{s.pricing.titlePost}</h2>
    </div>
    <div class="reveal">
      <PricingTable />
    </div>
    <p class="reveal" style="text-align:center;margin-top:22px">
      <a href={localizedHref(L, '/pricing')} class="link">{seeFull} &rarr;</a>
    </p>
  </div>
</section>
