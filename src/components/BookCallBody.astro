---
// Book-a-call page body. Single source rendered by both /book-a-call (English)
// and /de/book-a-call (German); self-localizes from Astro.currentLocale.
import BookCallForm from './BookCallForm.astro';
import { asLocale } from '../i18n/utils';
import { getBookCall } from '../i18n/pages';

const L = asLocale(Astro.currentLocale);
const c = getBookCall(L);
---
<section class="sec sec--paper bc-hero">
  <div class="wrap">
    <p class="eyebrow is-accent">{c.eyebrow}</p>
    <h1 class="bc-title">{c.title}</h1>
    <p class="bc-sub subheading">{c.sub}</p>
  </div>
</section>

<section class="sec sec--sand bc-body">
  <div class="wrap">
    <div class="bc-grid">
      <div class="bc-copy">
        <h2 class="heading_tertiary">{c.coversHeading}</h2>
        <ul class="bc-list">
          {c.covers.map((item) => (<li>{item}</li>))}
        </ul>
        <p class="bc-note">{c.note}</p>
      </div>
      <div class="bc-formcard">
        <BookCallForm />
      </div>
    </div>
  </div>
</section>

<style>
  .bc-hero { padding-bottom: clamp(24px,3vw,36px); }
  .bc-title { font-family:var(--font-head); font-weight:600; font-size:clamp(2rem,4.4vw,2.75rem); line-height:1.1; letter-spacing:-.02em; color:var(--sec-tx); margin:8px 0 0; }
  .bc-sub { margin-top:14px; max-width:60ch; }

  .bc-grid { display:grid; grid-template-columns:0.82fr 1.18fr; gap:clamp(28px,5vw,56px); align-items:start; }
  @media (max-width:820px){ .bc-grid{ grid-template-columns:1fr; } }

  .bc-copy .heading_tertiary { color:var(--sec-tx); margin-bottom:16px; }
  .bc-list { list-style:none; margin:0 0 22px; padding:0; display:flex; flex-direction:column; gap:12px; }
  .bc-list li { position:relative; padding-left:24px; font-family:var(--font-body); font-size:1.0625rem; line-height:1.5; color:var(--sec-tx); }
  .bc-list li::before { content:""; position:absolute; left:2px; top:.55em; width:8px; height:8px; border-radius:50%; background:var(--accent-on); }
  .bc-note { font-family:var(--font-body); font-size:15px; line-height:1.6; color:var(--sec-tx); opacity:.78; margin:0; max-width:46ch; }

  .bc-formcard { background:var(--sec-card); border:1px solid var(--sec-bd); border-radius:var(--radius-lg); padding:clamp(22px,3vw,30px); }
</style>
