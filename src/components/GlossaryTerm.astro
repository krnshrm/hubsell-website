---
// Glossary term body. Renders one term: category tag, H1, the one-line definition
// (the quotable answer), then the markdown body (the 4 written H2 sections), then
// an auto-built Related terms block, then a soft CTA. The route file owns
// BaseLayout and the DefinedTerm + breadcrumb JSON-LD.
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { localizedHref } from '../i18n/utils';
import { SIGNUP_URL } from '../data/site';
import { glossaryCollection, glossaryChrome, categoryKey } from '../data/glossary-i18n';
import type { Locale } from '../i18n/ui';

interface Props { L: Locale; entry: CollectionEntry<'glossary'> }
const { L, entry } = Astro.props;
const c = glossaryChrome(L);
const { Content } = await render(entry);
const catKey = categoryKey(L, entry.data.category);

// Resolve related slugs to their display names in the same locale.
const all = await getCollection(glossaryCollection(L), (e) => !e.data.draft);
const bySlug = new Map(all.map((e) => [e.id, e]));
const related = (entry.data.related || [])
  .map((s) => bySlug.get(s))
  .filter((e): e is typeof all[number] => Boolean(e))
  .map((e) => ({ slug: e.id, term: e.data.term, definition: e.data.definition }));
---
<article class="sec sec--paper gl-term">
  <div class="wrap wrap--narrow">
    <p class="gl-term__cat eyebrow is-accent">{c.categoryLabel(catKey)}</p>
    <h1 class="heading_hero gl-term__h1">{entry.data.term}</h1>
    <p class="gl-term__def">{entry.data.definition}</p>

    <div class="gl-term__body rich">
      <Content />
    </div>

    {related.length > 0 && (
      <section class="gl-related" aria-label={c.relatedTitle}>
        <h2 class="heading_small">{c.relatedTitle}</h2>
        <div class="gl-related__grid">
          {related.map((r) => (
            <a class="gl-related__card" href={localizedHref(L, `/glossary/${r.slug}`)}>
              <span class="gl-related__term">{r.term}</span>
              <span class="gl-related__def">{r.definition}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <p class="gl-term__back">
      <a class="link" href={localizedHref(L, '/glossary')}>&larr; {c.backToGlossary}</a>
    </p>
  </div>
</article>

<!-- Soft CTA (espresso) -->
<section class="sec sec--esp" aria-label={c.ctaTitle}>
  <div class="wrap" style="text-align:center">
    <h2 class="heading_primary">{c.ctaTitle}</h2>
    <p class="subheading" style="margin:16px auto 0;max-width:52ch">{c.ctaSub}</p>
    <p style="margin:28px 0 0"><a href={localizedHref(L, SIGNUP_URL)} class="button is-large">{c.ctaButton}</a></p>
  </div>
</section>

<style>
  .wrap--narrow{ max-width:760px }
  .gl-term__h1{ margin-top:10px }
  .gl-term__def{ margin-top:16px; font:500 1.25rem/1.6 var(--font-body); color:var(--sec-tx) }
  .gl-term__body{ margin-top:34px }
  .gl-term__body :global(h2){ font:600 1.35rem/1.3 var(--font-head); color:var(--sec-tx); margin:30px 0 10px }
  .gl-term__body :global(p){ font:400 1rem/1.7 var(--font-body); color:var(--sec-tx); opacity:.9; margin:0 0 14px }

  .gl-related{ margin-top:44px; padding-top:28px; border-top:1px solid var(--sec-bd) }
  .gl-related__grid{ display:grid; grid-template-columns:1fr; gap:12px; margin-top:16px }
  .gl-related__card{ display:flex; flex-direction:column; gap:6px; padding:15px 17px; border:1px solid var(--sec-bd);
    border-radius:12px; background:var(--sec-card); text-decoration:none; transition:border-color .2s, transform .2s }
  .gl-related__card:hover{ border-color:var(--accent-on); transform:translateY(-2px) }
  .gl-related__term{ font:600 1rem/1.2 var(--font-head); color:var(--sec-tx) }
  .gl-related__def{ font:400 13px/1.5 var(--font-body); color:var(--sec-tx); opacity:.78 }
  .gl-term__back{ margin-top:34px }
  @media (min-width:640px){ .gl-related__grid{ grid-template-columns:1fr 1fr } }
</style>
