const { s } = getHome(asLocale(Astro.currentLocale));
---
<section class="sec sec--paper" aria-label="Customers">
  <div class="wrap">
    <p class="eyebrow" style="text-align:center;margin-bottom:26px">{s.logos.eyebrow}</p>
    <div
      class="marquee"
      role="img"
      aria-label={s.logos.aria}
    >
      <div class="marquee__track">
        {logos.map((logo) => (
          <img class="marquee__logo" src={logo.src} alt={logo.name} loading="eager" decoding="async" draggable={false} />
        ))}
        {logos.map((logo) => (
          <img class="marquee__logo" src={logo.src} alt="" aria-hidden="true" loading="eager" decoding="async" draggable={false} />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Auto-scrolling wall of customer logos. They are colourful SVGs drawn for light
     backgrounds, so we mute them to a uniform grayscale wall and restore full
     colour on hover. In dark mode we do NOT recolour the logos (flat white
     silhouettes lost detail and looked uneven across the set); instead the marquee
     rides on a light warm panel so the original logos stay legible — the same
     "light card on a dark section" pattern used elsewhere on the page. */
  .marquee{
    padding:22px 0;
    border-radius:var(--radius-lg);
    background:transparent;
    transition:background .25s;
  }
  :global([data-theme="dark"]) .marquee{
    background:#E7DCC8; /* lighter, but not white — dark logos stay readable */
  }

  /* Spacing lives on each logo (margin), not on the track (flex gap), so the seam
     between the two identical copies matches the internal spacing exactly and the
     translateX(-50%) loop repeats with no half-gap jump. */
  .marquee__track{gap:0}
  .marquee__logo{
    height:30px;width:auto;flex:none;display:block;
    margin-right:56px;
    opacity:.62;filter:grayscale(1);
    transition:opacity .2s,filter .2s;
  }
  .marquee__logo:hover{opacity:1;filter:grayscale(0)}
  :global([data-theme="dark"]) .marquee__logo{opacity:.72}
  :global([data-theme="dark"]) .marquee__logo:hover{opacity:1}

  /* ~66 logos: slow, calm drift. Higher specificity than the global 32s rule.
     This single number is the speed dial — larger = slower. */
  :global(html.has-anim) .marquee__track{animation-duration:180s}
</style>

<script>
  // Randomise the logo order on every load so the wall looks fresh, while the two
  // identical halves (needed for the seamless loop) stay in sync — one shuffle
  // order is applied to both halves. The images are eager-loaded (see markup), so
  // both halves always have real widths and the marquee scrolls through EVERY logo
  // before repeating, instead of resetting after only a few.
  function shuffleMarquee(track) {
    const items = Array.from(track.children);
    const half = items.length / 2;
    if (!Number.isInteger(half) || half < 2) return;
    const first = items.slice(0, half);
    const second = items.slice(half);
    const order = Array.from({ length: half }, (_, i) => i);
    for (let i = half - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [order[i], order[j]] = [order[j], order[i]];
    }
    const frag = document.createDocumentFragment();
    for (const i of order) frag.appendChild(first[i]);
    for (const i of order) frag.appendChild(second[i]);
    track.appendChild(frag);
  }
  function initMarquees() {
    document.querySelectorAll('.marquee__track').forEach(shuffleMarquee);
  }
  initMarquees();
  document.addEventListener('astro:page-load', initMarquees);
</script>
