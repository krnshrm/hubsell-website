---
// Section 2 — Customer logos (Paper). Static, hand-picked grid (was an auto-scrolling
// marquee of ~66 logos). A short, curated set reads as more trustworthy than an endless
// band. The six companies that have a published customer story link to it and carry a
// small "story attached" indicator (accent dot + a localized "read the story" line);
// the rest are shown plain. Logos are colourful SVGs drawn for light backgrounds, so
// every tile is a white card in BOTH themes to keep them legible (the same "light card
// on a dark section" pattern used elsewhere). Localizes UI strings from the locale.
import { getHome } from '../data/home-i18n';
import { getCustomerStoriesPage } from '../i18n/pages';
import { asLocale, localizedHref } from '../i18n/utils';

const L = asLocale(Astro.currentLocale);
const { s } = getHome(L);
const cs = getCustomerStoriesPage(L);

// Companies with a published customer story: linked + story indicator. `slug` maps to
// /customerstories/<slug> (localized at render). Order matches the stories overview.
const storyLogos = [
  { name: 'Safran Software', slug: 'safran',       src: 'https://assets.hubsell.com/logos/6998a5a3d1e6f3a4831a8f45_Safran-Software.svg' },
  { name: 'Staffbase',       slug: 'staffbase',    src: 'https://assets.hubsell.com/logos/6998a5a331fa506eb2472cc2_Staffbase.svg' },
  { name: 'Verhaert',        slug: 'verhaert',     src: 'https://assets.hubsell.com/logos/6998a5a50b8cbce05a34c8f6_Verhaert.svg' },
  { name: 'Elium',           slug: 'elium',        src: '' }, // TODO: upload Elium logo to R2 (logos/) and paste the URL here
  { name: 'Workspace 365',   slug: 'workspace365', src: 'https://assets.hubsell.com/logos/6998a5a52084daa6c519f180_Workspace-365.svg' },
  { name: 'Sensolus',        slug: 'sensolus',     src: 'https://assets.hubsell.com/logos/6998a5a3d68828bdce8239a2_Sensolus.svg' },
];

// Additional hand-picked logos (no story): shown plain.
const moreLogos = [
  { name: 'GLS',       src: 'https://assets.hubsell.com/logos/6998a5a0115d997ba479a747_GLS-Sprachenzentrum.svg' },
  { name: 'FABs',      src: 'https://assets.hubsell.com/logos/6998a5a06aeabbbea89c3080_FABs.svg' },
  { name: 'ipushpull', src: 'https://assets.hubsell.com/logos/6998a5a1c67db980e6458cd0_ipushpull.svg' },
  { name: 'Kapturall', src: 'https://assets.hubsell.com/logos/6998a5a1a86ab14f562fc7c2_Kapturall.svg' },
  { name: 'Monotype',  src: 'https://assets.hubsell.com/logos/6998f31e8d66e1f222d84ab6_Monotype.avif' },
  { name: 'EuroComms', src: '' }, // TODO: upload EuroComms logo to R2 (logos/) and paste the URL here
];
---
<section class="sec sec--paper" aria-label={s.logos.aria}>
  <div class="wrap">
    <p class="eyebrow logos-eyebrow">{s.logos.eyebrow}</p>

    <ul class="logo-grid reveal-stagger">
      {storyLogos.map((l) => (
        <li>
          <a class="logo-tile logo-tile--story" href={localizedHref(L, `/customerstories/${l.slug}`)} aria-label={`${l.name} — ${cs.eyebrowStory}`}>
            <span class="logo-tile__dot" aria-hidden="true"></span>
            <span class="logo-tile__art">
              {l.src
                ? <img class="logo-tile__img" src={l.src} alt={l.name} loading="lazy" decoding="async" width="120" height="34" />
                : <span class="logo-tile__ph">{l.name}</span>}
            </span>
            <span class="logo-tile__cta">{cs.readStory}</span>
          </a>
        </li>
      ))}
      {moreLogos.map((l) => (
        <li>
          <div class="logo-tile">
            <span class="logo-tile__art">
              {l.src
                ? <img class="logo-tile__img" src={l.src} alt={l.name} loading="lazy" decoding="async" width="120" height="34" />
                : <span class="logo-tile__ph">{l.name}</span>}
            </span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .logos-eyebrow { text-align:center; margin-bottom:26px; }

  .logo-grid{
    list-style:none; margin:0 auto; padding:0;
    max-width:820px;
    display:grid; grid-template-columns:repeat(3, 1fr); gap:16px;
  }
  .logo-grid > li { margin:0; }

  /* Every tile is a white card in both themes so the colourful, light-background
     logos stay legible on the dark section too. */
  .logo-tile{
    position:relative;
    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:10px;
    height:100%; min-height:96px;
    background:#FFFFFF;
    border:1px solid var(--sec-bd);
    border-radius:var(--radius-lg);
    padding:22px 18px;
    text-decoration:none;
    transition:border-color .15s, transform .06s, box-shadow .15s;
  }
  .logo-tile__art{ display:flex; align-items:center; justify-content:center; min-height:34px; }
  .logo-tile__img{ height:30px; width:auto; max-width:150px; display:block; }
  .logo-tile__ph{
    font-family:var(--font-body); font-weight:600; font-size:15px; letter-spacing:.01em;
    color:#192341; opacity:.85;
  }

  /* Story tiles: interactive + indicator. Accent stays the fixed brand terracotta
     (not the theme accent) because the card is always white. */
  .logo-tile--story{ cursor:pointer; }
  .logo-tile--story:hover{
    border-color:var(--brand);
    transform:translateY(-2px);
    box-shadow:0 6px 20px rgba(25,35,65,.10);
  }
  .logo-tile--story:focus-visible{ outline:2px solid var(--brand); outline-offset:2px; }
  .logo-tile__dot{
    position:absolute; top:12px; right:12px;
    width:7px; height:7px; border-radius:50%;
    background:var(--brand);
    box-shadow:0 0 0 3px color-mix(in srgb, var(--brand) 20%, transparent);
  }
  .logo-tile__cta{
    font-family:var(--font-body); font-weight:500; font-size:12.5px; line-height:1;
    color:var(--brand);
    transition:opacity .15s;
  }
  .logo-tile--story:hover .logo-tile__cta{ opacity:.82; }

  @media (max-width:640px){
    .logo-grid{ grid-template-columns:repeat(2, 1fr); gap:12px; }
    .logo-tile{ min-height:88px; padding:18px 14px; }
  }
</style>
