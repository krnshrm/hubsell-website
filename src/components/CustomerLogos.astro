---
// Section 2 — Customer logos (Paper). A static, hand-picked "shelf": a bordered strip
// of equal cells divided by thin hairlines (styled after salesforge.ai's logo band),
// instead of the old auto-scrolling marquee. Top row = the five companies with a
// published customer story: each cell links to its story and carries a small corner
// arrow as the "story attached" indicator. Bottom row = five more trusted logos, shown
// plain. Every cell is a white card in BOTH themes so the colourful, light-background
// logos stay legible on the dark section. UI strings localize from the locale.
import { getHome } from '../data/home-i18n';
import { getCustomerStoriesPage } from '../i18n/pages';
import { asLocale, localizedHref } from '../i18n/utils';

const L = asLocale(Astro.currentLocale);
const { s } = getHome(L);
const cs = getCustomerStoriesPage(L);

// Row 1 — companies with a published customer story: linked + corner-arrow indicator.
// `slug` maps to /customerstories/<slug> (localized at render).
const storyLogos = [
  { name: 'Safran Software', slug: 'safran',       src: 'https://assets.hubsell.com/logos/6998a5a3d1e6f3a4831a8f45_Safran-Software.svg' },
  { name: 'Staffbase',       slug: 'staffbase',    src: 'https://assets.hubsell.com/logos/6998a5a331fa506eb2472cc2_Staffbase.svg' },
  { name: 'Verhaert',        slug: 'verhaert',     src: 'https://assets.hubsell.com/logos/6998a5a50b8cbce05a34c8f6_Verhaert.svg' },
  { name: 'Workspace 365',   slug: 'workspace365', src: 'https://assets.hubsell.com/logos/6998a5a52084daa6c519f180_Workspace-365.svg' },
  { name: 'Sensolus',        slug: 'sensolus',     src: 'https://assets.hubsell.com/logos/6998a5a3d68828bdce8239a2_Sensolus.svg' },
];

// Row 2 — additional hand-picked logos (no story): shown plain.
const moreLogos = [
  { name: 'GLS',       src: 'https://assets.hubsell.com/logos/6998a5a0115d997ba479a747_GLS-Sprachenzentrum.svg' },
  { name: 'FABs',      src: 'https://assets.hubsell.com/logos/6998a5a06aeabbbea89c3080_FABs.svg' },
  { name: 'ipushpull', src: 'https://assets.hubsell.com/logos/6998a5a1c67db980e6458cd0_ipushpull.svg' },
  { name: 'Kapturall', src: 'https://assets.hubsell.com/logos/6998a5a1a86ab14f562fc7c2_Kapturall.svg' },
  { name: 'Monotype',  src: 'https://assets.hubsell.com/logos/6998f31e8d66e1f222d84ab6_Monotype.avif' },
];
---
<section class="sec sec--paper" aria-label={s.logos.aria}>
  <div class="wrap">
    <p class="eyebrow logos-eyebrow">{s.logos.eyebrow}</p>

    <div class="logo-strip reveal">
      <div class="logo-grid">
        {storyLogos.map((l) => (
          <a class="logo-cell logo-cell--story" href={localizedHref(L, `/customerstories/${l.slug}`)} title={cs.readStory} aria-label={`${l.name} — ${cs.eyebrowStory}`}>
            <svg class="logo-cell__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
            <img class="logo-cell__img" src={l.src} alt={l.name} loading="lazy" decoding="async" width="130" height="30" />
          </a>
        ))}
        {moreLogos.map((l) => (
          <div class="logo-cell">
            <img class="logo-cell__img" src={l.src} alt={l.name} loading="lazy" decoding="async" width="130" height="30" />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .logos-eyebrow { text-align:center; margin-bottom:26px; }

  /* The "shelf": a framed strip whose 1px gaps show the border colour as hairline
     dividers between cells. overflow+radius round the outer corners. */
  .logo-strip{
    border:1px solid var(--sec-bd);
    border-radius:var(--radius-lg);
    overflow:hidden;
    background:var(--sec-bd);            /* shows through the grid gaps as dividers */
  }
  .logo-grid{
    display:grid;
    grid-template-columns:repeat(5, 1fr);
    gap:1px;                             /* the hairlines */
  }

  /* Every cell is a white card in both themes so the light-background logos read on
     the dark section too. */
  .logo-cell{
    position:relative;
    display:flex; align-items:center; justify-content:center;
    min-height:112px; padding:28px 22px;
    background:#FFFFFF;
    text-decoration:none;
    transition:background .15s;
  }
  .logo-cell__img{
    max-height:30px; max-width:150px; width:auto; height:auto;
    object-fit:contain; display:block;
  }

  /* Story cells: clickable, with a small corner arrow as the "story attached" cue.
     The arrow and hover accent use the fixed brand terracotta (the cell is always
     white, so the theme accent isn't needed). */
  .logo-cell--story{ cursor:pointer; }
  .logo-cell__arrow{
    position:absolute; top:12px; right:12px;
    width:15px; height:15px;
    color:#9A8F84;                      /* muted taupe at rest */
    transition:color .15s, transform .15s;
  }
  .logo-cell--story:hover{ background:#FCF7F2; }        /* faint warm tint */
  .logo-cell--story:hover .logo-cell__arrow{
    color:var(--brand);
    transform:translate(1px,-1px);
  }
  .logo-cell--story:focus-visible{ outline:2px solid var(--brand); outline-offset:-2px; }

  @media (max-width:820px){
    .logo-grid{ grid-template-columns:repeat(2, 1fr); }
    .logo-cell{ min-height:96px; padding:22px 16px; }
  }
</style>
