---
// Section 4 — The fragmented stack problem (Navy). Before/after: a loose pile of
// six disconnected tools (FragmentedPile) gives way to the same six jobs wired
// into one platform (UnifiedGrid). Both animated embeds run on the navy section.
import FragmentedPile from './FragmentedPile.astro';
import UnifiedGrid from './UnifiedGrid.astro';
import { SIGNUP_URL } from '../data/site';
---
<section class="sec sec--navy frag" aria-labelledby="frag-title">
  <div class="wrap">
    <div class="sec-head reveal" style="text-align:center">
      <p class="eyebrow">The fragmented stack problem</p>
      <h2 id="frag-title" class="heading_primary" style="margin-top:8px">Six tools in your stack. Six invoices. <span class="accent">None of them talking to each other.</span></h2>
    </div>

    <div class="frag-block">
      <div class="frag-block__head reveal">
        <span class="frag-tag frag-tag--bad">Disconnected</span>
        <p class="frag-line">The average revenue team runs six tools to do one job. Each one siloed, none of them talking. Hover any tool to see where it leaves you exposed.</p>
      </div>
      <FragmentedPile />
    </div>

    <div class="frag-join reveal" aria-hidden="true">
      <span class="frag-join__line"></span>
      <span class="frag-join__label">hubsell unifies all six</span>
      <span class="frag-join__line"></span>
    </div>

    <div class="frag-block">
      <div class="frag-block__head reveal">
        <span class="frag-tag frag-tag--good">Connected</span>
        <p class="frag-line">One platform. One login. One flow. One invoice. The same six jobs wired together, so a signal becomes outreach and outreach lands in your CRM. Hover any capability to see what it does.</p>
      </div>
      <UnifiedGrid />
    </div>

    <div class="reveal" style="display:flex;justify-content:center;margin-top:36px">
      <a href={SIGNUP_URL} class="button is-large">Unify your stack today</a>
    </div>
  </div>
</section>

<style>
  .frag .sec-head{ max-width:46ch; margin-left:auto; margin-right:auto }
  .frag-block{ margin-top:40px }
  .frag-block__head{ max-width:60ch; margin:0 auto 14px; text-align:center }
  .frag-tag{ display:inline-block; font-family:var(--font-body); font-weight:600; font-size:12px; letter-spacing:.08em; text-transform:uppercase; padding:5px 12px; border-radius:999px; margin-bottom:10px }
  .frag-tag--bad{ color:#FFD9D2; background:rgba(232,98,80,.18); border:1px solid rgba(232,98,80,.5) }
  .frag-tag--good{ color:#CFEFDD; background:rgba(47,160,110,.20); border:1px solid rgba(47,160,110,.5) }
  .frag-line{ font-family:var(--font-body); font-size:16px; line-height:1.6; color:var(--sec-tx); opacity:.82; margin:0 }

  .frag-join{ display:flex; align-items:center; gap:16px; max-width:520px; margin:34px auto 0 }
  .frag-join__line{ flex:1; height:1px; background:linear-gradient(90deg, transparent, var(--sec-bd), transparent) }
  .frag-join__label{ font-family:var(--font-body); font-weight:500; font-size:13px; letter-spacing:.04em; color:var(--sec-tx); opacity:.7; white-space:nowrap }
</style>
