---
// Section 3 — The fragmented stack problem (Navy).
// Two tall cards: heading at top, embed below (02-fragmented-stack / 03-unified-stack).
import EmbedSlot from './EmbedSlot.astro';
import { SIGNUP_URL } from '../data/site';
---
<section class="sec sec--navy" aria-labelledby="frag-title">
  <div class="wrap">
    <div class="sec-head reveal">
      <p class="eyebrow">The fragmented stack problem</p>
      <h2 id="frag-title" class="heading_primary" style="margin-top:8px">Six tools in your stack. Six invoices. <span class="accent">None of them talking to each other.</span></h2>
    </div>

    <div class="grid grid-2 reveal-stagger" style="align-items:stretch;gap:24px">
      <div class="card" style="display:flex;flex-direction:column;gap:8px">
        <p class="eyebrow" style="color:var(--error);opacity:1">Disconnected</p>
        <h3 class="heading_secondary">Fragmented GTM stack</h3>
        <p class="subheading" style="opacity:.85;margin-bottom:8px">The average revenue team <span class="accent">runs six tools to do one job</span>. Each one siloed. None of them talking.</p>
        <EmbedSlot name="02-fragmented-stack" recolor="navy" minHeight="380px" note="The fragmented-stack widget drops in here." />
      </div>

      <div class="card" style="display:flex;flex-direction:column;gap:8px;border-color:color-mix(in srgb,var(--accent-on) 45%,var(--sec-bd))">
        <p class="eyebrow" style="color:var(--positive);opacity:1">Connected</p>
        <h3 class="heading_secondary">Unified GTM stack</h3>
        <p class="subheading" style="opacity:1;margin-bottom:8px">hubsell <span class="accent">replaces all six with one platform</span>. One login. One flow. One invoice.</p>
        <EmbedSlot name="03-unified-stack" minHeight="380px" note="The unified-stack widget drops in here." />
      </div>
    </div>

    <div class="reveal" style="display:flex;justify-content:center;margin-top:40px">
      <a href={SIGNUP_URL} class="button is-large">Unify your stack today</a>
    </div>
  </div>
</section>
