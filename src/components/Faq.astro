---
// ============================= LEARNING NOTES =============================
// A COMPONENT WITH ALL FOUR PARTS a .astro component can have: frontmatter
// (data), template (markup), <script> (browser behavior) and, in most
// siblings, <style> (looks; this one leans on global.css instead). Study it
// as the exemplar for "interactive section component":
//
// 1. DATA: no props here. It reads the locale from the URL
//    (Astro.currentLocale) and pulls its copy from src/data/home-i18n.ts.
//    That is the standard translation pattern in this repo.
// 2. MARKUP: {faqs.map((f, idx) => ...)} loops the FAQ list; the second
//    map argument idx is the position, used to open the first item. Note
//    the conditional class: a template literal appends ' is-open' only for
//    idx 0. aria-expanded is an ACCESSIBILITY attribute telling screen
//    readers whether the accordion item is open.
// 3. BEHAVIOR: the <script> at the bottom runs in the browser. It finds
//    every [data-accordion], guards against double-binding with a
//    data-ready flag, and toggles panels on click by animating max-height.
//    The `!` after querySelector is TypeScript for "trust me, not null".
//    It re-runs on astro:page-load so client-side navigation keeps working.
// ==========================================================================
// Section 13 — FAQ. Accordion of the homepage-flagged FAQs from the shared FAQ
// source (src/data/faqs.ts); the full list lives at /faqs.
import { getHome } from '../data/home-i18n';
import { asLocale, localizedHref } from '../i18n/utils';
const L = asLocale(Astro.currentLocale);
const { faqs, s } = getHome(L);
---
<section class="sec sec--sand" aria-labelledby="faq-title">
  <div class="wrap" style="max-width:820px">
    <div class="sec-head reveal">
      <p class="eyebrow">{s.faqSec.eyebrow}</p>
      <h2 id="faq-title" class="heading_primary" style="margin-top:8px">{s.faqSec.titlePre}<span class="accent">{s.faqSec.titleAccent}</span>{s.faqSec.titlePost}</h2>
    </div>

    <div class="acc reveal" data-accordion>
      {faqs.map((f, idx) => (
        <div class={`acc__item${idx === 0 ? ' is-open' : ''}`}>
          <h3 style="margin:0">
            <button class="acc__btn" type="button" aria-expanded={idx === 0 ? 'true' : 'false'}>
              {f.question}
            </button>
          </h3>
          <div class="acc__panel" style={idx === 0 ? 'max-height:400px' : ''} set:html={f.answer}></div>
        </div>
      ))}
    </div>

    <p class="reveal" style="margin-top:28px">
      <a href={localizedHref(L, '/faqs')} class="link">{s.faqSec.seeAll}</a>
    </p>
  </div>
</section>

<script>
  function initAccordions() {
    document.querySelectorAll<HTMLElement>('[data-accordion]').forEach((acc) => {
      if (acc.dataset.ready) return;
      acc.dataset.ready = '1';
      acc.querySelectorAll<HTMLElement>('.acc__item').forEach((item) => {
        const btn = item.querySelector<HTMLButtonElement>('.acc__btn')!;
        const panel = item.querySelector<HTMLElement>('.acc__panel')!;
        btn.addEventListener('click', () => {
          const open = item.classList.toggle('is-open');
          btn.setAttribute('aria-expanded', String(open));
          panel.style.maxHeight = open ? panel.scrollHeight + 'px' : '';
        });
      });
    });
  }
  initAccordions();
  document.addEventListener('astro:page-load', initAccordions);
</script>
