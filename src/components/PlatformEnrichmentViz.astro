---
// Static product motif for /platform/enrichment. White card, navy ink in both
// themes. Shows a contact record filling from several sources, then verified.
---
<div class="enr">
  <div class="enr__top">
    <span class="enr__title">Contact record</span>
    <span class="enr__done">&#10003; Enriched</span>
  </div>

  <div class="enr__rows">
    <div class="enr__row"><span class="enr__k">Name</span><span class="enr__v">Complete</span><span class="enr__src">S1</span><span class="enr__ok">&#10003;</span></div>
    <div class="enr__row"><span class="enr__k">Work email</span><span class="enr__v">Verified</span><span class="enr__src">S2</span><span class="enr__ok">&#10003;</span></div>
    <div class="enr__row"><span class="enr__k">Phone</span><span class="enr__v">Complete</span><span class="enr__src">S3</span><span class="enr__ok">&#10003;</span></div>
    <div class="enr__row"><span class="enr__k">Role</span><span class="enr__v">Complete</span><span class="enr__src">S4</span><span class="enr__ok">&#10003;</span></div>
    <div class="enr__row"><span class="enr__k">Company, size, industry</span><span class="enr__v">Complete</span><span class="enr__src">S6</span><span class="enr__ok">&#10003;</span></div>
  </div>

  <div class="enr__foot">6 live sources, waterfalled &middot; verified at the point of use</div>
</div>

<style>
  .enr{background:#fff;border:1px solid #ECE1D4;border-radius:16px;padding:22px;
    width:100%;font-family:var(--font-body);color:#192341;box-shadow:0 1px 2px rgba(25,35,65,.05)}
  .enr__top{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
  .enr__title{font-family:var(--font-head);font-weight:600;font-size:1.05rem}
  .enr__done{font-size:12px;font-weight:600;color:#155C3F}
  .enr__rows{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
  .enr__row{display:grid;grid-template-columns:1fr auto auto auto;align-items:center;gap:12px;
    background:#FBF7F1;border:1px solid #ECE1D4;border-radius:10px;padding:11px 14px}
  .enr__k{font-size:13.5px;font-weight:500;color:#192341}
  .enr__v{font-size:12px;color:#155C3F;font-weight:500}
  .enr__src{font-family:ui-monospace,Menlo,monospace;font-size:11px;color:#978E84;
    background:#ECE1D4;border-radius:6px;padding:2px 7px}
  .enr__ok{color:#2FA06E;font-weight:700;font-size:14px}
  .enr__foot{font-size:12px;color:#978E84;border-top:1px solid #ECE1D4;padding-top:14px}
</style>
