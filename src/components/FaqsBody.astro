---
// ============================= LEARNING NOTES =============================
// PAGE BODY component: a thin route file under src/pages/ owns the layout,
// meta and structured data, and hands the actual rendering to this file.
// The split exists so the de/ and nl/ route copies reuse this body and it
// translates itself. Annotated exemplars for the pattern:
// src/components/GlossaryIndex.astro and src/components/SolutionDetail.astro.
// No props: it reads Astro.currentLocale and fetches its own strings
// from src/data/ (faqs-i18n, site).
// Uses set:html to inject trusted HTML strings; see the warning about it
// in src/pages/insights/[slug].astro.
// Has a browser <script>: runs in the visitor's browser, re-inits on
// astro:page-load. Build-time frontmatter vs browser script is explained
// in src/layouts/BaseLayout.astro.
// The <style> block is scoped to this component (Astro hashes the
// selectors), styled with the design tokens from src/styles/global.css.
// ==========================================================================
// FAQs page body. Single source rendered by /faqs (English) and /de/faqs (German);
// self-localizes from Astro.currentLocale. The FAQPage JSON-LD is built in the
// route files (so its slot="head" reaches BaseLayout); this renders the visible
// accordion and CTA. Accordion styles are global (.acc in global.css).
import { asLocale, localizedHref } from '../i18n/utils';
import { getFaqs } from '../data/faqs-i18n';
import { getFaqsPage } from '../i18n/pages';
import { SIGNUP_URL, DEMO_URL } from '../data/site';

const L = asLocale(Astro.currentLocale);
const c = getFaqsPage(L);
const faqList = getFaqs(L);
---
<section class="sec sec--paper" aria-labelledby="faqs-title">
  <div class="wrap" style="max-width:820px">
    <div class="sec-head">
      <p class="eyebrow is-accent">{c.eyebrow}</p>
      <h1 id="faqs-title" class="heading_primary" style="margin-top:8px">{c.title}</h1>
      <p class="subheading" style="margin-top:14px">{c.subPre}<a href={localizedHref(L, DEMO_URL)} class="link">{c.demoLink}</a>{c.subPost}</p>
    </div>

    <div class="acc" data-accordion style="margin-top:30px">
      {faqList.map((f, idx) => (
        <div class={`acc__item${idx === 0 ? ' is-open' : ''}`} id={f.slug}>
          <h2 style="margin:0">
            <button class="acc__btn" type="button" aria-expanded={idx === 0 ? 'true' : 'false'}>
              {f.question}
            </button>
          </h2>
          <div class="acc__panel" style={idx === 0 ? 'max-height:600px' : ''} set:html={f.answer}></div>
        </div>
      ))}
    </div>

    <div class="faqs-cta">
      <p class="faqs-cta__title">{c.ctaTitle}</p>
      <p class="faqs-cta__text">{c.ctaText}</p>
      <div class="faqs-cta__row">
        <a class="button is-large" href={localizedHref(L, SIGNUP_URL)}>{c.ctaPrimary}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .faqs-cta{
    margin-top:clamp(40px,6vw,60px); padding-top:clamp(32px,4vw,44px);
    border-top:1px solid var(--sec-bd); text-align:center;
  }
  .faqs-cta__title{ font-family:var(--font-head); font-weight:600; font-size:clamp(1.4rem,2.6vw,1.8rem); letter-spacing:-.02em; color:var(--sec-tx); margin:0; }
  .faqs-cta__text{ font-family:var(--font-body); font-size:1.0625rem; line-height:1.6; color:var(--sec-tx); opacity:.78; max-width:50ch; margin:10px auto 22px; }
  .faqs-cta__row{ display:flex; flex-wrap:wrap; gap:12px; justify-content:center; }
</style>

<script>
  function initFaqAccordion() {
    document.querySelectorAll<HTMLElement>('[data-accordion]').forEach((acc) => {
      if (acc.dataset.ready) return;
      acc.dataset.ready = '1';
      acc.querySelectorAll<HTMLElement>('.acc__item').forEach((item) => {
        const btn = item.querySelector<HTMLButtonElement>('.acc__btn')!;
        const panel = item.querySelector<HTMLElement>('.acc__panel')!;
        if (item.classList.contains('is-open')) panel.style.maxHeight = panel.scrollHeight + 'px';
        btn.addEventListener('click', () => {
          const open = item.classList.toggle('is-open');
          btn.setAttribute('aria-expanded', String(open));
          panel.style.maxHeight = open ? panel.scrollHeight + 'px' : '';
        });
      });
    });
  }
  initFaqAccordion();
  document.addEventListener('astro:page-load', initFaqAccordion);
</script>
