---
// ============================= LEARNING NOTES =============================
// SECTION component: one visual band, stacked by a page file. The pattern
// (locale lookup, strings from src/data, semantic markup, scoped style) is
// explained in src/components/Hero.astro; browser-script mechanics in
// src/components/Faq.astro.
// No props: it reads Astro.currentLocale and fetches its own strings
// from src/data/ (home-i18n, site).
// ==========================================================================
// Section 11 — Your LinkedIn content is already generating demand (Paper).
import { SIGNUP_URL } from '../data/site';
import { getHome } from '../data/home-i18n';
import { asLocale, localizedHref } from '../i18n/utils';
const L = asLocale(Astro.currentLocale);
const { s } = getHome(L);
const now = s.loop.now;
const beta = s.loop.beta;
---
<section class="sec sec--paper" aria-labelledby="loop-title">
  <div class="wrap">
    <div class="grid grid-2 reveal-stagger" style="align-items:center;gap:40px">
      <div>
        <p class="eyebrow is-accent">{s.loop.eyebrow}</p>
        <h2 id="loop-title" class="heading_primary" style="margin:8px 0 14px">{s.loop.titlePre}<span class="accent">{s.loop.titleAccent}</span>{s.loop.titlePost}</h2>
        <p class="paragraph">{s.loop.body}</p>
        <a href={localizedHref(L, SIGNUP_URL)} class="button" style="margin-top:22px">{s.loop.cta}</a>
      </div>

      <div class="card">
        <p class="eyebrow" style="margin-bottom:12px">{s.loop.nowLabel}</p>
        <ul class="ticks" style="margin-top:0">
          {now.map((n) => <li>{n}</li>)}
        </ul>
        <p class="eyebrow" style="margin:20px 0 12px">{s.loop.betaLabel}</p>
        <ul class="ticks" style="margin-top:0">
          {beta.map((b) => <li>{b}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>
