---
// Top utility bar — visible only at the very top of the page; it sits above the
// sticky nav in normal flow, so it scrolls away while the nav stays stuck (the
// HubSpot pattern). Holds the language control, the light/dark theme toggle, and
// log in. Uses the global theme tokens so it flips with light/dark mode.
const LOGIN_URL = 'https://app.hubsell.com/';
---
<div class="topbar">
  <div class="topbar__inner">
    <div class="topbar__cluster">
      <div class="topbar__lang">
        <button type="button" class="topbar__item topbar__langbtn" aria-haspopup="true" aria-expanded="false">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a15 15 0 0 1 0 18"/><path d="M12 3a15 15 0 0 0 0 18"/></svg>
          <span class="topbar__langword">English</span>
          <svg class="topbar__chev" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <ul class="topbar__menu" role="menu">
          <li><button type="button" role="menuitem" class="is-current" data-lang="en">English</button></li>
          <li><span class="is-soon">Deutsch</span></li>
          <li><span class="is-soon">Nederlands</span></li>
          <li><span class="is-soon">Français</span></li>
          <li><span class="is-soon">Español</span></li>
          <li><span class="is-soon">Português (BR)</span></li>
        </ul>
      </div>

      <button type="button" class="topbar__item js-theme-toggle" aria-pressed="false">
        <svg class="ic-moon" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="ic-sun" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <span class="js-theme-label">Dark mode</span>
      </button>
    </div>

    <div class="topbar__cluster">
      <a class="topbar__item" href={LOGIN_URL}>Log in</a>
    </div>
  </div>
</div>

<style>
  .topbar{
    background:var(--bg); color:var(--text-2);
    border-bottom:1px solid var(--border);
    transition:background .25s, color .25s, border-color .25s;
  }
  .topbar__inner{
    max-width:var(--maxw); margin:0 auto; padding:6px clamp(20px,5vw,56px);
    display:flex; align-items:center; justify-content:space-between; gap:16px;
  }
  .topbar__cluster{ display:flex; align-items:center; gap:4px; }
  .topbar__item{
    display:inline-flex; align-items:center; gap:7px;
    font-family:var(--font-body); font-size:13px; font-weight:500; line-height:1;
    color:var(--text-2); background:transparent; border:0; cursor:pointer;
    padding:7px 10px; border-radius:8px; text-decoration:none;
    transition:color .15s, background .15s;
  }
  .topbar__item:hover{ color:var(--text); background:color-mix(in srgb, var(--text) 6%, transparent); }
  .topbar__chev{ opacity:.55; }
  .ic-sun{ display:none; }
  [data-theme="dark"] .ic-sun{ display:block; }
  [data-theme="dark"] .ic-moon{ display:none; }

  .topbar__lang{ position:relative; }
  .topbar__menu{
    position:absolute; top:calc(100% + 4px); left:0; min-width:200px; margin:0; padding:6px;
    list-style:none; background:var(--bg); border:1px solid var(--border);
    border-radius:var(--radius); box-shadow:0 12px 30px rgba(0,0,0,.16);
    opacity:0; visibility:hidden; transform:translateY(-5px);
    transition:opacity .15s, transform .15s, visibility .15s; z-index:60;
  }
  .topbar__lang:hover .topbar__menu, .topbar__lang:focus-within .topbar__menu{ opacity:1; visibility:visible; transform:none; }
  .topbar__menu button, .topbar__menu span{
    display:flex; align-items:center; width:100%; text-align:left; font:500 13px/1.2 var(--font-body);
    padding:8px 10px; border-radius:7px; border:0; background:transparent; color:var(--text-2);
  }
  .topbar__menu button{ cursor:pointer; }
  .topbar__menu button.is-current{ color:var(--accent-on); }
  .topbar__menu button:hover{ background:color-mix(in srgb, var(--accent-on) 14%, transparent); color:var(--text); }
  .topbar__menu .is-soon{ color:var(--text-3); cursor:default; }
  .topbar__menu .is-soon::after{
    content:"Soon"; margin-left:auto; font-size:9px; font-weight:600; letter-spacing:.05em; text-transform:uppercase;
    padding:2px 6px; border-radius:999px; background:color-mix(in srgb, var(--text) 12%, transparent); color:var(--text-3);
  }

  @media (max-width:600px){
    .topbar__langword, .js-theme-label{ display:none; }
    .topbar__item{ padding:7px 8px; }
  }
</style>

<script>
  // Light/dark toggle. The chosen mode is stored and re-applied before paint by
  // the inline script in BaseLayout, so there is no flash on load. Toggling also
  // nudges the colour-aware nav to re-sample (it keys off section backgrounds,
  // which change with the theme).
  function initTheme() {
    const root = document.documentElement;

    function syncButtons(mode: string) {
      document.querySelectorAll<HTMLButtonElement>('.js-theme-toggle').forEach((b) => {
        const dark = mode === 'dark';
        b.setAttribute('aria-pressed', dark ? 'true' : 'false');
        const lbl = b.querySelector('.js-theme-label');
        if (lbl) lbl.textContent = dark ? 'Light mode' : 'Dark mode';
      });
    }

    function apply(mode: string) {
      root.setAttribute('data-theme', mode);
      try { localStorage.setItem('theme', mode); } catch (e) {}
      syncButtons(mode);
      window.dispatchEvent(new CustomEvent('hubsell:themechange')); // re-tint the colour-aware nav
    }

    document.querySelectorAll<HTMLButtonElement>('.js-theme-toggle').forEach((b) => {
      if (b.dataset.bound) return;
      b.dataset.bound = 'true';
      b.addEventListener('click', () => {
        const cur = root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
        apply(cur === 'dark' ? 'light' : 'dark');
      });
    });

    syncButtons(root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light');
  }
  initTheme();
  document.addEventListener('astro:page-load', initTheme);
</script>
