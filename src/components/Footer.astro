---
// Footer — fixed navy chrome. The columns are the expanded navigation: the small
// collections (customer stories, comparisons) are listed in full and pulled from the
// content collections, so new entries appear here automatically. The remaining live
// nav links, the account links, and the legal links come from src/data/navigation.ts.
import { getCollection } from 'astro:content';
import { menuGroups, topLinks, footerLinks, platformLinks, solutionsTeamLinks, solutionsRoleLinks, legalLinks, liveLinks } from '../data/navigation';
import { SIGNUP_URL } from '../data/site';
import { asLocale, useTranslations, localizedHref } from '../i18n/utils';

const year = new Date().getFullYear();
const LOGO_LIGHT = 'https://assets.hubsell.com/logo/hubsell-wordmark-light.svg'; // cream wordmark for the dark footer

const locale = asLocale(Astro.currentLocale);
const t = useTranslations(locale);

// Collections, expanded, in the same order as their overview pages.
const CS_ORDER = ['safran', 'staffbase', 'verhaert', 'elium', 'workspace365', 'sensolus'];
const CMP_ORDER = ['apollo', 'zoominfo', 'cognism', 'lusha', 'seamless'];
const byOrder = (order) => (a, b) => {
  const i = order.indexOf(a.slug), j = order.indexOf(b.slug);
  return (i < 0 ? 99 : i) - (j < 0 ? 99 : j);
};
const stories = (await getCollection('customerstories', (s) => !s.data.draft)).sort(byOrder(CS_ORDER));
const comparisons = (await getCollection('comparisons')).sort(byOrder(CMP_ORDER));

// Resources column: the Learn nav links that aren't expanded into their own column,
// plus the footer-only links, plus the top-level links. Company links get their own
// column so Contact (and future About/Careers) don't land under Resources.
const expanded = new Set(['/customerstories', '/comparisons']);
const learn = menuGroups.find((g) => g.heading === 'Learn');
const company = menuGroups.find((g) => g.heading === 'Company');
const learnLinks = learn ? liveLinks(learn.links).filter((l) => !expanded.has(l.href)) : [];
const companyLinks = company ? liveLinks(company.links) : [];

// Get started: Pricing plus Book a demo (Sign up rejoins once the signup page ships).
const getStartedCol = [
  ...liveLinks(topLinks),                                   // Pricing (/#pricing)
  { label: t('cta.trial'), href: SIGNUP_URL, external: true }, // Book a demo
];
// Solutions column = the team pages; Roles column = the role pages (Apollo's split).
const solutionsCol = liveLinks(solutionsTeamLinks);
const rolesCol = liveLinks(solutionsRoleLinks);
// Resources = the Learn links (Insights and so on) plus the footer-only links (Use cases, FAQ).
const resourceLinks = [...learnLinks, ...footerLinks];

const columns = [
  { heading: t('footer.heading.getstarted'), links: getStartedCol },
  { heading: t('footer.heading.solutions'), links: solutionsCol },
  { heading: t('footer.heading.platform'), links: liveLinks(platformLinks) },
  { heading: t('footer.heading.roles'), links: rolesCol },
  { heading: t('footer.heading.resources'), links: resourceLinks },
  {
    heading: t('footer.heading.customerstories'),
    links: [
      ...stories.map((s) => ({ label: s.data.company || s.data.title, href: `/customerstories/${s.slug}` })),
      { label: t('footer.all.customerstories'), href: '/customerstories', all: true },
    ],
  },
  {
    heading: t('footer.heading.comparisons'),
    links: [
      ...comparisons.map((c) => ({ label: c.data.title, href: `/vs/${c.slug}` })),
      { label: t('footer.all.comparisons'), href: '/comparisons', all: true },
    ],
  },
  { heading: t('footer.heading.company'), links: companyLinks },
].filter((c) => c.links.length);
---
<footer class="sec site-footer">
  <div class="wrap">
    <div class="site-footer__top">
      <div class="site-footer__brand-block">
        <a href={localizedHref(locale, '/')} class="site-footer__brand" aria-label="hubsell home">
          <img class="site-footer__logo" src={LOGO_LIGHT} alt="hubsell" width="124" />
        </a>
        <p class="site-footer__tag">{t('footer.tagline')}</p>
      </div>

      <nav class="site-footer__cols" aria-label="Footer">
        {columns.map((c) => (
          <div class="site-footer__col">
            <p class="site-footer__colhead">{c.heading}</p>
            <ul>
              {c.links.map((l) => (<li><a href={localizedHref(locale, l.href)} class={l.all ? 'is-all' : undefined}>{l.key ? t(l.key) : l.label}</a></li>))}
            </ul>
          </div>
        ))}
      </nav>
    </div>

    <nav class="site-footer__legal" aria-label="Legal">
      {legalLinks.map((l) => (<a href={localizedHref(locale, l.href!)}>{l.key ? t(l.key) : l.label}</a>))}
    </nav>

    <div class="site-footer__bottom">
      <p class="site-footer__meta">© 2016–{year} hubsell UG · Friedrichstraße 155, 10117 Berlin, {t('footer.country')} · HRB 175309B · DE305258320</p>
    </div>
  </div>
</footer>

<style>
  .site-footer{
    /* fixed navy chrome, in both themes */
    --sec-bg:var(--chrome-bg); --sec-tx:var(--chrome-tx);
    --sec-bd:var(--chrome-bd); --sec-card:var(--chrome-card);
    padding:clamp(48px,6vw,72px) 0 clamp(28px,4vw,40px);
  }
  .site-footer__top{
    display:grid; grid-template-columns:minmax(220px,1.1fr) 3fr; gap:40px clamp(24px,4vw,56px);
    padding-bottom:32px; border-bottom:1px solid var(--sec-bd);
  }
  @media (max-width:820px){ .site-footer__top{ grid-template-columns:1fr; gap:34px; } }

  .site-footer__brand{ display:inline-block; text-decoration:none; }
  .site-footer__logo{ height:auto; display:block; }
  .site-footer__tag{
    font-family:var(--font-body); font-size:14px; line-height:1.55; color:var(--sec-tx);
    opacity:.62; max-width:34ch; margin:16px 0 0;
  }

  .site-footer__cols{ display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:30px 24px; }
  .site-footer__col ul{ list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:11px; }
  .site-footer__colhead{
    font:600 11px/1 var(--font-body); letter-spacing:.08em; text-transform:uppercase;
    color:var(--sec-tx); opacity:.5; margin:0 0 14px;
  }
  .site-footer__col a{
    font-family:var(--font-body); font-size:14px; color:var(--sec-tx); opacity:.72;
    text-decoration:none; transition:opacity .15s, color .15s;
  }
  .site-footer__col a:hover{ opacity:1; color:var(--accent-on); }
  .site-footer__col a.is-all{ color:var(--accent-on); opacity:.92; font-weight:500; }
  .site-footer__col a.is-all:hover{ opacity:1; }

  .site-footer__legal{ display:flex; flex-wrap:wrap; gap:10px 22px; margin:28px 0 0; }
  .site-footer__legal a{
    font-family:var(--font-body); font-size:13px; color:var(--sec-tx); opacity:.6;
    text-decoration:none; transition:opacity .15s, color .15s;
  }
  .site-footer__legal a:hover{ opacity:1; color:var(--accent-on); }

  .site-footer__bottom{
    display:flex; flex-wrap:wrap; gap:16px 28px; align-items:center; justify-content:space-between;
    margin:24px 0 0;
  }
  .site-footer__meta{ font-size:13px; color:var(--sec-tx); opacity:.5; margin:0; }
</style>
