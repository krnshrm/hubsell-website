---
// Hero pipeline flow — the signature visual.
// REWRITTEN: the connecting line + return loop are now pure CSS, positioned
// relative to the real cards (top/bottom: half a card-height), so they always
// align to the first and last card centres regardless of stack height. This is
// immune to the global `img,svg{max-width:100%}` reset that was scaling the old
// fixed-coordinate SVG layer and compressing the loop. The travelling light is a
// CSS pulse that rides the same closed circuit (down the spine, around the loop).
//   • spine + loop + pulse glow → terracotta accent (var(--accent-on), theme-aware)
//   • per-step icon hues → brand palette (terracotta/amber/coral/navy/green)
// Motion is gated behind the .has-anim class (reduced-motion / no-JS show the
// cards and the static connector at rest).
import { et } from '../data/embed-i18n';
import { asLocale, localizedHref } from '../i18n/utils';
const L = asLocale(Astro.currentLocale);
// Each hero card links to its matching stage in the pipeline section for now.
// Swap these to the /platform/* pages when those ship.
const STAGE = {
  data: localizedHref(L, '/platform/live-data'),
  outreach: localizedHref(L, '/platform/multichannel-outreach'),
  sync: localizedHref(L, '/platform/crm-sync'),
};
---
<div class="hubsell-flow-embed">
  <div class="hw-track-container">

    <!-- Connector layer (behind the cards). Pure CSS — self-aligning. -->
    <!-- Spine: first card centre -> last card centre, down the middle.
         Masked by the opaque cards, so it only shows in the gaps. -->
    <div class="hw-spine" aria-hidden="true"></div>
    <!-- Return loop: last card's left edge, around the left, to the first
         card's left edge. The "[" bracket auto-spans the full stack height. -->
    <div class="hw-loop" aria-hidden="true"></div>
    <!-- Travelling light that flows the closed circuit. -->
    <div class="hw-pulse" aria-hidden="true"></div>

    <!-- Group labels: absolute, so they never shift the cards or the connector. -->
    <span class="hw-group-label hw-gl-1">{et(L, "Live data")}</span>
    <span class="hw-group-label hw-gl-2">{et(L, "Outreach")}</span>
    <span class="hw-group-label hw-gl-3">{et(L, "CRM sync")}</span>

    <!-- Step 1: Source live contacts (group: Live data) -->
    <a class="hw-card step-1" href={STAGE.data} style="--color: #E0533A; --lit-delay: -0.5s;">
      <div class="hw-icon-box">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
          <circle cx="8.5" cy="7" r="4"></circle>
          <line x1="20" y1="8" x2="20" y2="14"></line>
          <line x1="23" y1="11" x2="17" y2="11"></line>
        </svg>
      </div>
      <div class="hw-text-group">
        <p class="hw-title">{et(L, "Source live contacts")}</p>
        <p class="hw-subtitle">{et(L, "pulled from LinkedIn, matched to your ICP")}</p>
      </div>
    </a>

    <!-- Step 2: Layer buying signals (group: Live data) -->
    <a class="hw-card step-2" href={STAGE.data} style="--color: #F4A93C; --lit-delay: 0.78s;">
      <div class="hw-icon-box">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
          <polyline points="17 6 23 6 23 12"></polyline>
        </svg>
      </div>
      <div class="hw-text-group">
        <p class="hw-title">{et(L, "Layer buying signals")}</p>
        <p class="hw-subtitle">{et(L, "job changes, events, post engagement")}</p>
      </div>
    </a>

    <!-- Step 3: Validate contact details (group: Live data) -->
    <a class="hw-card step-3" href={STAGE.data} style="--color: #E86250; --lit-delay: 2.04s;">
      <div class="hw-icon-box">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
      </div>
      <div class="hw-text-group">
        <p class="hw-title">{et(L, "Validate contact details")}</p>
        <p class="hw-subtitle">{et(L, "checked on the spot, catch-alls included")}</p>
      </div>
    </a>

    <!-- Step 4: Run email, LinkedIn, & phone (group: Outreach) -->
    <a class="hw-card step-4" href={STAGE.outreach} style="--color: #192341; --lit-delay: 3.30s;">
      <div class="hw-icon-box">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-10 5-10-5"></path>
        </svg>
      </div>
      <div class="hw-text-group">
        <p class="hw-title">{et(L, "Run email, LinkedIn, & phone")}</p>
        <p class="hw-subtitle">{et(L, "one coordinated flow, calls as CRM tasks")}</p>
      </div>
    </a>

    <!-- Step 5: Sync to your CRM (group: CRM sync) -->
    <a class="hw-card step-5" href={STAGE.sync} style="--color: #2FA06E; --lit-delay: 4.56s;">
      <div class="hw-icon-box">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
          <path d="M3 3v5h5"></path>
          <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"></path>
          <path d="M16 21v-5h5"></path>
        </svg>
      </div>
      <div class="hw-text-group">
        <p class="hw-title">{et(L, "Sync to your CRM")}</p>
        <p class="hw-subtitle">{et(L, "Salesforce, HubSpot, Pipedrive, auto-logged")}</p>
      </div>
    </a>

  </div>
</div>

<style>
  .hubsell-flow-embed{
    display:flex; justify-content:center;
    font-family:'Instrument Sans',system-ui,sans-serif;
    /* left padding holds the return loop without clipping */
    padding:40px 20px 40px 80px;
    width:100%; box-sizing:border-box; background:transparent;
  }
  .hubsell-flow-embed *{box-sizing:border-box}

  .hw-track-container{
    /* --card-h drives BOTH the card height and the connector anchor points,
       so they can never drift apart. */
    --card-h:88px;
    --gap:48px;             /* space between cards */
    --label-drop:22px;      /* how high a group label sits above its card */
    --half:calc(var(--card-h) / 2);
    --loop-w:56px;             /* how far the return loop reaches left of the cards */
    display:flex; flex-direction:column; align-items:center;
    gap:var(--gap); position:relative; width:266px; flex-shrink:0;
  }

  /* ---------- Connector: spine (centre) ---------- */
  /* top/bottom = half a card, so the line spans first-card centre -> last-card centre
     no matter how tall the stack is. z-index below the cards => masked behind
     them, visible only in the gaps. */
  .hw-spine{
    position:absolute; z-index:1;
    top:var(--half); bottom:var(--half);
    left:50%; transform:translateX(-50%);
    width:2px; background:var(--accent-on);
    border-radius:2px;
    opacity:1; transition:opacity .7s cubic-bezier(.16,1,.3,1);
  }

  /* ---------- Connector: return loop (left bracket) ---------- */
  /* A "[" — left + top + bottom dashed borders, open on the right. Its top edge
     sits at the first card's centre, its bottom edge at the last card's centre; the open right side
     meets the cards' left edge (tucked 2px under, so there's no seam). */
  .hw-loop{
    position:absolute; z-index:1;
    top:var(--half); bottom:var(--half);
    left:calc(-1 * var(--loop-w)); width:calc(var(--loop-w) + 2px);
    border:2px dashed var(--accent-on);
    border-right:0;
    border-radius:14px 0 0 14px;
    opacity:1; transition:opacity .7s cubic-bezier(.16,1,.3,1);
  }

  /* ---------- Travelling light ---------- */
  /* Rides the closed circuit: down the spine (masked except in the gaps), under
     the last card to the loop, up the loop's left side, back under the first
     card. Positions are container-relative, so it tracks the cards exactly. */
  .hw-pulse{
    position:absolute; z-index:1; pointer-events:none;
    width:9px; height:9px; border-radius:50%;
    background:#FFFFFF;
    box-shadow:0 0 4px 1px rgba(224,83,58,1), 0 0 9px 3px rgba(232,98,80,.85);
    left:133px; top:var(--half);             /* start: card-1 centre on the spine */
    transform:translate(-50%,-50%);
    opacity:0;                                /* appears only once flowing (JS) */
    will-change:left,top;
  }

  /* 133px = centre of the 266px stack; the loop x tracks --loop-w (the +1px lands
     on the 2px border's centreline) so the light stays on the loop at every width. */
  @keyframes hw-pulse-flow{
    0%   { left:133px;  top:var(--half); }                                  /* spine top  (card 1) */
    42%  { left:133px;  top:calc(100% - var(--half)); }                     /* spine base (last card) */
    50%  { left:calc(-1 * var(--loop-w) + 1px); top:calc(100% - var(--half)); }  /* across to loop foot */
    92%  { left:calc(-1 * var(--loop-w) + 1px); top:var(--half); }               /* up the loop         */
    100% { left:133px;  top:var(--half); }                                  /* across back to spine  */
  }

  /* Card glow as the pulse passes behind it — same look as :hover. The lit
     pulse sits in the first ~12% of the cycle; each card's --lit-delay shifts
     it to match the light's vertical position on the spine. */
  @keyframes hw-card-lit{
    0%, 12%, 100%{
      transform:translateY(0);
      box-shadow:0 4px 12px rgba(0,0,0,.04);
      border-color:var(--border);
    }
    4%{
      transform:translateY(-3px);
      box-shadow:0 8px 24px rgba(0,0,0,.08);
      border-color:var(--color);
    }
  }
  @keyframes hw-icon-lit{
    0%, 12%, 100%{
      border-color:var(--border);
      background-color:#FBF7F1;
    }
    4%{
      border-color:var(--color);
      background-color:color-mix(in srgb, var(--color) 8%, transparent);
    }
  }

  /* Pre-animation state when motion is enabled (BaseLayout adds .has-anim). */
  html.has-anim .hw-spine,
  html.has-anim .hw-loop,
  html.has-anim .hw-group-label{opacity:0}
  html.has-anim .hw-card{opacity:0}

  /* Flowing state (added by JS after the cards reveal). Must come AFTER the
     .has-anim rules so it wins at equal specificity. */
  .is-flowing .hw-spine,
  .is-flowing .hw-loop{opacity:1}
  .is-flowing .hw-group-label{opacity:.6}
  .is-flowing .hw-pulse{opacity:1; animation:hw-pulse-flow 12s linear infinite}
  /* Period matches the pulse (12s) so the cascade stays locked to the light. */
  .is-flowing .hw-card{
    animation-name:hw-card-lit; animation-duration:12s;
    animation-timing-function:linear; animation-iteration-count:infinite;
    animation-delay:var(--lit-delay,0s);
  }
  .is-flowing .hw-icon-box{
    animation-name:hw-icon-lit; animation-duration:12s;
    animation-timing-function:linear; animation-iteration-count:infinite;
    animation-delay:var(--lit-delay,0s);
  }

  /* ---------- Cards ---------- */
  .hw-card{
    width:266px; height:var(--card-h); background:#FFFFFF;  /* opaque => masks the spine behind it */
    border:1px solid var(--border); border-radius:8px;
    display:flex; align-items:center; padding:0 16px; gap:14px;
    box-shadow:0 4px 12px rgba(0,0,0,.04);
    position:relative; z-index:3; cursor:pointer; text-decoration:none; color:inherit;
    transition:transform .3s cubic-bezier(.16,1,.3,1), box-shadow .3s ease, border-color .3s ease;
  }
  .hw-card:hover{
    transform:translateY(-3px)!important;
    box-shadow:0 8px 24px rgba(0,0,0,.08)!important;
    border-color:var(--color)!important; z-index:10;
  }

  .hw-icon-box{
    width:39px; height:39px; border:1px solid var(--border); border-radius:6px;
    display:flex; justify-content:center; align-items:center;
    color:var(--color); background:#FBF7F1;
    transition:background-color .25s ease, border-color .25s ease; flex-shrink:0;
  }
  .hw-card:hover .hw-icon-box{
    border-color:var(--color)!important;
    background-color:color-mix(in srgb, var(--color) 8%, transparent)!important;
  }

  .hw-text-group{display:flex; flex-direction:column; gap:2px}
  .hw-title{font-family:'Lexend',sans-serif; font-weight:600; font-size:14px; line-height:1.25; color:#192341; margin:0; overflow-wrap:break-word; hyphens:auto; }
  .hw-subtitle{font-size:11px; color:#54596B; margin:0; line-height:1.2; overflow-wrap:break-word; hyphens:auto; }

  /* ---------- Group labels ---------- */
  /* Placed above each group's first card. Absolute, so they don't move the
     cards or the connector. Colour follows the section (flips in dark). */
  .hw-group-label{
    position:absolute; left:2px; z-index:4; pointer-events:none;
    font-family:'Instrument Sans',system-ui,sans-serif;
    font-weight:600; font-size:11px; letter-spacing:.07em; text-transform:uppercase;
    color:var(--sec-tx,#54596B); opacity:.6;
    transition:opacity .7s cubic-bezier(.16,1,.3,1);
  }
  .hw-gl-1{ top:calc(-1 * var(--label-drop)); }
  .hw-gl-2{ top:calc(3 * (var(--card-h) + var(--gap)) - var(--label-drop)); }
  .hw-gl-3{ top:calc(4 * (var(--card-h) + var(--gap)) - var(--label-drop)); }

  @media (prefers-reduced-motion: reduce){
    .hw-pulse{display:none}
    .is-flowing .hw-card, .is-flowing .hw-icon-box{animation:none}
  }
  @media (max-width:440px){
    .hubsell-flow-embed{padding:24px 8px 24px 64px}
    .hw-track-container{--loop-w:44px}
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initPipeline() {
    const wrap = document.querySelector('.hubsell-flow-embed') as HTMLElement | null;
    if (!wrap || wrap.dataset.ready) return;
    // Only animate when motion is allowed — BaseLayout adds .has-anim pre-paint.
    // Without it (reduced motion / no JS) the CSS shows cards + connector at rest.
    if (!document.documentElement.classList.contains('has-anim')) return;
    wrap.dataset.ready = '1';

    const cards = wrap.querySelectorAll('.hw-card');

    gsap.registerPlugin(ScrollTrigger);

    const tl = gsap.timeline({
      scrollTrigger: { trigger: wrap, start: 'top 75%', toggleActions: 'play none none none' },
    });

    // 1. Cards stagger in
    tl.fromTo(cards,
      { opacity: 0, y: 15 },
      { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', stagger: 0.15, clearProps: 'transform' }
    );
    // 2. Reveal the connector and start the travelling light (CSS handles the rest)
    tl.add(() => wrap.classList.add('is-flowing'), '-=0.2');
  }

  initPipeline();
  document.addEventListener('astro:page-load', initPipeline);
</script>
