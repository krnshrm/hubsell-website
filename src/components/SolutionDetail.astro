---
// ============================= LEARNING NOTES =============================
// SHARED BODY TEMPLATE serving all 8 solution pages (4 team + 4 role) in
// every language: one component, many pages. Two techniques to learn:
// 1. DYNAMIC COMPONENT CHOICE: STEP_VISUALS below maps a page path to a
//    COMPONENT (components are values in JavaScript, so they can sit in an
//    object). The template later picks one and renders it via a capitalized
//    variable, e.g. `const Steps = STEP_VISUALS[path]` then `<Steps ... />`.
//    That is how you swap a section per page without if/else in the markup.
// 2. TYPED CONTENT: `import type { SolutionDetailData }` pulls in only a
//    TYPE (erased at build), so the component and the data files in
//    src/data/solutions*.ts agree on the exact shape of a solution page.
//    Change the shape in one place and TypeScript flags every mismatch.
// The route files (src/pages/solutions/**) stay thin; they resolve the data
// for their path and pass it here as props.
// ==========================================================================
// Shared body template for the /solutions leaf pages (team + role). The route file
// owns BaseLayout, title/description, and breadcrumb JSON-LD; this renders the
// sections. Jobs-to-be-done framing: hero, the jobs, how hubsell helps (each block
// links out to a platform or use-case page), proof (story + quote, or quote only),
// FAQ picks, closing CTA. Background rhythm: sand, paper, navy, sand, paper, esp.
import { localizedHref } from '../i18n/utils';
import { SIGNUP_URL } from '../data/site';
import { getHome } from '../data/home-i18n';
import { getSolutionQuote } from '../data/solutions-i18n';
import type { SolutionDetailData } from '../data/solutions-content';
import type { Locale } from '../i18n/ui';
import PlatformStoryCard from './PlatformStoryCard.astro';
import PlatformFaqPicks from './PlatformFaqPicks.astro';
import SolutionStepsSalesTeams from './SolutionStepsSalesTeams.astro';
import SolutionStepsAgencies from './SolutionStepsAgencies.astro';
import SolutionStepsRevops from './SolutionStepsRevops.astro';
import SolutionStepsFounders from './SolutionStepsFounders.astro';
import SolutionStepsSdr from './SolutionStepsSdr.astro';
import SolutionStepsSalesLeader from './SolutionStepsSalesLeader.astro';
import SolutionStepsMarketing from './SolutionStepsMarketing.astro';
import SolutionStepsSalesOperations from './SolutionStepsSalesOperations.astro';
import SolutionHeroSdr from './SolutionHeroSdr.astro';
import SolutionEmailCta from './SolutionEmailCta.astro';

const STEP_VISUALS: Record<string, any> = {
  '/solutions/team/sales-teams': SolutionStepsSalesTeams,
  '/solutions/team/agencies': SolutionStepsAgencies,
  '/solutions/team/revops': SolutionStepsRevops,
  '/solutions/team/founders': SolutionStepsFounders,
  '/solutions/role/sdr': SolutionStepsSdr,
  '/solutions/role/sales-leader': SolutionStepsSalesLeader,
  '/solutions/role/marketing': SolutionStepsMarketing,
  '/solutions/role/sales-operations': SolutionStepsSalesOperations,
};

// Pages with an animated hero visual render the hero as two columns.
const HERO_VISUALS: Record<string, any> = {
  '/solutions/role/sdr': SolutionHeroSdr,
};

interface Props { L: Locale; data: SolutionDetailData }
const { L, data: d } = Astro.props;
const { s } = getHome(L);
const quote = getSolutionQuote(L, d.quoteSlug);
const StepVisual = STEP_VISUALS[d.path];
const HeroVisual = HERO_VISUALS[d.path];
const hasPains = !!(d.pains && d.pains.length > 0);
const quote2 = d.quoteSlug2 ? getSolutionQuote(L, d.quoteSlug2) : undefined;
const proofItems = (d.storySlug ? 1 : 0) + (quote ? 1 : 0) + (quote2 ? 1 : 0);
---
<!-- 1 · Hero (sand). Two columns when the page has a hero visual. -->
<section class="sec sec--sand" aria-labelledby="sol-title">
  <div class="wrap">
    <div class={HeroVisual ? 'sol-hero has-visual' : 'sol-hero'}>
      <div class="sec-head" style="margin-bottom:0">
        <p class="eyebrow">{d.eyebrow}</p>
        <h1 id="sol-title" class="heading_hero" style="margin-top:10px">{d.h1Pre}<span class="accent">{d.h1Accent}</span>{d.h1Post}</h1>
        <p class="subheading" style="margin-top:16px;max-width:62ch">{d.sub}</p>
        {!d.emailCta && (
          <p style="margin:28px 0 0"><a href={localizedHref(L, SIGNUP_URL)} class="button">{d.demoCta}</a></p>
        )}
      </div>
      {HeroVisual && (
        <div class="sol-hero__visual">
          <HeroVisual L={L} />
        </div>
      )}
    </div>
  </div>
</section>

<!-- 1b · Problem / solution pairs (paper), used instead of jobs+how when present -->
{d.pains && d.pains.length > 0 && (
  <section class="sec sec--paper" aria-label={d.painsTitle ?? d.eyebrow}>
    <div class="wrap">
      {d.painsTitle && (
        <div class="sec-head">
          {d.painsEyebrow && <p class="eyebrow">{d.painsEyebrow}</p>}
          <h2 class="heading_primary" style="margin-top:8px">{d.painsTitle}</h2>
        </div>
      )}
      <div class="sol-pains">
        {d.pains.map((p, i) => (
          <div class="sol-pain">
            <div class="sol-pain__problem">
              <span class="sol-job__n">{String(i + 1).padStart(2, '0')}</span>
              <h2 class="heading_primary" style="margin-top:10px">{p.problemTitle}</h2>
              <p class="paragraph" style="margin-top:14px">{p.problemBody}</p>
            </div>
            <div class="card sol-pain__solution">
              <h3 class="heading_small">{p.solutionTitle}</h3>
              <p class="paragraph_small" style="margin-top:10px">{p.solutionBody}</p>
              <ul class="sol-pain__points">
                {p.points.map((pt) => (
                  <li><b>{pt.label}:</b> {pt.body}</li>
                ))}
              </ul>
              {p.href && p.linkLabel && (
                <a href={localizedHref(L, p.href)} class="link" style="margin-top:auto;padding-top:18px;display:inline-block">{p.linkLabel} &rarr;</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- 2 · The jobs to be done (navy on pain pages, paper elsewhere) -->
{d.jobs && d.jobs.length > 0 && (
<section class={hasPains ? 'sec sec--navy' : 'sec sec--paper'} aria-label={d.jobsTitle}>
  <div class="wrap">
    <div class="sec-head">
      <p class="eyebrow">{d.jobsEyebrow}</p>
      <h2 class="heading_primary" style="margin-top:8px">{d.jobsTitle}</h2>
    </div>
    <ol class="sol-jobs">
      {d.jobs.map((j, i) => (
        <li class="sol-job">
          <span class="sol-job__n">{String(i + 1).padStart(2, '0')}</span>
          <p class="paragraph" style="margin:0">{j}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
)}

<!-- 3 · How hubsell helps (white on pain pages, navy elsewhere) -->
{d.how && d.how.length > 0 && (
<section class={hasPains ? 'sec sec--sand' : 'sec sec--navy'} aria-label={d.howTitle}>
  <div class="wrap">
    <div class="sec-head">
      <p class="eyebrow">{d.howEyebrow}</p>
      <h2 class="heading_primary" style="margin-top:8px">{d.howTitle}</h2>
    </div>
    {StepVisual
      ? <StepVisual L={L} how={d.how} />
      : (
        <div class="sol-how">
          {d.how.map((h) => (
            <div class="card sol-howcard">
              <h3 class="heading_small">{h.title}</h3>
              <p class="paragraph_small" style="margin-top:10px">{h.body}</p>
              <a href={localizedHref(L, h.href)} class="link" style="margin-top:auto;padding-top:16px;display:inline-block">{h.linkLabel} &rarr;</a>
            </div>
          ))}
        </div>
      )}
  </div>
</section>
)}

<!-- 4 · Proof: story (optional) + quote (paper on pain pages, white elsewhere) -->
<section class={hasPains ? 'sec sec--paper' : 'sec sec--sand'} aria-label={d.proofTitle}>
  <div class="wrap">
    <div class="sec-head">
      <p class="eyebrow">{d.proofEyebrow}</p>
      <h2 class="heading_primary" style="margin-top:8px">{d.proofTitle}</h2>
    </div>
    <div class={proofItems > 1 ? 'sol-proof' : 'sol-proof is-solo'}>
      {d.storySlug && <PlatformStoryCard L={L} slug={d.storySlug} label={d.storyLabel ?? ''} />}
      {quote && (
        <figure class="card sol-quote">
          <blockquote class="quote" style="margin:0">&ldquo;{quote.quote}&rdquo;</blockquote>
          <figcaption class="paragraph_small" style="margin-top:16px">
            <b>{quote.name}</b>{quote.title && `, ${quote.title}`}{quote.company && ` \u00b7 ${quote.company}`}
          </figcaption>
        </figure>
      )}
      {quote2 && (
        <figure class="card sol-quote">
          <blockquote class="quote" style="margin:0">&ldquo;{quote2.quote}&rdquo;</blockquote>
          <figcaption class="paragraph_small" style="margin-top:16px">
            <b>{quote2.name}</b>{quote2.title && `, ${quote2.title}`}{quote2.company && ` \u00b7 ${quote2.company}`}
          </figcaption>
        </figure>
      )}
    </div>
  </div>
</section>

<!-- 5 · Single email CTA band (espresso), above the FAQ, on pages that opt in -->
{d.emailCta && <SolutionEmailCta L={L} closing={d.closing} cta={d.emailCta} />}

<!-- 6 · FAQ picks (paper) -->
<PlatformFaqPicks L={L} eyebrow={d.faqEyebrow} title={d.faqTitle} slugs={d.faqSlugs} seeAll={s.faqSec.seeAll} tone="paper" accent={false} />

<!-- 7 · Closing CTA (espresso), only when the page has no email CTA band -->
{!d.emailCta && (
<section class="sec sec--esp" aria-label={d.closing.titlePre + d.closing.titleAccent + d.closing.titlePost}>
  <div class="wrap" style="text-align:center">
    <h2 class="heading_primary">{d.closing.titlePre}<span class="accent">{d.closing.titleAccent}</span>{d.closing.titlePost}</h2>
    <p class="subheading" style="margin:16px auto 0;max-width:56ch">{d.closing.sub}</p>
    <p style="margin:30px 0 0"><a href={localizedHref(L, SIGNUP_URL)} class="button is-large">{d.closingCta}</a></p>
  </div>
</section>
)}

<style>
  .sol-hero{ display:grid; grid-template-columns:1fr; gap:32px; align-items:center }
  .sol-hero__visual{ display:flex; justify-content:center }
  @media (min-width:880px){
    .sol-hero.has-visual{ grid-template-columns:minmax(0,1.1fr) minmax(0,.9fr); gap:clamp(32px,5vw,72px) }
  }

  .sol-jobs{ list-style:none; margin:0; padding:0; display:grid; grid-template-columns:1fr; gap:16px; counter-reset:none }
  .sol-job{ display:flex; gap:18px; align-items:flex-start; padding:20px 0; border-top:1px solid var(--sec-bd) }
  .sol-job:first-child{ border-top:0 }
  .sol-job__n{ font-family:var(--font-head); font-weight:600; font-size:1.1rem; color:var(--accent-on); flex:none; line-height:1.5 }

  .sol-how{ display:grid; grid-template-columns:1fr; gap:20px }
  .sol-howcard{ display:flex; flex-direction:column }

  .sol-proof{ display:grid; grid-template-columns:1fr; gap:20px; align-items:stretch }
  .sol-proof.is-solo{ max-width:720px }
  .sol-quote{ display:flex; flex-direction:column; justify-content:center }

  .sol-pains{ display:grid; grid-template-columns:1fr; gap:clamp(40px,6vw,64px) }
  .sol-pain{ display:grid; grid-template-columns:1fr; gap:22px; align-items:start }
  .sol-pain__solution{ display:flex; flex-direction:column }
  .sol-pain__points{ list-style:none; margin:14px 0 0; padding:0; display:grid; gap:10px }
  .sol-pain__points li{ font-family:var(--font-body); font-size:14.5px; line-height:1.6; color:var(--sec-tx) }
  .sol-pain__points b{ font-weight:600 }

  @media (min-width:760px){
    .sol-pain{ grid-template-columns:1fr 1fr; gap:36px }
    /* Alternate sides: even blocks put the card left, the problem right. */
    .sol-pain:nth-child(even) .sol-pain__problem{ order:2 }
    .sol-pain:nth-child(even) .sol-pain__solution{ order:1 }
    .sol-how{ grid-template-columns:1fr 1fr 1fr }
    .sol-proof:not(.is-solo){ grid-template-columns:1fr 1fr }
  }
</style>
