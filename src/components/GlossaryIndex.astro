---
// Glossary index, A-to-Z dictionary style. One column of terms in alphabetical
// order, grouped under sticky letter headings, each row showing term, one-line
// definition, and category tag with a hairline between rows. A search box filters
// live, and a letter rail jumps to each group (empty letters shown inactive).
// The route file owns BaseLayout and the DefinedTermSet + breadcrumb JSON-LD.
import { getCollection } from 'astro:content';
import { localizedHref } from '../i18n/utils';
import { glossaryCollection, glossaryChrome, categoryKey } from '../data/glossary-i18n';
import type { Locale } from '../i18n/ui';

interface Props { L: Locale }
const { L } = Astro.props;
const c = glossaryChrome(L);

const entries = await getCollection(glossaryCollection(L), (e) => !e.data.draft);
const terms = entries
  .map((e) => ({
    slug: e.slug,
    term: e.data.term,
    definition: e.data.definition,
    catKey: categoryKey(L, e.data.category),
    letter: e.data.term.replace(/^\W+/, '').charAt(0).toUpperCase(),
  }))
  .sort((a, b) => a.term.localeCompare(b.term, undefined, { sensitivity: 'base' }));

// Group into letter buckets, in order.
const groups: { letter: string; items: typeof terms }[] = [];
for (const t of terms) {
  let g = groups.find((x) => x.letter === t.letter);
  if (!g) { g = { letter: t.letter, items: [] }; groups.push(g); }
  g.items.push(t);
}
groups.sort((a, b) => a.letter.localeCompare(b.letter));

// Full alphabet for the rail; letters with no terms render inactive.
const ALPHABET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
const present = new Set(groups.map((g) => g.letter));
---
<!-- Hero (sand) -->
<section class="sec sec--sand" aria-labelledby="gl-title">
  <div class="wrap">
    <div class="sec-head" style="margin-bottom:0">
      <p class="eyebrow is-accent">{c.eyebrow}</p>
      <h1 id="gl-title" class="heading_hero" style="margin-top:10px">{c.h1}</h1>
      <p class="subheading" style="margin-top:16px;max-width:60ch">{c.intro}</p>
      <p class="gl-count" style="margin-top:14px">{c.termsLabel(terms.length)}</p>
    </div>
  </div>
</section>

<!-- Dictionary list (paper) -->
<section class="sec sec--paper" aria-label={c.h1}>
  <div class="wrap">
    <div class="gl-top">
      <input type="search" class="gl-search" placeholder={c.searchPlaceholder} aria-label={c.searchPlaceholder} data-gl-search />
    </div>

    <nav class="gl-rail" aria-label="A to Z" data-gl-rail>
      {ALPHABET.map((ltr) => (
        present.has(ltr)
          ? <a href={`#gl-let-${ltr}`} class="gl-rail__l" data-letter={ltr}>{ltr}</a>
          : <span class="gl-rail__l is-off" aria-disabled="true">{ltr}</span>
      ))}
    </nav>

    <div class="gl-list" data-gl-list>
      {groups.map((g) => (
        <div class="gl-group" data-group={g.letter}>
          <h2 class="gl-group__letter" id={`gl-let-${g.letter}`}>{g.letter}</h2>
          <dl class="gl-defs">
            {g.items.map((t) => (
              <a
                class="gl-row"
                href={localizedHref(L, `/glossary/${t.slug}`)}
                data-term={t.term.toLowerCase()}
                data-def={t.definition.toLowerCase()}
              >
                <dt class="gl-row__term">
                  {t.term}
                  <span class="gl-row__cat">{c.categoryLabel(t.catKey)}</span>
                </dt>
                <dd class="gl-row__def">{t.definition}</dd>
              </a>
            ))}
          </dl>
        </div>
      ))}
    </div>
    <p class="gl-empty" data-gl-empty hidden>{c.searchPlaceholder}</p>
  </div>
</section>

<style>
  .gl-count{ font:600 .95rem/1 var(--font-head); color:var(--accent-on) }
  .gl-top{ margin-bottom:22px }
  .gl-search{ width:100%; max-width:420px; padding:12px 16px; border:1px solid var(--sec-bd); border-radius:12px;
    background:var(--sec-card); color:var(--sec-tx); font:400 15px/1.2 var(--font-body) }
  .gl-search:focus{ outline:2px solid var(--accent-on); outline-offset:1px }

  /* letter rail: horizontal on mobile, sticky vertical column on wide screens */
  .gl-rail{ display:flex; flex-wrap:wrap; gap:3px; margin-bottom:22px }
  .gl-rail__l{ display:inline-flex; align-items:center; justify-content:center; min-width:28px; height:28px;
    border-radius:7px; font:600 12.5px/1 var(--font-head); color:var(--accent-on); text-decoration:none }
  .gl-rail__l:hover{ background:color-mix(in srgb, var(--accent-on) 14%, transparent) }
  .gl-rail__l.is-off{ color:var(--sec-tx); opacity:.28; pointer-events:none }

  .gl-group{ margin-top:8px }
  .gl-group__letter{ font:600 1.5rem/1 var(--font-head); color:var(--accent-on); margin:26px 0 6px;
    padding-bottom:8px; border-bottom:2px solid var(--sec-bd); position:sticky; top:60px;
    background:var(--sec-bg); scroll-margin-top:74px; z-index:1 }
  .gl-defs{ margin:0 }
  .gl-row{ display:grid; grid-template-columns:1fr; gap:4px; padding:16px 4px; text-decoration:none;
    border-bottom:1px solid var(--sec-bd); transition:background .15s }
  .gl-row:hover{ background:color-mix(in srgb, var(--sec-tx) 3%, transparent) }
  .gl-row__term{ display:flex; align-items:baseline; flex-wrap:wrap; gap:10px;
    font:600 1.15rem/1.3 var(--font-head); color:var(--sec-tx); margin:0 }
  .gl-row__cat{ font:600 10.5px/1 var(--font-head); letter-spacing:.05em; text-transform:uppercase;
    color:var(--accent-on); border:1px solid color-mix(in srgb, var(--accent-on) 40%, transparent);
    border-radius:999px; padding:4px 9px }
  .gl-row__def{ margin:0; font:400 15px/1.6 var(--font-body); color:var(--sec-tx); opacity:.82; max-width:74ch }
  .gl-empty{ margin-top:22px; color:var(--sec-tx); opacity:.7 }

  @media (min-width:900px){
    /* two columns: sticky rail on the left, list on the right */
    .gl-rail{ position:sticky; top:74px; float:left; width:40px; flex-direction:column; gap:2px;
      margin:0; padding-top:2px }
    .gl-list{ margin-left:72px }
    .gl-top{ margin-left:72px }
    .gl-row{ grid-template-columns:minmax(220px, 320px) 1fr; gap:24px; align-items:baseline }
    .gl-row__term{ font-size:1.05rem }
  }
</style>

<script>
  function initGlossaryIndex() {
    const list = document.querySelector('[data-gl-list]');
    if (!list || (list as HTMLElement).dataset.init) return;
    (list as HTMLElement).dataset.init = '1';
    const rows = Array.from(list.querySelectorAll('.gl-row')) as HTMLElement[];
    const groups = Array.from(list.querySelectorAll('.gl-group')) as HTMLElement[];
    const search = document.querySelector('[data-gl-search]') as HTMLInputElement | null;
    const empty = document.querySelector('[data-gl-empty]') as HTMLElement | null;
    const railLinks = Array.from(document.querySelectorAll('.gl-rail__l[data-letter]')) as HTMLElement[];

    function apply() {
      const q = (search?.value || '').trim().toLowerCase();
      let shown = 0;
      rows.forEach((row) => {
        const hit = !q || (row.dataset.term || '').includes(q) || (row.dataset.def || '').includes(q);
        row.style.display = hit ? '' : 'none';
        if (hit) shown++;
      });
      // hide a letter group whose rows are all filtered out, and dim its rail link
      groups.forEach((g) => {
        const anyVisible = Array.from(g.querySelectorAll('.gl-row')).some((r) => (r as HTMLElement).style.display !== 'none');
        g.style.display = anyVisible ? '' : 'none';
        const letter = g.dataset.group;
        const link = railLinks.find((l) => l.dataset.letter === letter);
        if (link) link.style.opacity = anyVisible ? '' : '.28';
      });
      if (empty) empty.hidden = shown !== 0;
    }
    search?.addEventListener('input', apply);
  }
  initGlossaryIndex();
  document.addEventListener('astro:page-load', initGlossaryIndex);
</script>
