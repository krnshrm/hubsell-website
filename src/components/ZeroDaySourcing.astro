---
// ============================= LEARNING NOTES =============================
// ANIMATED VISUAL component. The house recipe (markup with resting states,
// theme-token CSS, GSAP init gated behind html.has-anim, astro:page-load
// re-init) is explained once in src/components/HeroPipelineFlow.astro;
// read that first, then this file is mostly scene-specific detail.
// No props: it reads Astro.currentLocale and fetches its own strings
// from src/data/ (home-i18n).
// The <style> block is scoped to this component (Astro hashes the
// selectors), styled with the design tokens from src/styles/global.css.
// ==========================================================================
// Section 5 — Zero-day sourcing (Paper). Full-width timeline embed contrasting the
// slow database model with hubsell's live, same-day sourcing.
import ZeroDayTimeline from './ZeroDayTimeline.astro';
import { getHome } from '../data/home-i18n';
import { asLocale } from '../i18n/utils';
const { s } = getHome(asLocale(Astro.currentLocale));
---
<section class="sec sec--paper" aria-labelledby="zds-title">
  <div class="wrap">
    <div class="sec-head reveal">
      <p class="eyebrow is-accent">{s.zds.eyebrow}</p>
      <h2 id="zds-title" class="heading_primary" style="margin-top:8px">{s.zds.titlePre}<span class="accent">{s.zds.titleAccent}</span>{s.zds.titlePost}</h2>
      <p class="subheading" style="margin-top:14px;max-width:64ch;opacity:.85">{s.zds.sub}</p>
    </div>

    <div class="zds-embed reveal">
      <ZeroDayTimeline />
    </div>

    <div class="zds-closer reveal">
      <p class="paragraph zds-closer__line">{s.zds.closer}</p>
      <a href="#pipeline" class="button is-secondary">{s.zds.cta}</a>
    </div>
  </div>
</section>

<style>
  .zds-embed{ margin-top:40px }
  .zds-closer{ display:flex; flex-direction:column; align-items:center; gap:18px; margin-top:36px; text-align:center }
  .zds-closer__line{ max-width:58ch; opacity:.9 }
</style>
