---
// ============================= LEARNING NOTES =============================
// PAGE BODY component: a thin route file under src/pages/ owns the layout,
// meta and structured data, and hands the actual rendering to this file.
// The split exists so the de/ and nl/ route copies reuse this body and it
// translates itself. Annotated exemplars for the pattern:
// src/components/GlossaryIndex.astro and src/components/SolutionDetail.astro.
// Receives props: L, data. See Avatar.astro for how typed
// props with defaults work.
// The <style> block is scoped to this component (Astro hashes the
// selectors), styled with the design tokens from src/styles/global.css.
// ==========================================================================
// Standalone /pricing page body. Reuses the real PricingTable widget (single
// source of truth for prices) and the PricingComparison tables, then adds the
// FAQ and a closing CTA. Page copy comes from pricing-page.ts.
import PricingTable from './PricingTable.astro';
import PricingComparison from './PricingComparison.astro';
import { localizedHref } from '../i18n/utils';
import { SIGNUP_URL } from '../data/site';
import type { PricingPageData } from '../data/pricing-page';
import type { Locale } from '../i18n/ui';

interface Props { L: Locale; data: PricingPageData }
const { L, data: d } = Astro.props;
const demoHref = localizedHref(L, SIGNUP_URL);
---
<!-- Hero -->
<section class="sec sec--paper" aria-labelledby="pricing-h1">
  <div class="wrap">
    <div class="sec-head" style="margin-bottom:0">
      <p class="eyebrow is-accent">{d.eyebrow}</p>
      <h1 id="pricing-h1" class="heading_hero" style="margin-top:10px">{d.h1Pre}<span class="accent">{d.h1Accent}</span>{d.h1Post}</h1>
      <p class="subheading" style="margin-top:16px;max-width:62ch">{d.sub}</p>
      <p style="margin:28px 0 0"><a href={demoHref} class="button">{d.demoCta}</a></p>
    </div>
  </div>
</section>

<!-- Live pricing widget -->
<section class="sec sec--sand" aria-label={d.eyebrow}>
  <div class="wrap">
    <PricingTable />
  </div>
</section>

<!-- Detailed comparison tables -->
<PricingComparison L={L} data={d} />

<!-- FAQ -->
<section class="sec sec--sand" aria-labelledby="pricing-faq">
  <div class="wrap" style="max-width:820px">
    <div class="sec-head">
      <p class="eyebrow is-accent">{d.faqEyebrow}</p>
      <h2 id="pricing-faq" class="heading_primary" style="margin-top:8px">{d.faqTitle}</h2>
    </div>
    <div class="pfaq-list">
      {d.faq.map((item) => (
        <details class="pfaq">
          <summary>{item.q}</summary>
          <div class="pfaq__a"><p class="paragraph">{item.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- Closing CTA -->
<section class="sec sec--navy" aria-label={d.closingPre + d.closingAccent + d.closingPost}>
  <div class="wrap">
    <div class="sec-head" style="text-align:center;max-width:58ch;margin-left:auto;margin-right:auto">
      <h2 class="heading_primary">{d.closingPre}<span class="accent">{d.closingAccent}</span>{d.closingPost}</h2>
      <p class="subheading" style="margin-top:14px">{d.closingSub}</p>
      <p style="margin-top:26px"><a href={demoHref} class="button">{d.closingCta}</a></p>
    </div>
  </div>
</section>

<style>
  .pfaq-list { margin-top:8px; border-top:1px solid var(--sec-bd); }
  .pfaq { border-bottom:1px solid var(--sec-bd); }
  .pfaq summary { list-style:none; cursor:pointer; padding:18px 0; font-family:var(--font-head); font-weight:500; font-size:1.05rem; color:var(--sec-tx); display:flex; justify-content:space-between; align-items:center; gap:16px; }
  .pfaq summary::-webkit-details-marker { display:none; }
  .pfaq summary::after { content:"+"; font-family:var(--font-body); font-weight:400; color:var(--accent-on); font-size:1.4rem; line-height:1; }
  .pfaq[open] summary::after { content:"\2013"; }
  .pfaq__a { padding:0 0 20px; max-width:66ch; }
  .pfaq__a .paragraph { color:var(--sec-tx); opacity:.82; }
</style>
