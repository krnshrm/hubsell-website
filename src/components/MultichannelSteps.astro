---
// Stepped detail visual for /platform/multichannel-outreach. Expands the
// MultichannelFlow embed into three walked steps: (1) a contact enters one
// sequence, (2) email, LinkedIn, and phone run as branches of the same flow,
// (3) the flow reacts to what the contact does. Same 2-column row shape and
// white-card / green-connector vocabulary as LiveDataSteps. Animated on scroll,
// reduced-motion safe.
import { et } from '../data/embed-i18n';
import { asLocale } from '../i18n/utils';
const L = asLocale(Astro.currentLocale);
---
<div class="mcs" data-mcs>
  <!-- STEP 1 — one sequence -->
  <div class="mcs-step">
    <div class="mcs-text">
      <span class="mcs-num">01</span>
      <h3 class="heading_small">{et(L, 'One sequence, not three tools')}</h3>
      <p class="paragraph_small mcs-cap">{et(L, 'A contact enters a single flow you build once.')}</p>
    </div>
    <div class="mcs-viz">
      <div class="mcs-enter">
        <div class="mcs-person">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/></svg>
          {et(L, 'New contact')}
        </div>
        <svg class="mcs-arrow" viewBox="0 0 60 24" aria-hidden="true"><path class="mcs-flow" d="M0 12 H50"/><path d="M46 6 L56 12 L46 18" fill="none"/></svg>
        <div class="mcs-seq">{et(L, 'Your sequence')}</div>
      </div>
    </div>
  </div>

  <!-- STEP 2 — three channels, one flow -->
  <div class="mcs-step">
    <div class="mcs-text">
      <span class="mcs-num">02</span>
      <h3 class="heading_small">{et(L, 'Email, LinkedIn, and phone')}</h3>
      <p class="paragraph_small mcs-cap">{et(L, 'Every channel runs from the same flow, not separate tools.')}</p>
    </div>
    <div class="mcs-viz">
      <div class="mcs-channels">
        <div class="mcs-chan">
          <span class="mcs-cico"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg></span>{et(L, 'Email')}
        </div>
        <div class="mcs-chan">
          <span class="mcs-cico"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></span>{et(L, 'LinkedIn')}
        </div>
        <div class="mcs-chan">
          <span class="mcs-cico"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>{et(L, 'Phone')}
        </div>
      </div>
    </div>
  </div>

  <!-- STEP 3 — reacts to behaviour -->
  <div class="mcs-step">
    <div class="mcs-text">
      <span class="mcs-num">03</span>
      <h3 class="heading_small">{et(L, 'Reacts to what they do')}</h3>
      <p class="paragraph_small mcs-cap">{et(L, 'Opens, replies, and silence each send the contact down a different path.')}</p>
    </div>
    <div class="mcs-viz">
      <div class="mcs-branch card">
        <div class="mcs-brow"><span class="mcs-cond">{et(L, 'Replied')}</span><span class="mcs-act is-green">{et(L, 'Notify you')}</span></div>
        <div class="mcs-brow"><span class="mcs-cond">{et(L, 'Opened, no reply')}</span><span class="mcs-act">{et(L, 'Send LinkedIn touch')}</span></div>
        <div class="mcs-brow"><span class="mcs-cond">{et(L, 'No response')}</span><span class="mcs-act">{et(L, 'Queue a call task')}</span></div>
      </div>
    </div>
  </div>
</div>

<style>
  .mcs{ display:flex; flex-direction:column; gap:14px }
  .mcs-step{ display:grid; grid-template-columns:1fr; gap:16px; align-items:center;
    border:1px solid var(--sec-bd); border-radius:16px; padding:22px; background:color-mix(in srgb, var(--sec-tx) 3%, transparent) }
  .mcs-num{ font-family:var(--font-head); font-weight:600; font-size:.95rem; color:var(--accent-on) }
  .mcs-text .heading_small{ margin:6px 0 0 }
  .mcs-cap{ margin:8px 0 0; max-width:44ch }
  .mcs-viz{ display:flex; align-items:center; justify-content:center; min-height:120px }

  .mcs-enter{ display:flex; align-items:center; gap:12px; flex-wrap:wrap; justify-content:center }
  .mcs-person{ display:flex; align-items:center; gap:8px; background:#FFFFFF; color:#192341; border:1px solid #E5E7EB; border-radius:10px; padding:10px 14px; font:500 13px/1 var(--font-body); box-shadow:0 4px 12px rgba(0,0,0,.10) }
  .mcs-seq{ background:#FFFFFF; color:#155C3F; border:2px solid #2FA06E; border-radius:10px; padding:10px 16px; font:600 13px/1 var(--font-head); box-shadow:0 6px 16px rgba(47,160,110,.18) }
  .mcs-arrow{ width:60px; height:24px; color:#2FA06E; flex:none }
  .mcs-arrow path{ stroke:currentColor; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; fill:none }

  .mcs-channels{ display:flex; flex-direction:column; gap:10px; width:100%; max-width:300px }
  .mcs-chan{ display:flex; align-items:center; gap:10px; background:#FFFFFF; color:#192341; border:1px solid #E5E7EB; border-radius:10px; padding:11px 14px; font:500 13.5px/1 var(--font-body); box-shadow:0 4px 12px rgba(0,0,0,.10) }
  .mcs-cico{ width:26px; height:26px; border-radius:7px; background:#E4F2EA; color:#155C3F; display:flex; align-items:center; justify-content:center; flex:none }

  .mcs-branch{ width:100%; max-width:360px; padding:16px 18px }
  .mcs-brow{ display:flex; align-items:center; justify-content:space-between; gap:12px; padding:10px 0; border-top:1px solid var(--sec-bd) }
  .mcs-brow:first-child{ border-top:0 }
  .mcs-cond{ font:500 13px/1.2 var(--font-body); color:var(--sec-tx) }
  .mcs-act{ font:600 12px/1 var(--font-body); color:var(--sec-tx); opacity:.72; text-align:right }
  .mcs-act.is-green{ color:#155C3F; opacity:1; background:#E4F2EA; border-radius:999px; padding:5px 10px }

  .mcs-flow{ stroke:#2FA06E; stroke-width:2; fill:none }

  @media (min-width:760px){
    .mcs-step{ grid-template-columns:0.9fr 1.1fr; gap:28px; padding:26px 30px }
    .mcs-channels{ flex-direction:row; max-width:none }
    .mcs-chan{ flex:1 }
  }

  :global(html.has-anim) [data-mcs] .mcs-step{ opacity:0; transform:translateY(16px) }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initMultichannelSteps() {
    const wrap = document.querySelector('[data-mcs]') as HTMLElement | null;
    if (!wrap || wrap.dataset.init) return;
    if (!document.documentElement.classList.contains('has-anim')) return;
    wrap.dataset.init = '1';
    gsap.registerPlugin(ScrollTrigger);

    const steps = Array.from(wrap.querySelectorAll('.mcs-step')) as HTMLElement[];
    steps.forEach((step) => {
      gsap.timeline({ scrollTrigger: { trigger: step, start: 'top 82%', toggleActions: 'play none none none' } })
        .fromTo(step, { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out', clearProps: 'transform' });
    });
  }

  initMultichannelSteps();
  document.addEventListener('astro:page-load', initMultichannelSteps);
</script>
