---
// ============================= LEARNING NOTES =============================
// SECTION component: one visual band, stacked by a page file. The pattern
// (locale lookup, strings from src/data, semantic markup, scoped style) is
// explained in src/components/Hero.astro; browser-script mechanics in
// src/components/Faq.astro.
// No props: it reads Astro.currentLocale and fetches its own strings
// from src/data/ (home-i18n).
// ==========================================================================
// Section 8 — One platform for GTM (Navy). The six personas double as use-cases.
import { getHome } from '../data/home-i18n';
import { asLocale } from '../i18n/utils';
const { roles, s } = getHome(asLocale(Astro.currentLocale));
---
<section id="use-cases" class="sec sec--navy" aria-labelledby="roles-title">
  <div class="wrap">
    <div class="sec-head reveal">
      <p class="eyebrow">{s.usecases.eyebrow}</p>
      <h2 id="roles-title" class="heading_primary" style="margin-top:8px">{s.usecases.titlePre}<span class="accent">{s.usecases.titleAccent}</span>{s.usecases.titlePost}</h2>
      <p class="subheading">{s.usecases.sub}</p>
    </div>

    <div class="grid grid-3 reveal-stagger">
      {roles.map((r) => (
        <div class="card" style="display:flex;flex-direction:column;gap:8px">
          <h3 class="heading_tertiary">{r.title}</h3>
          <p class="paragraph_small" style="opacity:.78">{r.line}</p>
        </div>
      ))}
    </div>
  </div>
</section>
