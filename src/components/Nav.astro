---
// Main navigation. Colour-aware: the bar samples the background of the section
// currently under it, then flips between a light and dark treatment (text, logo,
// hairline) and tints a frosted bar to match. Keys off the section's *computed*
// background, so it works in dark mode too and needs no per-section tagging.
// Login + language + theme live in the TopBar above this; this bar carries the
// primary nav (Resources, Pricing) and the trial CTA.
import { SIGNUP_URL } from '../data/site';

const LOGO_DARK = 'https://assets.hubsell.com/logo/hubsell-wordmark-dark.svg';   // for light sections
const LOGO_LIGHT = 'https://assets.hubsell.com/logo/hubsell-wordmark-light.svg'; // for dark sections

// Resources mega-menu. Live links plus greyed "coming soon" items for pages not
// built yet (Products / Solutions / Our Data / GTM Developers come in a later pass).
const learn = [
  { href: '/insights', label: 'Insights' },
  { href: '/customerstories', label: 'Case studies' },
];
const learnSoon = ['Resource center', 'Events', 'AI sales coach', 'Free tools', 'GTM plays', 'Help center'];
const companySoon = ['About us', 'Careers', 'Partner program', 'Newsroom'];
---
<header class="nav" data-tone="light">
  <div class="nav__inner">
    <a href="/" class="nav__mark" aria-label="hubsell home">
      <img class="nav__logo nav__logo--dark" src={LOGO_DARK} alt="hubsell" width="108" />
      <img class="nav__logo nav__logo--light" src={LOGO_LIGHT} alt="hubsell" width="108" />
    </a>

    <nav class="nav__links" aria-label="Primary">
      <div class="nav__group nav__group--mega">
        <button type="button" class="nav__link nav__trigger" aria-haspopup="true" aria-expanded="false">Resources</button>
        <div class="nav__mega">
          <div class="nav__megacol">
            <p class="nav__megahead">Learn</p>
            <ul>
              {learn.map((i) => (<li><a href={i.href}>{i.label}</a></li>))}
              {learnSoon.map((l) => (<li><span class="nav__soon">{l}</span></li>))}
            </ul>
          </div>
          <div class="nav__megacol">
            <p class="nav__megahead">Company</p>
            <ul>
              {companySoon.map((l) => (<li><span class="nav__soon">{l}</span></li>))}
            </ul>
          </div>
        </div>
      </div>
      <a class="nav__link" href="/#pricing">Pricing</a>
    </nav>

    <div class="nav__actions">
      <a class="button is-small nav__cta" href={SIGNUP_URL}>Start free trial</a>
      <button type="button" class="nav__burger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="nav__mobile" hidden>
    <p class="nav__mobhead">Resources</p>
    {learn.map((i) => (<a class="nav__moblink" href={i.href}>{i.label}</a>))}
    {learnSoon.map((l) => (<span class="nav__moblink nav__soon">{l}</span>))}
    {companySoon.map((l) => (<span class="nav__moblink nav__soon">{l}</span>))}
    <hr class="nav__mobrule" />
    <a class="nav__moblink" href="/#pricing">Pricing</a>
    <a class="button nav__mobcta" href={SIGNUP_URL}>Start free trial</a>
  </div>
</header>

<style>
  @property --nav-bg { syntax: '<color>'; inherits: true; initial-value: #EADBC2; }

  .nav{
    position:sticky; top:0; z-index:200;
    background:color-mix(in srgb, var(--nav-bg) 82%, transparent);
    -webkit-backdrop-filter:saturate(140%) blur(10px);
    backdrop-filter:saturate(140%) blur(10px);
    border-bottom:1px solid var(--nav-bd);
    transition:--nav-bg .35s ease, border-color .3s ease;
  }

  /* Tone tokens — flipped by the script via [data-tone]. */
  .nav[data-tone="light"]{
    --nav-tx:#192341; --nav-tx-dim:rgba(25,35,65,.62);
    --nav-bd:rgba(25,35,65,.10); --nav-hover:rgba(25,35,65,.06);
    --nav-card:#FFFFFF; --nav-card-bd:rgba(25,35,65,.10);
  }
  .nav[data-tone="dark"]{
    --nav-tx:#FBF4EA; --nav-tx-dim:rgba(251,244,234,.72);
    --nav-bd:rgba(255,255,255,.12); --nav-hover:rgba(251,244,234,.10);
    --nav-card:#222E4C; --nav-card-bd:rgba(255,255,255,.12);
  }
  /* Before the colour script runs the bar still reads data-tone="light"; in dark
     mode that would flash a light bar for a frame. Paint the dark treatment for
     that initial state straight away (the script then takes over via inline style). */
  [data-theme="dark"] .nav[data-tone="light"]{
    --nav-tx:#FBF4EA; --nav-tx-dim:rgba(251,244,234,.72);
    --nav-bd:rgba(255,255,255,.12); --nav-hover:rgba(251,244,234,.10);
    --nav-card:#222E4C; --nav-card-bd:rgba(255,255,255,.12);
    --nav-bg:#1E1712;
  }

  .nav__inner{
    max-width:var(--maxw); margin:0 auto; padding:12px clamp(20px,5vw,56px);
    display:flex; align-items:center; gap:18px;
  }

  .nav__mark{display:flex; align-items:center; margin-right:auto; line-height:0}
  .nav__logo{width:108px; height:auto; display:block}
  .nav[data-tone="light"] .nav__logo--light{display:none}
  .nav[data-tone="dark"]  .nav__logo--dark{display:none}
  [data-theme="dark"] .nav[data-tone="light"] .nav__logo--dark{display:none}
  [data-theme="dark"] .nav[data-tone="light"] .nav__logo--light{display:block}

  .nav__links{display:flex; align-items:center; gap:4px}
  .nav__group{position:relative}
  .nav__link{
    font-family:var(--font-body); font-size:14px; font-weight:500; color:var(--nav-tx-dim);
    text-decoration:none; background:transparent; border:0; cursor:pointer;
    padding:8px 12px; border-radius:8px; transition:color .15s, background .15s;
  }
  .nav__link:hover, .nav__trigger[aria-expanded="true"]{ color:var(--nav-tx); background:var(--nav-hover); }

  /* Resources mega-menu */
  .nav__mega{
    position:absolute; top:calc(100% + 6px); left:0;
    display:grid; grid-template-columns:1fr 1fr; gap:6px 30px;
    min-width:520px; padding:18px 20px;
    background:var(--nav-bg); border:1px solid var(--nav-bd);
    border-radius:var(--radius-lg); box-shadow:0 16px 40px rgba(0,0,0,.22);
    opacity:0; visibility:hidden; transform:translateY(-6px);
    transition:opacity .16s, transform .16s, visibility .16s; z-index:10;
  }
  .nav__group--mega:hover .nav__mega, .nav__group--mega:focus-within .nav__mega{ opacity:1; visibility:visible; transform:none; }
  .nav__megacol ul{ list-style:none; margin:0; padding:0; }
  .nav__megahead{ font:600 11px/1 var(--font-body); letter-spacing:.08em; text-transform:uppercase; color:var(--nav-tx-dim); opacity:.7; margin:0 0 8px; padding:0 10px; }
  .nav__megacol li a, .nav__megacol li .nav__soon{
    display:flex; align-items:center; gap:8px; padding:8px 10px; border-radius:8px;
    font-size:13.5px; color:var(--nav-tx-dim); text-decoration:none;
  }
  .nav__megacol li a:hover{ color:var(--nav-tx); background:color-mix(in srgb, var(--accent-on) 16%, transparent); }
  .nav__soon{ color:var(--nav-tx-dim); opacity:.5; cursor:default; }
  .nav__soon::after{
    content:"Soon"; margin-left:auto; font-size:9px; font-weight:600; letter-spacing:.05em; text-transform:uppercase;
    padding:2px 6px; border-radius:999px; background:color-mix(in srgb, var(--nav-tx) 12%, transparent);
  }

  .nav__actions{display:flex; align-items:center; gap:10px}

  /* Mobile hamburger + panel */
  .nav__burger{
    display:none; width:40px; height:40px; align-items:center; justify-content:center;
    flex-direction:column; gap:4px; background:transparent; border:0; cursor:pointer; border-radius:8px;
  }
  .nav__burger span{ display:block; width:20px; height:2px; background:var(--nav-tx); border-radius:2px; transition:transform .2s, opacity .2s; }
  .nav__burger[aria-expanded="true"] span:nth-child(1){ transform:translateY(6px) rotate(45deg); }
  .nav__burger[aria-expanded="true"] span:nth-child(2){ opacity:0; }
  .nav__burger[aria-expanded="true"] span:nth-child(3){ transform:translateY(-6px) rotate(-45deg); }

  .nav__mobile{
    display:none; flex-direction:column; gap:2px;
    padding:10px clamp(20px,5vw,56px) 20px;
    border-top:1px solid var(--nav-bd);
    background:color-mix(in srgb, var(--nav-bg) 96%, transparent);
  }
  .nav__mobhead{ font:600 11px/1 var(--font-body); letter-spacing:.08em; text-transform:uppercase; color:var(--nav-tx-dim); opacity:.7; margin:8px 8px 4px; }
  .nav__moblink{ display:flex; align-items:center; padding:11px 8px; border-radius:8px; font-size:15px; font-weight:500; color:var(--nav-tx); text-decoration:none; }
  .nav__moblink:hover{ background:var(--nav-hover); }
  .nav__moblink.nav__soon{ color:var(--nav-tx-dim); opacity:.5; }
  .nav__moblink.nav__soon::after{ content:"Soon"; margin-left:auto; font-size:9px; font-weight:600; letter-spacing:.05em; text-transform:uppercase; padding:2px 6px; border-radius:999px; background:color-mix(in srgb, var(--nav-tx) 12%, transparent); }
  .nav__mobrule{ border:0; border-top:1px solid var(--nav-bd); margin:8px 8px; }
  .nav__mobcta{ margin-top:10px; justify-content:center; }

  @media (max-width:860px){
    .nav__links{ display:none; }
    .nav__cta{ display:none; }
    .nav__burger{ display:flex; }
    .nav__mobile:not([hidden]){ display:flex; }
  }
  @media (prefers-reduced-motion:reduce){ .nav{transition:none} }
</style>

<script>
  // ---- Resources mega-menu: keyboard/click affordance (hover/focus handles the rest) ----
  function initNavMenus() {
    document.querySelectorAll<HTMLButtonElement>('.nav__trigger').forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = 'true';
      const group = btn.closest('.nav__group')!;
      btn.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      });
      document.addEventListener('click', (e) => {
        if (!group.contains(e.target as Node)) btn.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // ---- Mobile menu toggle ----
  function initNavBurger() {
    const burger = document.querySelector<HTMLButtonElement>('.nav__burger');
    const panel = document.querySelector<HTMLElement>('.nav__mobile');
    if (!burger || !panel || burger.dataset.bound) return;
    burger.dataset.bound = 'true';
    const close = () => { burger.setAttribute('aria-expanded', 'false'); panel.setAttribute('hidden', ''); };
    burger.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      if (open) { close(); } else { burger.setAttribute('aria-expanded', 'true'); panel.removeAttribute('hidden'); }
    });
    panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
  }

  // ---- Colour-aware bar: sample the section under the nav, flip tone + tint ----
  function initNavColour() {
    const nav = document.querySelector<HTMLElement>('.nav');
    if (!nav || nav.dataset.colourBound) return;
    nav.dataset.colourBound = 'true';

    const sections = Array.from(document.querySelectorAll<HTMLElement>('.sec'));
    if (!sections.length) return;

    const parse = (s: string) => {
      const m = s.match(/rgba?\(([^)]+)\)/);
      if (!m) return null;
      const p = m[1].split(',').map((x) => parseFloat(x.trim()));
      return { r: p[0], g: p[1], b: p[2], a: p.length > 3 ? p[3] : 1 };
    };
    const lum = (r: number, g: number, b: number) => {
      const f = (c: number) => { c /= 255; return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4); };
      return 0.2126 * f(r) + 0.7152 * f(g) + 0.0722 * f(b);
    };
    const bgOf = (el: HTMLElement | null) => {
      let node: HTMLElement | null = el;
      while (node && node !== document.documentElement) {
        const c = parse(getComputedStyle(node).backgroundColor);
        if (c && c.a > 0) return c;
        node = node.parentElement;
      }
      return parse(getComputedStyle(document.body).backgroundColor) || { r: 255, g: 255, b: 255, a: 1 };
    };

    let navH = nav.offsetHeight || 60;
    let ticking = false;

    const update = () => {
      ticking = false;
      const probeY = navH * 0.5 + 1;
      let current: HTMLElement | null = null;
      for (const sec of sections) {
        const r = sec.getBoundingClientRect();
        if (r.top <= probeY && r.bottom > probeY) { current = sec; break; }
      }
      if (!current) current = sections[0];
      const c = bgOf(current);
      nav.style.setProperty('--nav-bg', `rgb(${Math.round(c.r)}, ${Math.round(c.g)}, ${Math.round(c.b)})`);
      nav.dataset.tone = lum(c.r, c.g, c.b) < 0.5 ? 'dark' : 'light';
    };

    const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => { navH = nav.offsetHeight || navH; update(); });

    // The switch suppresses transitions, so one re-sample reads the settled colour.
    window.addEventListener('hubsell:themechange', update);
    update();
  }

  function initNav() { initNavMenus(); initNavBurger(); initNavColour(); }
  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>
