---
// Site navigation. Colour-aware: the bar samples the background of the section
// currently under it, then flips between a light and dark treatment (text, logo,
// hairline) and tints a frosted bar to match that section. It keys off the
// luminance of the section's *computed* background, so it also works in dark mode
// and needs no per-section tagging — every section just carries `.sec`.
import { SIGNUP_URL } from '../data/site';

const LOGO_DARK = 'https://assets.hubsell.com/logo/hubsell-wordmark-dark.svg';   // for light sections
const LOGO_LIGHT = 'https://assets.hubsell.com/logo/hubsell-wordmark-light.svg'; // for dark sections

const customerStories = [
  { href: '/customerstories/safran', label: 'Safran Software: CAC down 30%' },
  { href: '/customerstories/staffbase', label: 'Staffbase: 15 new markets' },
  { href: '/customerstories/verhaert', label: 'Verhaert: 3× opportunities' },
  { href: '/customerstories/elium', label: 'Elium: leads up 25%' },
  { href: '/customerstories/workspace365', label: 'Workspace 365: 100+ opportunities' },
  { href: '/customerstories/sensolus', label: 'Sensolus: 22% reply rate' },
];
---
<header class="nav" data-tone="light">
  <div class="nav__inner">
    <a href="/" class="nav__mark" aria-label="hubsell home">
      <img class="nav__logo nav__logo--dark" src={LOGO_DARK} alt="hubsell" width="108" />
      <img class="nav__logo nav__logo--light" src={LOGO_LIGHT} alt="hubsell" width="108" />
    </a>

    <nav class="nav__links" aria-label="Primary">
      <div class="nav__group">
        <button type="button" class="nav__link nav__trigger" aria-haspopup="true" aria-expanded="false">Customers</button>
        <ul class="nav__menu">
          {customerStories.map((s) => (
            <li><a href={s.href}>{s.label}</a></li>
          ))}
        </ul>
      </div>
      <a class="nav__link" href="/insights">Insights</a>
      <a class="nav__link" href="/#pricing">Pricing</a>
    </nav>

    <div class="nav__actions">
      <a class="nav__login" href="https://app.hubsell.com/">Login</a>
      <a class="button is-small" href={SIGNUP_URL}>Start free trial</a>
    </div>
  </div>
</header>

<style>
  /* The frosted bar is tinted to the section behind it; a typed custom property
     lets that tint cross-fade smoothly at section boundaries (degrades to an
     instant swap where @property is unsupported). */
  @property --nav-bg { syntax: '<color>'; inherits: false; initial-value: #EADBC2; }

  .nav{
    position:sticky; top:0; z-index:40;
    background:color-mix(in srgb, var(--nav-bg) 82%, transparent);
    -webkit-backdrop-filter:saturate(140%) blur(10px);
    backdrop-filter:saturate(140%) blur(10px);
    border-bottom:1px solid var(--nav-bd);
    transition:--nav-bg .35s ease, border-color .3s ease;
  }

  /* Tone tokens — flipped by the script via [data-tone]. */
  .nav[data-tone="light"]{
    --nav-tx:#192341; --nav-tx-dim:rgba(25,35,65,.62);
    --nav-bd:rgba(25,35,65,.10); --nav-hover:rgba(25,35,65,.06);
    --nav-card:#FFFFFF; --nav-card-bd:rgba(25,35,65,.10);
  }
  .nav[data-tone="dark"]{
    --nav-tx:#FBF4EA; --nav-tx-dim:rgba(251,244,234,.72);
    --nav-bd:rgba(255,255,255,.12); --nav-hover:rgba(251,244,234,.10);
    --nav-card:#222E4C; --nav-card-bd:rgba(255,255,255,.12);
  }

  .nav__inner{
    max-width:var(--maxw); margin:0 auto; padding:12px clamp(20px,5vw,56px);
    display:flex; align-items:center; gap:18px;
  }

  .nav__mark{display:flex; align-items:center; margin-right:auto; line-height:0}
  .nav__logo{width:108px; height:auto; display:block}
  .nav[data-tone="light"] .nav__logo--light{display:none}
  .nav[data-tone="dark"]  .nav__logo--dark{display:none}

  .nav__links{display:flex; align-items:center; gap:4px}
  .nav__group{position:relative}
  .nav__link{
    font-family:var(--font-body); font-size:14px; font-weight:500; color:var(--nav-tx-dim);
    text-decoration:none; background:transparent; border:0; cursor:pointer;
    padding:8px 12px; border-radius:8px; transition:color .15s, background .15s;
  }
  .nav__link:hover, .nav__trigger[aria-expanded="true"]{ color:var(--nav-tx); background:var(--nav-hover); }

  .nav__menu{
    position:absolute; top:calc(100% + 6px); left:0; min-width:300px; margin:0; padding:8px;
    list-style:none; background:var(--nav-card); border:1px solid var(--nav-card-bd);
    border-radius:var(--radius-lg); box-shadow:0 16px 40px rgba(0,0,0,.22);
    opacity:0; visibility:hidden; transform:translateY(-6px);
    transition:opacity .16s, transform .16s, visibility .16s;
  }
  .nav__group:hover .nav__menu, .nav__group:focus-within .nav__menu{opacity:1; visibility:visible; transform:none}
  .nav__menu li a{
    display:block; padding:9px 12px; border-radius:8px; text-decoration:none;
    font-size:13.5px; color:var(--nav-tx-dim); transition:color .12s, background .12s;
  }
  .nav__menu li a:hover{color:var(--nav-tx); background:color-mix(in srgb, var(--accent-on) 18%, transparent)}

  .nav__actions{display:flex; align-items:center; gap:10px}
  .nav__login{
    font-family:var(--font-body); font-size:14px; font-weight:500; color:var(--nav-tx-dim);
    text-decoration:none; padding:8px 10px; border-radius:8px; transition:color .15s;
  }
  .nav__login:hover{color:var(--nav-tx)}

  @media (max-width:860px){ .nav__links{display:none} .nav__login{display:none} }
  @media (prefers-reduced-motion:reduce){ .nav{transition:none} }
</style>

<script>
  // ---- Customers dropdown: keyboard/click affordance (hover handles the rest) ----
  function initNavMenus() {
    document.querySelectorAll<HTMLButtonElement>('.nav__trigger').forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = 'true';
      const group = btn.closest('.nav__group')!;
      btn.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      });
      document.addEventListener('click', (e) => {
        if (!group.contains(e.target as Node)) btn.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // ---- Colour-aware bar: sample the section under the nav, flip tone + tint ----
  function initNavColour() {
    const nav = document.querySelector<HTMLElement>('.nav');
    if (!nav || nav.dataset.colourBound) return;
    nav.dataset.colourBound = 'true';

    const sections = Array.from(document.querySelectorAll<HTMLElement>('.sec'));
    if (!sections.length) return;

    const parse = (s: string) => {
      const m = s.match(/rgba?\(([^)]+)\)/);
      if (!m) return null;
      const p = m[1].split(',').map((x) => parseFloat(x.trim()));
      return { r: p[0], g: p[1], b: p[2], a: p.length > 3 ? p[3] : 1 };
    };
    const lum = (r: number, g: number, b: number) => {
      const f = (c: number) => { c /= 255; return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4); };
      return 0.2126 * f(r) + 0.7152 * f(g) + 0.0722 * f(b);
    };
    const bgOf = (el: HTMLElement | null) => {
      let node: HTMLElement | null = el;
      while (node && node !== document.documentElement) {
        const c = parse(getComputedStyle(node).backgroundColor);
        if (c && c.a > 0) return c;
        node = node.parentElement;
      }
      return parse(getComputedStyle(document.body).backgroundColor) || { r: 255, g: 255, b: 255, a: 1 };
    };

    let navH = nav.offsetHeight || 60;
    let ticking = false;

    const update = () => {
      ticking = false;
      const probeY = navH * 0.5 + 1;
      let current: HTMLElement | null = null;
      for (const sec of sections) {
        const r = sec.getBoundingClientRect();
        if (r.top <= probeY && r.bottom > probeY) { current = sec; break; }
      }
      if (!current) current = sections[0];
      const c = bgOf(current);
      nav.style.setProperty('--nav-bg', `rgb(${Math.round(c.r)}, ${Math.round(c.g)}, ${Math.round(c.b)})`);
      nav.dataset.tone = lum(c.r, c.g, c.b) < 0.5 ? 'dark' : 'light';
    };

    const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => { navH = nav.offsetHeight || navH; update(); });
    update();
  }

  function initNav() { initNavMenus(); initNavColour(); }
  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>
