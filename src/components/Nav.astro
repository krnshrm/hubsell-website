    <nav class="nav__links" aria-label="Primary">
      <div class="nav__group">
        <button type="button" class="nav__link nav__trigger" aria-haspopup="true" aria-expanded="false">Customers</button>
        <ul class="nav__menu">
          {customerStories.map((s) => (
            <li><a href={s.href}>{s.label}</a></li>
          ))}
        </ul>
      </div>
      <a class="nav__link" href="/insights">Insights</a>
      <a class="nav__link" href="/#pricing">Pricing</a>
    </nav>

    <div class="nav__actions">
      <a class="nav__login" href="https://app.hubsell.com/">Login</a>
      <a class="button is-small" href={SIGNUP_URL}>Start free trial</a>
    </div>
  </div>
</header>

<style>
  .nav{
    position:sticky; top:0; z-index:40;
    background:color-mix(in srgb, var(--chrome-bg) 90%, transparent);
    backdrop-filter:saturate(140%) blur(10px);
    border-bottom:1px solid var(--chrome-bd);
  }
  .nav__inner{
    max-width:var(--maxw); margin:0 auto; padding:12px clamp(20px,5vw,56px);
    display:flex; align-items:center; gap:18px;
  }
  .nav__mark{color:var(--chrome-tx); display:flex; align-items:center; margin-right:auto}
  .nav__mark svg{width:108px; height:auto}

  .nav__links{display:flex; align-items:center; gap:4px}
  .nav__group{position:relative}
  .nav__link{
    font-family:var(--font-body); font-size:14px; font-weight:500; color:var(--chrome-tx-dim);
    text-decoration:none; background:transparent; border:0; cursor:pointer;
    padding:8px 12px; border-radius:8px; transition:color .15s, background .15s;
  }
  .nav__link:hover, .nav__trigger[aria-expanded="true"]{
    color:var(--chrome-tx); background:var(--chrome-hover);
  }
  .nav__menu{
    position:absolute; top:calc(100% + 6px); left:0; min-width:300px; margin:0; padding:8px;
    list-style:none; background:var(--chrome-card); border:1px solid var(--chrome-bd);
    border-radius:var(--radius-lg); box-shadow:0 16px 40px rgba(0,0,0,.32);
    opacity:0; visibility:hidden; transform:translateY(-6px);
    transition:opacity .16s, transform .16s, visibility .16s;
  }
  .nav__group:hover .nav__menu, .nav__group:focus-within .nav__menu{opacity:1; visibility:visible; transform:none}
  .nav__menu li a{
    display:block; padding:9px 12px; border-radius:8px; text-decoration:none;
    font-size:13.5px; color:var(--chrome-tx-dim); transition:color .12s, background .12s;
  }
  .nav__menu li a:hover{color:var(--chrome-tx); background:color-mix(in srgb, var(--accent-on) 18%, transparent)}

  .nav__actions{display:flex; align-items:center; gap:10px}
  .nav__login{font-family:var(--font-body); font-size:14px; font-weight:500; color:var(--chrome-tx-dim); text-decoration:none; padding:8px 10px; border-radius:8px}
  .nav__login:hover{color:var(--chrome-tx)}

  @media (max-width:860px){
    .nav__links{display:none}
    .nav__login{display:none}
  }
</style>

<script>
  // Keyboard/click affordance for the Customers menu (hover handles the rest).
  function initNav() {
    document.querySelectorAll<HTMLButtonElement>('.nav__trigger').forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = 'true';
      const group = btn.closest('.nav__group')!;
      btn.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      });
      document.addEventListener('click', (e) => {
        if (!group.contains(e.target as Node)) btn.setAttribute('aria-expanded', 'false');
      });
    });
  }
  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>
