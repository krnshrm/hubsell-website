---
// Section 9 — Live data, email and LinkedIn orchestrated in one solution (Sand).
import { getHome } from '../data/home-i18n';
import { asLocale } from '../i18n/utils';
const { features, s } = getHome(asLocale(Astro.currentLocale));
---
<section id="features" class="sec sec--sand" aria-labelledby="features-title">
  <div class="wrap">
    <div class="sec-head reveal">
      <p class="eyebrow is-accent">{s.featuresSec.eyebrow}</p>
      <h2 id="features-title" class="heading_primary" style="margin-top:8px">{s.featuresSec.titlePre}<span class="accent">{s.featuresSec.titleAccent}</span>{s.featuresSec.titlePost}</h2>
    </div>

    <div class="grid grid-4 reveal-stagger" style="grid-template-columns:repeat(auto-fit,minmax(250px,1fr))">
      {features.map((f) => (
        <div class="card" style="display:flex;flex-direction:column;gap:8px">
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            <h3 class="heading_small">{f.title}</h3>
            {f.beta && <span class="badge">{s.featuresSec.beta}</span>}
          </div>
          <p class="paragraph_small" style="opacity:.8">{f.body}</p>
          {f.beta && <span class="paragraph_small" style="opacity:.6;margin-top:auto">{s.featuresSec.comingSoon}</span>}
        </div>
      ))}
    </div>
  </div>
</section>
