    </div>
  </div>

  <div class="pricing-popup-bg" data-popup-bg>
    <div class="pricing-popup">
      <button class="pricing-popup-close" data-popup-close>×</button>
      <div class="pricing-popup-title">{et(L, "How credits work")}</div>
