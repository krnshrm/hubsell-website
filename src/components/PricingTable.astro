      <div class="pricing-card">
        <div class="pricing-card-name">{et(L, "Sales Intelligence | Subscription")}</div>
        <div class="pricing-card-price-prefix">{et(L, "Starting at")}</div>
        <div class="pricing-card-price"><span class="price-currency">€</span><span class="price-value" data-eur="5000" data-usd="5800" data-gbp="4300">5,000</span><span class="pricing-card-price-period">{et(L, "/year")}</span></div>
        <div class="pricing-card-desc">{et(L, "For teams that need a larger amount of data and more advanced sourcing techniques.")}</div>
        <div class="pricing-card-emph-line">{et(L, "Includes 5000 credits - enriches 10K-50K contacts.")}</div>
        <div class="pricing-card-divider"></div>
        <div class="pricing-card-features-label">{et(L, "Everything in Pay as you go, plus:")}</div>
        <ul class="pricing-card-features">
          <li>
            <div class="feat-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></div>
            <span>{et(L, "Account Based Targeting")}</span>
          </li>
          <li>
            <div class="feat-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg></div>
