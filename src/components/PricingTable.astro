.pricing-card-name { font-family: 'Lexend', system-ui, sans-serif; font-size: 24px; font-weight: 500; margin-bottom: 16px;  overflow-wrap:break-word; hyphens:auto; }
.pricing-card-price-prefix { font-size: 13px; opacity: 0.55; margin-bottom: 6px; }
.pricing-card-price { font-family: 'Lexend', system-ui, sans-serif; font-size: 32px; font-weight: 500; line-height: 1.1; margin-bottom: 4px; }
.pricing-card-price-period { font-size: 16px; font-weight: 400; opacity: 0.6; }
.pricing-card-link { display: inline-block; color: var(--accent-primary); font-size: 13px; font-weight: 500; text-decoration: none; margin-top: 4px; cursor: pointer; }
.pricing-card-link:hover { text-decoration: underline; }
.pricing-card-desc { font-size: 14px; line-height: 1.55; margin-top: 18px; opacity: 0.85;  overflow-wrap:break-word; hyphens:auto; }
.pricing-card-emph-line { font-size: 14px; color: var(--accent-primary); font-weight: 500; margin-top: 4px; }
.pricing-card-emph { color: var(--accent-primary); font-weight: 500; }
.pricing-card-divider { border-top: 1px solid var(--pt-hair); margin: 22px 0; }
.pricing-card-features-label { font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.55; margin-bottom: 14px; }

.pricing-card-features { list-style: none; padding: 0; margin: 0 0 24px 0; flex: 1; display: flex; flex-direction: column; gap: 12px; }
.pricing-card-features li { display: flex; align-items: flex-start; gap: 12px; font-size: 14px; line-height: 1.5; }
.feat-icon-box { width: 22px; height: 22px; border-radius: 6px; background: color-mix(in srgb, var(--accent-primary) 10%, transparent); color: var(--accent-primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
