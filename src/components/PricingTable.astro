</div>

<style>
.pricing-wrap {
  /* Map the embed's Webflow tokens onto our theme tokens (terracotta + theme-aware) */
  --accent-primary: var(--accent-on);
  --neutral-primary: var(--sec-card, #FFFFFF);
  --neutral-inverse: var(--sec-tx, #192341);
  --pt-hair: color-mix(in srgb, var(--sec-tx) 8%, transparent);
  --pt-hair-soft: color-mix(in srgb, var(--sec-tx) 5%, transparent);
  --pt-hair-strong: color-mix(in srgb, var(--sec-tx) 12%, transparent);
  font-family: 'Instrument Sans', system-ui, sans-serif; color: var(--neutral-inverse); width: 100%; max-width: 1180px; margin: 0 auto; padding: 8px 0;
}
.pricing-controls { display: flex; flex-direction: column; align-items: center; gap: 24px; margin-bottom: 40px; }
.pricing-currency { display: inline-flex; background: color-mix(in srgb, var(--sec-tx) 5%, transparent); border-radius: 999px; padding: 4px; gap: 2px; }
.pricing-currency-btn { background: transparent; border: none; padding: 9px 20px; border-radius: 999px; font: inherit; font-size: 14px; font-weight: 500; color: var(--neutral-inverse); opacity: 0.55; cursor: pointer; transition: all 0.25s ease; min-width: 56px; }
.pricing-currency-btn:hover { opacity: 0.85; }
.pricing-currency-btn.is-active { background: var(--neutral-inverse); color: var(--neutral-primary); opacity: 1; }
.pricing-tabs { display: flex; border-bottom: 1px solid var(--pt-hair); width: 100%; max-width: 720px; }
.pricing-tab { flex: 1; background: transparent; border: none; padding: 18px 12px 16px; font: inherit; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; text-align: center; transition: all 0.25s ease; }
.pricing-tab-title { font-family: 'Lexend', system-ui, sans-serif; font-size: 17px; font-weight: 500; color: var(--neutral-inverse); opacity: 0.55; margin-bottom: 4px; display: inline-flex; align-items: center; gap: 6px; }
.pricing-tab-sub { font-size: 12px; opacity: 0.4; }
.pricing-tab:hover .pricing-tab-title, .pricing-tab:hover .pricing-tab-sub { opacity: 0.85; }
.pricing-tab.is-active { border-bottom-color: var(--accent-primary); }
.pricing-tab.is-active .pricing-tab-title { opacity: 1; color: var(--accent-primary); }
.pricing-tab.is-active .pricing-tab-sub { opacity: 0.7; }
.pricing-tab-dot { display: inline-block; width: 7px; height: 7px; background: var(--accent-primary); transform: rotate(45deg); animation: pricingDotPulse 1.8s ease-in-out infinite; }
.pricing-tab.is-active .pricing-tab-dot { display: none; }
@keyframes pricingDotPulse { 0%, 100% { opacity: 0.35; transform: rotate(45deg) scale(1); } 50% { opacity: 1; transform: rotate(45deg) scale(1.3); } }
.pricing-panel { display: none; }
.pricing-panel.is-active { display: block; animation: pricingFadeIn 0.35s ease; }
@keyframes pricingFadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.pricing-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; }
.pricing-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; max-width: 880px; margin: 0 auto; }
.pricing-grid-1 { max-width: 600px; margin: 0 auto; }
