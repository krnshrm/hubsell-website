.pricing-card-cta:hover {
  background-color: var(--brand-hover, #BE3F22);
  color: #ffffff !important;
}

.pricing-expand { display: block; width: 100%; margin-top: 32px; background: transparent; border: 1px solid var(--pt-hair-strong); border-radius: 12px; padding: 16px 20px; font: inherit; font-size: 14px; font-weight: 500; cursor: pointer; color: var(--neutral-inverse); transition: all 0.2s ease; text-align: center; }
.pricing-expand:hover { border-color: var(--accent-primary); color: var(--accent-primary); }
.pricing-expand-arrow { display: inline-block; transition: transform 0.3s ease; margin-left: 8px; }
.pricing-expand.is-open .pricing-expand-arrow { transform: rotate(180deg); }
.pricing-features { height: 0; overflow: hidden; opacity: 0; }
.pricing-features-inner { padding-top: 32px; }
