.pricing-card-cta {
  display: block;
  text-align: center;
  background-color: var(--accent-primary);
  color: #ffffff !important;
  border: none;
  padding: 14px 24px;
  border-radius: 8px;
  font-family: inherit;
  font-size: 15px;
  font-weight: 500;
  cursor: pointer;
  text-decoration: none;
  transition: background-color 0.25s cubic-bezier(0.16, 1, 0.3, 1), filter 0.25s ease;
