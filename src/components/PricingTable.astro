.pricing-features-thead td { padding: 14px 12px; font-weight: 600; font-size: 14px; text-align: center; }
.pricing-features-thead td:first-child { text-align: left; }
.pricing-features-category td { padding: 32px 0 14px 0; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; opacity: 0.6; border-top: 1px solid var(--pt-hair-strong); }
.pricing-features-row { border-top: 1px solid var(--pt-hair-soft); }
.pricing-features-row td { padding: 14px 12px; font-size: 14px; vertical-align: middle; }
.pricing-features-name { width: 40%; opacity: 0.85; }
.pricing-features-value { width: 20%; text-align: center; opacity: 0.7; }
.pricing-features-x { opacity: 0.25; }
.pricing-popup-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); display: none; align-items: center; justify-content: center; z-index: 9999; }
.pricing-popup-bg.is-open { display: flex; }
.pricing-popup { background: var(--neutral-primary); border-radius: 20px; padding: 40px; max-width: 520px; width: 90%; max-height: 80vh; overflow-y: auto; position: relative; }
.pricing-popup-close { position: absolute; top: 16px; right: 16px; background: transparent; border: none; font-size: 28px; cursor: pointer; opacity: 0.5; padding: 4px 8px; line-height: 1; color: var(--neutral-inverse); }
.pricing-popup-close:hover { opacity: 1; }
.pricing-popup-title { font-family: 'Lexend', system-ui, sans-serif; font-size: 22px; font-weight: 500; margin-bottom: 16px; }
.pricing-popup-body { font-size: 14px; line-height: 1.6; }
@media (max-width: 900px) {
  .pricing-grid-3, .pricing-grid-2 { grid-template-columns: 1fr; max-width: 600px; margin: 0 auto; }
  .pricing-tabs { flex-direction: column; border-bottom: none; gap: 8px; max-width: 100%; }
  .pricing-tab { border: 1px solid var(--pt-hair); border-radius: 12px; padding: 14px 16px; text-align: left; margin-bottom: 0; }
  .pricing-tab.is-active { border-color: var(--accent-primary); background: color-mix(in srgb, var(--accent-primary) 6%, transparent); border-bottom-color: var(--accent-primary); }
}
</style>

<script>
  // Currency conversion + Platform/Data tabs + credits popup.
  function initPricingTable() {
    const wrap = document.querySelector('[data-pricing]');
    if (!wrap || wrap.dataset.pricingBound) return;
    wrap.dataset.pricingBound = '1';

    const symbols = { eur: '€', usd: '$', gbp: '£' };
    const currencyBtns = wrap.querySelectorAll('.pricing-currency-btn');
    const priceValues = wrap.querySelectorAll('.price-value');
    const priceCurrencies = wrap.querySelectorAll('.price-currency');

    function formatPrice(n) {
      if (n >= 1000) return n.toLocaleString('en-US');
      if (n % 1 !== 0) return n.toFixed(2);
      return n.toString();
    }
    function setCurrency(cur) {
      currencyBtns.forEach((b) => b.classList.toggle('is-active', b.dataset.currency === cur));
      priceCurrencies.forEach((c) => (c.textContent = symbols[cur]));
      priceValues.forEach((v) => (v.textContent = formatPrice(parseFloat(v.dataset[cur]))));
    }
    currencyBtns.forEach((b) => b.addEventListener('click', () => setCurrency(b.dataset.currency)));
    setCurrency('eur');

    const tabs = wrap.querySelectorAll('.pricing-tab');
    const panels = wrap.querySelectorAll('.pricing-panel');
    tabs.forEach((t) =>
      t.addEventListener('click', () => {
        const which = t.dataset.tab;
        tabs.forEach((b) => b.classList.toggle('is-active', b === t));
        panels.forEach((p) => p.classList.toggle('is-active', p.dataset.panel === which));
      })
    );

    wrap.querySelectorAll('[data-go-to-tab]').forEach((btn) =>
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const target = btn.dataset.goToTab;
        const tabBtn = wrap.querySelector('.pricing-tab[data-tab="' + target + '"]');
        if (tabBtn) {
          tabBtn.click();
          wrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      })
    );

    const popupBg = wrap.querySelector('[data-popup-bg]');
    const popupClose = wrap.querySelector('[data-popup-close]');
    wrap.querySelectorAll('[data-popup]').forEach((t) =>
      t.addEventListener('click', (e) => {
        e.preventDefault();
        if (popupBg) popupBg.classList.add('is-open');
      })
    );
    if (popupClose) popupClose.addEventListener('click', () => popupBg.classList.remove('is-open'));
    if (popupBg) popupBg.addEventListener('click', (e) => { if (e.target === popupBg) popupBg.classList.remove('is-open'); });
  }

  initPricingTable();
  document.addEventListener('astro:page-load', initPricingTable);
</script>
