---
// ============================= LEARNING NOTES =============================
// SECTION component: one visual band, stacked by a page file. The pattern
// (locale lookup, strings from src/data, semantic markup, scoped style) is
// explained in src/components/Hero.astro; browser-script mechanics in
// src/components/Faq.astro.
// Receives props: L, eyebrow, title, slugs, seeAll, tone, accent. See Avatar.astro for how typed
// props with defaults work.
// Uses set:html to inject trusted HTML strings; see the warning about it
// in src/pages/insights/[slug].astro.
// Has a browser <script>: runs in the visitor's browser, re-inits on
// astro:page-load. Build-time frontmatter vs browser script is explained
// in src/layouts/BaseLayout.astro.
// ==========================================================================
// A small FAQ accordion for the /platform pages: renders a hand-picked subset of
// the shared FAQ source by slug, in the given order, using the global .acc styles
// and the same guarded init pattern as the homepage Faq section.
import { getFaqs } from '../data/faqs-i18n';
import { localizedHref } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  L: Locale;
  eyebrow: string;
  title: string;
  slugs: string[];
  seeAll: string;
  tone?: 'sand' | 'paper';
  accent?: boolean;   // false = muted eyebrow like the homepage hero
}
const { L, eyebrow, title, slugs, seeAll, tone = 'sand', accent = true } = Astro.props;
const all = getFaqs(L);
const picks = slugs
  .map((s) => all.find((f) => f.slug === s))
  .filter((f): f is NonNullable<typeof f> => Boolean(f));
---
<section class={`sec sec--${tone}`} aria-label={title}>
  <div class="wrap" style="max-width:820px">
    <div class="sec-head">
      <p class={accent ? 'eyebrow is-accent' : 'eyebrow'}>{eyebrow}</p>
      <h2 class="heading_primary" style="margin-top:8px">{title}</h2>
    </div>

    <div class="acc" data-accordion style="margin-top:32px">
      {picks.map((f, idx) => (
        <div class={`acc__item${idx === 0 ? ' is-open' : ''}`}>
          <h3 style="margin:0">
            <button class="acc__btn" type="button" aria-expanded={idx === 0 ? 'true' : 'false'}>
              {f.question}
            </button>
          </h3>
          <div class="acc__panel" style={idx === 0 ? 'max-height:400px' : ''} set:html={f.answer}></div>
        </div>
      ))}
    </div>

    <p style="margin-top:28px">
      <a href={localizedHref(L, '/faqs')} class="link">{seeAll}</a>
    </p>
  </div>
</section>

<script>
  function initAccordions() {
    document.querySelectorAll<HTMLElement>('[data-accordion]').forEach((acc) => {
      if (acc.dataset.ready) return;
      acc.dataset.ready = '1';
      acc.querySelectorAll<HTMLElement>('.acc__item').forEach((item) => {
        const btn = item.querySelector<HTMLButtonElement>('.acc__btn')!;
        const panel = item.querySelector<HTMLElement>('.acc__panel')!;
        btn.addEventListener('click', () => {
          const open = item.classList.toggle('is-open');
          btn.setAttribute('aria-expanded', String(open));
          panel.style.maxHeight = open ? panel.scrollHeight + 'px' : '';
        });
      });
    });
  }
  initAccordions();
  document.addEventListener('astro:page-load', initAccordions);
</script>
