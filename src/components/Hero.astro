---
// Homepage hero — section 1, Sand.
// Decluttered: headline + subhead + two CTAs (sign-up first), a quiet ratings
// line, and the discreet "Ask AI" row. The pipeline flow sits to the right.
import HeroPipelineFlow from './HeroPipelineFlow.astro';
import AskAiWidget from './AskAiWidget.astro';
import { SIGNUP_URL, DEMO_URL } from '../data/site';
import { getHome } from '../data/home-i18n';
import { asLocale } from '../i18n/utils';
const { s } = getHome(asLocale(Astro.currentLocale));
---
<section id="hero" class="sec sec--sand hero">
  <div class="wrap">
    <div class="hero__grid">
      <div class="hero__copy reveal-stagger">
        <p class="eyebrow">{s.hero.eyebrow}</p>
        <h1 class="heading_hero">{s.hero.titlePre}<span class="accent">{s.hero.titleAccent}</span>{s.hero.titlePost}</h1>
        <p class="subheading hero__sub">{s.hero.sub}</p>

        <div class="hero__cta">
          <a class="button is-large" href={SIGNUP_URL}>{s.hero.ctaPrimary}</a>
          <a class="button is-secondary is-large" href={DEMO_URL}>{s.hero.ctaSecondary}</a>
        </div>

        <p class="hero__ratings">{s.hero.ratingsPre}<strong>{s.hero.ratingsScore}</strong>{s.hero.ratingsPost}</p>

        <div class="hero__askai"><AskAiWidget /></div>
      </div>

      <div class="hero__visual">
        <HeroPipelineFlow />
      </div>
    </div>
  </div>
</section>

<style>
  /* Hero is the first section. The global .sec padding (up to 120px top+bottom)
     is what pushes the pipeline below the fold — the hero's own content fits.
     Trim it (top especially) so the whole hero clears a ~870px-tall viewport.
     Scoped .hero outranks the global .sec rule, so other sections are untouched. */
  .hero{padding-top:clamp(20px,3vw,32px); padding-bottom:clamp(36px,5vw,56px)}

  .hero__grid{
    display:grid; grid-template-columns:minmax(0,1.05fr) minmax(0,.95fr);
    gap:clamp(32px,5vw,72px); align-items:center;
  }
  .hero__copy{max-width:34rem}
  .hero__copy .eyebrow{margin-bottom:20px}
  .hero__copy .heading_hero{margin-bottom:22px}
  .hero__sub{margin-bottom:34px; max-width:31rem}

  .hero__cta{display:flex; flex-wrap:wrap; gap:14px; align-items:center}

  .hero__ratings{margin:28px 0 0; font-size:.9375rem; color:var(--accent-on); font-weight:500}
  .hero__ratings strong{font-weight:700}

  .hero__askai{margin-top:40px}

  .hero__visual{display:flex; justify-content:center}

  @media (max-width:880px){
    .hero__grid{grid-template-columns:1fr; gap:32px}
    .hero__copy{max-width:none}
  }
</style>
