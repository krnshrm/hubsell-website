---
// ============================= LEARNING NOTES =============================
// ANIMATED VISUAL component. The house recipe (markup with resting states,
// theme-token CSS, GSAP init gated behind html.has-anim, astro:page-load
// re-init) is explained once in src/components/HeroPipelineFlow.astro;
// read that first, then this file is mostly scene-specific detail.
// No props: it reads Astro.currentLocale and fetches its own strings
// from src/data/ (embed-i18n).
// Its styles use :global()/is:global because they must reach markup that
// Astro's scoping cannot see (slotted or set:html content); the gotcha is
// explained in src/layouts/PageLayout.astro.
// ==========================================================================
// Pipeline step 3 — CRM sync. A targeted contact on the left, every touchpoint
// logging into the CRM activity feed on the right, in real time. White cards on
// espresso; the sync line and accents are hubsell green. Adapted: bundled GSAP,
// reduced-motion safe (the full feed renders at rest when motion is off), purple
// recoloured to green, font links dropped.
import { et } from '../data/embed-i18n';
import { asLocale } from '../i18n/utils';
const L = asLocale(Astro.currentLocale);
---
<div class="hubsell-sync-embed">
  <div class="cs-wrapper">

    <!-- Profile Card -->
    <div class="cs-card">
      <div class="cs-card-role">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>
        {et(L, "Targeted contact")}
      </div>
      <div class="cs-card-profile">
        <div class="cs-avatar">AC</div>
        <div class="cs-profile-info">
          <span class="cs-name">Alex Chen</span>
          <span class="cs-job">{et(L, "Security Architect")}</span>
          <div class="cs-social-row">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
        </div>
      </div>
      <div class="cs-details-grid" style="margin-top:6px;">
        <span class="cs-pill cs-sync-tag cs-tag-10"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg> {et(L, "Connected")}</span>
        <span class="cs-pill cs-sync-tag cs-tag-8"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg> {et(L, "Opened")}</span>
      </div>
      <div class="cs-details-grid">
        <span class="cs-pill cs-sync-tag cs-tag-7"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94m-1 7.98v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg> {et(L, "Clicked")}</span>
        <span class="cs-pill cs-sync-tag cs-tag-6"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> {et(L, "Spent 5 mins")}</span>
      </div>
      <div class="cs-details-grid">
        <span class="cs-pill cs-sync-tag cs-tag-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg> {et(L, "Replied")}</span>
        <span class="cs-pill cs-sync-tag cs-tag-1"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> {et(L, "Booked")}</span>
      </div>
    </div>

    <!-- Connector -->
    <div class="cs-connector">
      <svg viewBox="0 0 90 20" xmlns="http://www.w3.org/2000/svg">
        <defs><filter id="soft-glow" x="-20%" y="-20%" width="140%" height="140%"><feGaussianBlur stdDeviation="1.8" result="blur" /><feComposite in="SourceGraphic" in2="blur" operator="over" /></filter></defs>
        <path class="cs-base-track" d="M 0 10 H 90" fill="none" stroke="#2FA06E" stroke-width="2" stroke-opacity="0" />
        <path class="cs-zap-line" d="M 0 10 H 90" fill="none" stroke="#FFFFFF" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="25 100" stroke-dashoffset="120" opacity="0" filter="url(#soft-glow)" />
      </svg>
    </div>

    <!-- CRM window -->
    <div class="cs-crm-card">
      <div>
        <h3 class="cs-crm-title">{et(L, "Syncing contact")}</h3>
        <p class="cs-crm-subtitle">{et(L, "Recent activity: Alex Chen")}</p>
      </div>
      <div class="cs-activity-window">
        <div class="cs-activity-track">
          <div class="cs-act-item cs-log-1"><svg class="cs-act-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg><div class="cs-act-row-1"><span class="cs-act-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> {et(L, "Meeting booked")}</span> {et(L, "1 hour ago")}</div></div>
          <div class="cs-act-item cs-log-2"><svg class="cs-act-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg><div class="cs-act-row-1"><span class="cs-act-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg> {et(L, "Replied")}</span> {et(L, "2 hours ago")}</div></div>
          <div class="cs-act-item cs-log-3"><svg class="cs-act-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94m-1 7.98v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg><div class="cs-act-row-1"><span class="cs-act-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94m-1 7.98v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg> {et(L, "Clicked")}</span> {et(L, "5 hours ago")}</div></div>
          <div class="cs-act-item cs-log-4"><svg class="cs-act-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg><div class="cs-act-row-1"><span class="cs-act-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg> {et(L, "Opened email")}</span> {et(L, "8 hours ago")}</div></div>
          <div class="cs-act-item cs-log-5"><svg class="cs-act-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"></path><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg><div class="cs-act-row-1"><span class="cs-act-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"></path><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg> {et(L, "Sent email")}</span> {et(L, "14 hours ago")}</div></div>
          <div class="cs-act-item cs-log-6"><svg class="cs-act-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg><div class="cs-act-row-1"><span class="cs-act-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> {et(L, "Spent 5 mins")}</span> {et(L, "1 day ago")}</div></div>
          <div class="cs-act-item cs-log-7"><svg class="cs-act-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94m-1 7.98v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg><div class="cs-act-row-1"><span class="cs-act-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94m-1 7.98v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg> {et(L, "Clicked")}</span> {et(L, "1 day ago")}</div></div>
          <div class="cs-act-item cs-log-8"><svg class="cs-act-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg><div class="cs-act-row-1"><span class="cs-act-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg> {et(L, "Opened email")}</span> {et(L, "1 day ago")}</div></div>
          <div class="cs-act-item cs-log-9"><svg class="cs-act-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"></path><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg><div class="cs-act-row-1"><span class="cs-act-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"></path><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg> {et(L, "Sent email")}</span> {et(L, "2 days ago")}</div></div>
          <div class="cs-act-item cs-log-10"><svg class="cs-act-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg><div class="cs-act-row-1"><span class="cs-act-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg> {et(L, "Connected")}</span> {et(L, "3 days ago")}</div></div>
          <div class="cs-act-item cs-log-11"><svg class="cs-act-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg><div class="cs-act-row-1"><span class="cs-act-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg> {et(L, "Profile visited")}</span> {et(L, "4 days ago")}</div></div>
          <div class="cs-act-item cs-log-12"><svg class="cs-act-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg><div class="cs-act-row-1"><span class="cs-act-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg> {et(L, "Request sent")}</span> {et(L, "5 days ago")}</div></div>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
  .hubsell-sync-embed{ display:flex; justify-content:center; align-items:center; font-family:'Instrument Sans', system-ui, sans-serif; padding:8px 0; width:100%; background:transparent; box-sizing:border-box; overflow:visible }
  .hubsell-sync-embed *{ box-sizing:border-box }
  .cs-wrapper{ display:flex; align-items:center; gap:0; width:max-content }

  .cs-card{ width:280px; background:#FFFFFF; border:1px solid #E5E7EB; border-radius:12px; padding:16px 20px; box-shadow:0 10px 28px rgba(0,0,0,.20); display:flex; flex-direction:column; gap:14px; position:relative; cursor:pointer; z-index:5; transition:transform .3s cubic-bezier(0.16,1,0.3,1), box-shadow .3s ease, border-color .3s ease }
  .cs-card:hover{ transform:translateY(-4px) !important; box-shadow:0 18px 34px rgba(47,160,110,.18); border-color:#2FA06E; z-index:10 }
  .cs-card-role{ display:flex; align-items:center; gap:6px; font-size:13px; font-weight:500; color:#374151 }
  .cs-card-role svg{ color:#2FA06E }
  .cs-card-profile{ display:flex; align-items:center; gap:14px; padding:12px; border:1px solid #E5E7EB; border-radius:8px; background:#F9FAFB }
  .cs-avatar{ width:40px; height:40px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:600; font-size:14px; color:#FFFFFF; flex-shrink:0; background:linear-gradient(135deg, #2FA06E, #155C3F) }
  .cs-profile-info{ display:flex; flex-direction:column; gap:2px }
  .cs-name{ font-family:'Lexend', sans-serif; font-size:15px; font-weight:600; color:#111827; line-height:1.1 }
  .cs-job{ font-size:12px; color:#6B7280 }
  .cs-social-row{ display:flex; gap:8px; margin-top:4px; color:#9CA3AF }
  .cs-details-grid{ display:flex; flex-wrap:wrap; align-items:center; gap:6px; font-size:11px; color:#4B5563 }
  .cs-pill{ padding:4px 8px; border:1px solid #E5E7EB; border-radius:12px; display:flex; align-items:center; gap:5px; background:#FFFFFF; white-space:nowrap; transition:all .25s ease }
  .cs-pill svg{ color:currentColor }

  .cs-connector{ position:relative; width:90px; height:20px; z-index:1; display:flex; align-items:center; overflow:visible }
  .cs-connector svg{ width:100%; height:100%; overflow:visible }
  .cs-zap-line{ stroke:#FFFFFF !important; -webkit-filter:drop-shadow(0 0 4px rgba(47,160,110,1)) drop-shadow(0 0 8px rgba(47,160,110,.8)); filter:drop-shadow(0 0 4px rgba(47,160,110,1)) drop-shadow(0 0 8px rgba(47,160,110,.8)); will-change:stroke-dashoffset, opacity }

  .cs-crm-card{ width:340px; height:480px; background:#FFFFFF; border:1px solid #E5E7EB; border-radius:12px; padding:24px; box-shadow:0 10px 30px rgba(0,0,0,.20); display:flex; flex-direction:column; z-index:5; transition:transform .3s cubic-bezier(0.16,1,0.3,1), box-shadow .3s ease, border-color .3s ease }
  .cs-crm-card:hover{ transform:translateY(-4px) !important; box-shadow:0 18px 34px rgba(0,0,0,.24); border-color:#2FA06E; z-index:10 }
  .cs-crm-title{ font-family:'Lexend', sans-serif; font-size:16px; font-weight:600; color:#111827; margin:0 0 6px 0 ; overflow-wrap:break-word; hyphens:auto; }
  .cs-crm-subtitle{ font-size:13px; color:#6B7280; padding-bottom:16px; border-bottom:1px solid #E5E7EB; margin:0 0 28px 0 }

  .cs-activity-window{ flex:1; overflow-y:auto; padding-right:4px; padding-top:4px }
  .cs-activity-window::-webkit-scrollbar{ width:4px }
  .cs-activity-window::-webkit-scrollbar-track{ background:transparent }
  .cs-activity-window::-webkit-scrollbar-thumb{ background:#E5E7EB; border-radius:4px }
  .cs-activity-window::-webkit-scrollbar-thumb:hover{ background:#CBD5E1 }
  .cs-activity-track{ display:flex; flex-direction:column }

  /* Activity rows: visible at rest (reduced motion shows the full feed) */
  .cs-act-item{ display:flex; align-items:center; gap:12px; margin-bottom:12px }
  .cs-act-icon{ color:#9CA3AF; flex-shrink:0 }
  .cs-act-row-1{ display:flex; align-items:center; gap:8px; font-size:12px; color:#6B7280; white-space:nowrap }
  .cs-act-pill{ padding:4px 8px; border:1px solid #E5E7EB; border-radius:6px; display:flex; align-items:center; gap:6px; color:#374151; font-weight:500; background:#FFFFFF }
  .cs-act-pill svg{ color:#6B7280 }

  @media (max-width:860px){
    .hubsell-sync-embed{ padding:8px 0 }
    .cs-wrapper{ flex-direction:column; width:100%; max-width:340px; gap:24px }
    .cs-card{ width:100% }
    .cs-connector{ display:none !important }
    .cs-crm-card{ width:100%; height:auto; min-height:480px }
  }

  /* Motion-on starting states only */
  :global(html.has-anim) .cs-card,
  :global(html.has-anim) .cs-crm-card{ opacity:0; transform:translateY(15px) }
  :global(html.has-anim) .cs-act-item{ height:0; opacity:0; margin-bottom:0; overflow:hidden; transform:translateY(-10px) }
  :global(html.has-anim) .cs-sync-tag{ opacity:0; visibility:hidden; transform:scale(0.8) }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initCrmSync() {
    const wrap = document.querySelector('.hubsell-sync-embed') as HTMLElement | null;
    if (!wrap || wrap.dataset.init) return;
    if (!document.documentElement.classList.contains('has-anim')) return;
    wrap.dataset.init = '1';

    gsap.registerPlugin(ScrollTrigger);

    const leftCard = wrap.querySelector('.cs-card');
    const crmCard = wrap.querySelector('.cs-crm-card');
    const zapLine = wrap.querySelector('.cs-zap-line');
    const baseTrack = wrap.querySelector('.cs-base-track');
    const tags = wrap.querySelectorAll('.cs-sync-tag');
    const logItems = wrap.querySelectorAll('.cs-act-item');

    const syncTl = gsap.timeline({ paused: true, repeat: 0 });
    const zapTl = gsap.timeline({ repeat: -1, paused: true });

    function applyResetStates() {
      gsap.set([leftCard, crmCard], { opacity: 0, y: 15 });
      if (baseTrack) gsap.set(baseTrack, { strokeOpacity: 0 });
      gsap.set(tags, { opacity: 0, scale: 0.8, visibility: 'hidden', backgroundColor: '#FFFFFF', borderColor: '#E5E7EB', color: '#6B7280' });
      gsap.set(logItems, { height: 0, opacity: 0, y: -10, overflow: 'hidden', marginBottom: 0, marginTop: 0, padding: 0, display: 'none' });
      if (zapLine) gsap.set(zapLine, { strokeDashoffset: 120, opacity: 0 });
    }

    function revealLog(selector: string) {
      return gsap.to(selector, {
        display: 'flex', height: 'auto', opacity: 1, y: 0, marginBottom: 12, duration: 0.4, ease: 'power2.out',
        onComplete() { gsap.set(selector, { overflow: 'visible' }); },
      });
    }

    function highlightTag(selector: string) {
      const isBooked = selector.includes('cs-tag-1') && !selector.includes('cs-tag-10');
      const bg = isBooked ? '#ECFDF5' : '#E4F2EA';
      const border = isBooked ? '#34D399' : '#6FCF97';
      const text = isBooked ? '#059669' : '#155C3F';
      return gsap.to(selector, { visibility: 'visible', opacity: 1, scale: 1, backgroundColor: bg, borderColor: border, color: text, duration: 0.4, ease: 'back.out(1.5)' });
    }

    function addSyncStep(tagSelector: string | null, logSelector: string, delay: string = '+=0.6') {
      if (tagSelector) {
        syncTl.add(highlightTag(tagSelector), delay);
        syncTl.add(revealLog(logSelector), '+=0.25');
      } else {
        syncTl.add(revealLog(logSelector), delay);
      }
    }

    if (zapLine) {
      zapTl.fromTo(zapLine, { strokeDashoffset: 120, opacity: 0 }, {
        keyframes: [
          { strokeDashoffset: 120, opacity: 1, duration: 0 },
          { strokeDashoffset: -120, opacity: 1, duration: 8 },
          { opacity: 0, duration: 0.1 },
        ], ease: 'none',
      });
    }

    syncTl.add(applyResetStates);
    syncTl.to(leftCard, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '+=0.2');
    syncTl.to(crmCard, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '+=0.15');
    if (baseTrack) syncTl.to(baseTrack, { strokeOpacity: 1, duration: 0.4, ease: 'power1.inOut' }, '+=0.1');
    syncTl.add(() => { zapTl.play(0); });

    addSyncStep(null, '.cs-log-12', '+=0.5');
    addSyncStep(null, '.cs-log-11');
    addSyncStep('.cs-tag-10', '.cs-log-10');
    addSyncStep(null, '.cs-log-9');
    addSyncStep('.cs-tag-8', '.cs-log-8');
    addSyncStep('.cs-tag-7', '.cs-log-7');
    addSyncStep('.cs-tag-6', '.cs-log-6');
    addSyncStep(null, '.cs-log-5');
    addSyncStep(null, '.cs-log-4');
    addSyncStep('.cs-tag-7', '.cs-log-3');
    addSyncStep('.cs-tag-2', '.cs-log-2');
    addSyncStep('.cs-tag-1', '.cs-log-1');

    ScrollTrigger.create({ trigger: wrap, start: 'top 75%', once: true, onEnter: () => syncTl.play() });
  }

  initCrmSync();
  document.addEventListener('astro:page-load', initCrmSync);
</script>
