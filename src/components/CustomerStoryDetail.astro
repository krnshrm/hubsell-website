---
// Shared customer-story body, rendered by /customerstories/[slug] (English,
// `customerstories`) and /de/customerstories/[slug] (German, `customerstoriesDe`).
// Self-localizes UI strings from Astro.currentLocale; the story body, pull quote,
// results, and byline come from the entry, already in the page's language. The
// route owns BaseLayout, the Newsreader font link, and the breadcrumb JSON-LD.
import { getCustomerStoriesPage } from '../i18n/pages';
import { asLocale, localizedHref } from '../i18n/utils';
import { SIGNUP_URL } from '../data/site';

interface Props { story: any; stories: any[]; }
const { story, stories } = Astro.props;
const { title, company, champion, championTitle, championImage, testimonial, results, cta } = story.data;

const L = asLocale(Astro.currentLocale);
const c = getCustomerStoriesPage(L);

// story.body is the raw Webflow HTML, already link-rewritten by the converter.
const bodyHtml = story.body && story.body.trim() ? story.body : '';
// the export wraps the testimonial in straight quotes; the pull-quote supplies its own.
const quote = (testimonial || '').replace(/^[\s"“”]+|[\s"“”]+$/g, '');
const role = [championTitle, company].filter(Boolean).join(', ');

// Two other customer stories to read, rotating by slug so each story differs.
const others = stories.filter((s) => s.id !== story.id);
const off = others.length ? [...story.id].reduce((a, c2) => a + c2.charCodeAt(0), 0) % others.length : 0;
const related = others.length
  ? [...new Map([others[off], others[(off + 1) % others.length]].filter(Boolean).map((s) => [s.id, s])).values()]
  : [];

// Trial CTA copy: a per-story override (frontmatter `cta`) if set, otherwise a default.
const ctaText = cta || c.ctaTextDefault;
---
<article class="sec sec--paper cs-page">
  <div class="wrap">
    <a class="cs-back link" href={localizedHref(L, '/customerstories')}>&larr; {c.back}</a>

    <header class="cs-head">
      <p class="eyebrow is-accent">{c.eyebrowStory}</p>
      <h1 class="cs-title">{title}</h1>

      {champion && (
        <div class="cs-byline">
          {championImage && (
            <img class="cs-byline__img" src={championImage} alt={champion} width="48" height="48" loading="lazy" />
          )}
          <div>
            <p class="cs-byline__name">{champion}</p>
            {role && <p class="cs-byline__role">{role}</p>}
          </div>
        </div>
      )}
    </header>

    {results && results.length > 0 && (
      <div class="cs-results">
        {results.map((r: any) => (
          <div class="cs-result">
            <p class="cs-result__metric">{r.metric}</p>
            <p class="cs-result__label">{r.label}</p>
          </div>
        ))}
      </div>
    )}

    {quote && (
      <blockquote class="cs-quote">
        <p>{quote}</p>
        {champion && <footer>{champion}{role ? `, ${role}` : ''}</footer>}
      </blockquote>
    )}

    <div class="story" set:html={bodyHtml} />

    {related.length > 0 && (
      <aside class="cs-related">
        <p class="eyebrow is-accent">{c.relatedLabel}</p>
        <div class="cs-related__grid">
          {related.map((s: any) => (
            <a class="cs-card" href={localizedHref(L, `/customerstories/${s.id}`)}>
              <div class="cs-card__top">
                {s.data.championImage && (
                  <img class="cs-card__img" src={s.data.championImage} alt={s.data.champion} loading="lazy" width="40" height="40" />
                )}
                <span class="cs-card__co">{s.data.company}</span>
              </div>
              <h3 class="cs-card__title">{s.data.title}</h3>
              {s.data.results && s.data.results.length > 0 && (
                <ul class="cs-card__metrics">
                  {s.data.results.map((r: any) => (
                    <li><b>{r.metric}</b> <span>{r.label}</span></li>
                  ))}
                </ul>
              )}
              <span class="cs-card__more">{c.readStory}</span>
            </a>
          ))}
        </div>
      </aside>
    )}

    <aside class="cs-cta sec--navy">
      <h2 class="cs-cta__title">{c.ctaTitlePre}{company || c.ctaTitleFallback}{c.ctaTitlePost}</h2>
      <p class="cs-cta__text">{ctaText}</p>
      <a class="button is-large" href={localizedHref(L, SIGNUP_URL)}>{c.ctaButton}</a>
    </aside>
  </div>
</article>

<style>
  .cs-back { display:inline-block; font-size:14px; margin-bottom:28px; }
  .cs-head { max-width:760px; margin:0 auto; }
  .cs-title {
    font-family:var(--font-head); font-weight:600;
    font-size:clamp(1.9rem,4vw,2.75rem); line-height:1.12; letter-spacing:-.02em;
    color:var(--sec-tx); margin:10px 0 0;
  }
  .cs-byline { display:flex; align-items:center; gap:12px; margin-top:22px; }
  .cs-byline__img { width:48px; height:48px; border-radius:50%; object-fit:cover; border:1px solid var(--sec-bd); background:color-mix(in srgb,var(--sec-tx) 6%,transparent); }
  .cs-byline__name { font-family:var(--font-head); font-weight:600; font-size:1rem; color:var(--sec-tx); margin:0; }
  .cs-byline__role { font-family:var(--font-body); font-size:14px; color:var(--sec-tx); opacity:.62; margin:2px 0 0; }

  /* results band */
  .cs-results {
    max-width:760px; margin:36px auto 0; padding:24px 0;
    border-top:1px solid var(--sec-bd); border-bottom:1px solid var(--sec-bd);
    display:grid; grid-template-columns:repeat(3,1fr); gap:24px;
  }
  .cs-result__metric { font-family:var(--font-head); font-weight:600; font-size:clamp(1.8rem,3.2vw,2.4rem); line-height:1; letter-spacing:-.02em; color:var(--accent-on); margin:0; }
  .cs-result__label { font-family:var(--font-body); font-size:13.5px; line-height:1.45; color:var(--sec-tx); opacity:.7; margin:8px 0 0; }
  @media (max-width:600px){ .cs-results { grid-template-columns:1fr; gap:18px; } }

  /* pull quote */
  .cs-quote {
    max-width:760px; margin:34px auto 0; padding:0 0 0 22px;
    border-left:3px solid var(--accent-on);
    font-family:'Newsreader', Georgia, serif; font-weight:500;
    font-size:clamp(1.3rem,2.4vw,1.65rem); line-height:1.45; color:var(--sec-tx);
  }
  .cs-quote p { margin:0; }
  .cs-quote footer { font-family:var(--font-body); font-weight:500; font-size:14px; opacity:.62; margin-top:14px; }

  /* reading column: serif body (Newsreader), brand headings (Lexend) — matches the blog */
  .story {
    max-width:68ch; margin:34px auto 0;
    font-family:'Newsreader', Georgia, 'Times New Roman', serif;
    font-size:1.1875rem; line-height:1.75; color:var(--sec-tx);
  }
  .story > :first-child { margin-top:0; }
  .story :is(h2,h3,h4) { font-family:var(--font-head); font-weight:600; color:var(--sec-tx); line-height:1.2; letter-spacing:-.01em; }
  .story h2 { font-size:1.6rem; margin:1.7em 0 .5em; }
  .story h3 { font-size:1.25rem; margin:1.5em 0 .4em; }
  .story h4 { font-size:1.08rem; margin:1.4em 0 .4em; }
  .story p { margin:0 0 1.1em; }
  .story a { color:var(--accent-on); text-decoration:none; border-bottom:1px solid transparent; transition:border-color .15s; overflow-wrap:anywhere; }
  .story a:hover { border-bottom-color:var(--accent-on); }
  .story strong { font-weight:600; }
  .story em { font-style:italic; }
  .story ul, .story ol { margin:0 0 1.1em; padding-left:1.3em; }
  .story li { margin:0 0 .5em; }
  .story li::marker { color:var(--accent-on); }
  .story hr { border:0; border-top:1px solid var(--sec-bd); margin:2em 0; }

  /* more customer stories (mirrors the overview cards) */
  .cs-related { max-width:760px; margin:52px auto 0; }
  .cs-related__grid { display:grid; grid-template-columns:repeat(2,1fr); gap:20px; margin-top:16px; }
  .cs-card {
    display:flex; flex-direction:column;
    background:var(--sec-card); border:1px solid var(--sec-bd); border-radius:var(--radius-lg);
    padding:24px 24px 22px; color:var(--sec-tx); text-decoration:none;
    transition:border-color .15s, transform .05s;
  }
  .cs-card:hover { border-color:color-mix(in srgb,var(--accent-on) 55%,var(--sec-bd)); }
  .cs-card:active { transform:translateY(1px); }
  .cs-card__top { display:flex; align-items:center; gap:10px; margin-bottom:14px; }
  .cs-card__img { width:40px; height:40px; border-radius:50%; object-fit:cover; border:1px solid var(--sec-bd); background:color-mix(in srgb,var(--sec-tx) 6%,transparent); }
  .cs-card__co { font-family:var(--font-body); font-weight:500; font-size:13px; letter-spacing:.04em; text-transform:uppercase; color:var(--sec-tx); opacity:.7; }
  .cs-card__title { font-family:var(--font-head); font-weight:600; font-size:1.2rem; line-height:1.25; letter-spacing:-.01em; color:var(--sec-tx); margin:0 0 16px; }
  .cs-card__metrics { list-style:none; margin:0 0 18px; padding:0; display:flex; flex-direction:column; gap:9px; }
  .cs-card__metrics li { display:flex; align-items:baseline; gap:8px; font-family:var(--font-body); font-size:13.5px; line-height:1.35; color:var(--sec-tx); }
  .cs-card__metrics b { font-family:var(--font-head); font-weight:600; font-size:1.05rem; color:var(--accent-on); min-width:64px; }
  .cs-card__metrics span { opacity:.72; }
  .cs-card__more { margin-top:auto; font-family:var(--font-body); font-weight:500; font-size:14px; color:var(--accent-on); }

  /* closing trial CTA (navy panel) */
  .cs-cta {
    max-width:760px; margin:48px auto 0; padding:clamp(28px,4vw,44px);
    border-radius:var(--radius-lg); text-align:center;
    background:var(--sec-bg); color:var(--sec-tx); border:1px solid var(--sec-bd);
  }
  .cs-cta__title { font-family:var(--font-head); font-weight:600; font-size:clamp(1.5rem,3vw,2rem); letter-spacing:-.02em; color:var(--sec-tx); margin:0; }
  .cs-cta__text { font-family:var(--font-body); font-size:1.0625rem; line-height:1.6; color:var(--sec-tx); opacity:.82; max-width:52ch; margin:12px auto 22px; }

  @media (max-width:600px){ .story { font-size:1.0625rem; } .cs-related__grid { grid-template-columns:1fr; } }
</style>
