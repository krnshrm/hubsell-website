---
// ============================= LEARNING NOTES =============================
// SECTION component: one visual band, stacked by a page file. The pattern
// (locale lookup, strings from src/data, semantic markup, scoped style) is
// explained in src/components/Hero.astro; browser-script mechanics in
// src/components/Faq.astro.
// No props: it reads Astro.currentLocale and fetches its own strings
// from src/data/ (home-i18n).
// ==========================================================================
// Section 14 — Insights (Paper): newsletter signup + latest blog posts.
import { getHome } from '../data/home-i18n';
import { asLocale, localizedHref } from '../i18n/utils';
import WaitlistForm from './WaitlistForm.astro';
const L = asLocale(Astro.currentLocale);
const { insights, s } = getHome(L);
---
<section id="insights" class="sec sec--paper" aria-labelledby="insights-title">
  <div class="wrap">
    <div class="card reveal" style="display:flex;flex-wrap:wrap;gap:24px;align-items:center;justify-content:space-between;margin-bottom:48px">
      <div style="max-width:46ch">
        <h2 class="heading_secondary">{s.insightsSec.newsTitle}</h2>
        <p class="paragraph_small" style="opacity:.75;margin-top:8px">{s.insightsSec.newsSub}</p>
      </div>
      <div style="flex:1;min-width:280px;max-width:420px">
        <WaitlistForm form="newsletter" buttonLabel={s.insightsSec.subscribeLabel} placeholder={s.insightsSec.emailPlaceholder} help="" />
      </div>
    </div>

    <div class="sec-head reveal">
      <p class="eyebrow is-accent">{s.insightsSec.eyebrow}</p>
      <h2 id="insights-title" class="heading_primary" style="margin-top:8px">{s.insightsSec.title}</h2>
    </div>

    <div class="grid grid-3 reveal-stagger">
      {insights.map((post) => (
        <a class="post" href={localizedHref(L, `/insights/${post.slug}`)}>
          <img class="post__img" src={post.image} alt={post.title} loading="lazy" width="400" height="225" />
          <div class="post__body">
            <p class="eyebrow is-accent" style="font-size:.72rem">{s.insightsSec.cardTag}</p>
            <h3 class="post__title">{post.title}</h3>
            <p class="post__excerpt">{post.excerpt}</p>
          </div>
        </a>
      ))}
    </div>

    <p class="reveal" style="margin-top:30px">
      <a href={localizedHref(L, '/insights')} class="link">{s.insightsSec.readMore}</a>
    </p>
  </div>
</section>
