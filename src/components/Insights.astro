---
// Section 14 — Insights (Paper): newsletter signup + latest blog posts.
import { insights } from '../data/home-content';
import WaitlistForm from './WaitlistForm.astro';
---
<section id="insights" class="sec sec--paper" aria-labelledby="insights-title">
  <div class="wrap">
    <div class="card reveal" style="display:flex;flex-wrap:wrap;gap:24px;align-items:center;justify-content:space-between;margin-bottom:48px">
      <div style="max-width:46ch">
        <h2 class="heading_secondary">Stay ahead in B2B sales and marketing</h2>
        <p class="paragraph_small" style="opacity:.75;margin-top:8px">Playbooks, deliverability, and outbound strategy, straight to your inbox.</p>
      </div>
      <div style="flex:1;min-width:280px;max-width:420px">
        <WaitlistForm form="newsletter" buttonLabel="Subscribe" placeholder="Your email" help="" />
      </div>
    </div>

    <div class="sec-head reveal">
      <p class="eyebrow is-accent">Insights</p>
      <h2 id="insights-title" class="heading_primary" style="margin-top:8px">B2B outbound sales playbooks and insights</h2>
    </div>

    <div class="grid grid-3 reveal-stagger">
      {insights.map((post) => (
        <a class="post" href={`/insights/${post.slug}`}>
          <img class="post__img" src={post.image} alt={post.title} loading="lazy" width="400" height="225" />
          <div class="post__body">
            <p class="eyebrow is-accent" style="font-size:.72rem">B2B sales</p>
            <h3 class="post__title">{post.title}</h3>
            <p class="post__excerpt">{post.excerpt}</p>
          </div>
        </a>
      ))}
    </div>

    <p class="reveal" style="margin-top:30px">
      <a href="/insights" class="link">Read more insights →</a>
    </p>
  </div>
</section>
