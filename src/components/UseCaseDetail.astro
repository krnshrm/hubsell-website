---
// Shared use-case detail body, rendered by /use-cases/[slug] (English, from the
// `usecases` collection) and /de/use-cases/[slug] (German, from `usecasesDe`).
// Self-localizes UI strings from Astro.currentLocale; the route passes the entry
// and its sibling items (same collection) for the related lookup. The proof block
// reuses the German champion quote + metrics from testimonialsDe by slug; the
// testimonial strip draws from the locale-matched pool.
import { getCollection } from 'astro:content';
import Avatar from './Avatar.astro';
import TestimonialStrip from './TestimonialStrip.astro';
import UnifiedGrid from './UnifiedGrid.astro';
import ZeroDayTimeline from './ZeroDayTimeline.astro';
import MultichannelFlow from './MultichannelFlow.astro';
import SocialProspecting from './SocialProspecting.astro';
import { TESTIMONIALS } from '../data/testimonials';
import { TESTIMONIALS_DE } from '../data/testimonials.de';
import { TESTIMONIALS_NL } from '../data/testimonials.nl';
import { testimonialsDe } from '../data/home.de';
import { testimonialsNl } from '../data/home.nl';
import { getUseCasesPage } from '../i18n/pages';
import { asLocale, localizedHref } from '../i18n/utils';
import { SIGNUP_URL, DEMO_URL } from '../data/site';

interface Props { entry: any; items: any[]; }
const { entry, items } = Astro.props;
const d = entry.data;
const { Content } = await entry.render();

const L = asLocale(Astro.currentLocale);
const c = getUseCasesPage(L);

// Page visual: a real product widget, reused from the homepage embeds.
const WIDGETS: Record<string, any> = { UnifiedGrid, ZeroDayTimeline, MultichannelFlow, SocialProspecting };
const Widget = d.widget && WIDGETS[d.widget] ? WIDGETS[d.widget] : null;
const widgetBg = d.widgetBg || 'sec--navy';

// Proof = the referenced customer story (English collection; stories not yet
// localized). For German, swap in the champion's German quote + metrics by slug.
let proof: any = null;
if (d.proofStory) {
  const stories = await getCollection('customerstories', (s: any) => !s.data.draft);
  proof = stories.find((s: any) => s.slug === d.proofStory) || null;
}
const deProof = L === 'de' && proof ? testimonialsDe.find((t) => t.slug === proof.slug) : null;
const nlProof = L === 'nl' && proof ? testimonialsNl.find((t) => t.slug === proof.slug) : null;
const proofQuote = ((deProof?.quote ?? nlProof?.quote ?? proof?.data.testimonial) ?? '').replace(/^[\s"“”]+|[\s"“”]+$/g, '');
const proofMetrics = (deProof?.results ?? nlProof?.results ?? proof?.data.results) ?? [];
const proofRole = proof ? [proof.data.championTitle, proof.data.company].filter(Boolean).join(', ') : '';
const championPhoto = proof ? TESTIMONIALS.find((t) => t.storySlug === proof.slug)?.photo : undefined;

// Strip = curated testimonials for this use case, from the locale-matched pool,
// never repeating the proof champion.
const pool = L === 'de' ? TESTIMONIALS_DE : L === 'nl' ? TESTIMONIALS_NL : TESTIMONIALS;
const stripQuotes = (d.quotes ?? [])
  .map((s: string) => pool.find((t) => t.slug === s))
  .filter(Boolean)
  .filter((t: any) => t.storySlug !== proof?.slug);

// Related: the explicit list, else the other use-cases in order.
const others = items
  .filter((u) => u.slug !== entry.slug)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const related = (d.related && d.related.length
  ? d.related.map((slug: string) => items.find((u) => u.slug === slug)).filter(Boolean)
  : others
).slice(0, 2);

const ctaHeading = d.ctaHeading || c.ctaHeadingDefault;
const ctaText = d.ctaText || c.ctaTextDefault;
---
{/* HERO */}
<section class="sec sec--paper uc-hero">
  <div class="wrap">
    <a class="uc-back link" href={localizedHref(L, '/use-cases')}>&larr; {c.back}</a>
    <p class="eyebrow is-accent">{d.eyebrow || c.eyebrowDefault}</p>
    <h1 class="uc-title">{d.title}</h1>
    {d.subhead && <p class="uc-sub subheading">{d.subhead}</p>}
    <div class="uc-cta-row">
      <a class="button" href={localizedHref(L, SIGNUP_URL)}>{c.ctaPrimary}</a>
      <a class="button is-secondary" href={localizedHref(L, DEMO_URL)}>{c.ctaSecondary}</a>
    </div>
  </div>
</section>

{/* PRODUCT VISUAL */}
{Widget && (
  <section class={`sec ${widgetBg} uc-visual`}>
    <div class="wrap">
      {d.widgetCaption && <p class="uc-visual__cap">{d.widgetCaption}</p>}
      <div class="uc-visual__frame"><Widget /></div>
    </div>
  </section>
)}

{/* BODY */}
<section class="sec sec--paper uc-bodywrap">
  <div class="wrap">
    {(d.features?.length || d.roles?.length) && (
      <div class="uc-meta">
        {d.features?.length && (
          <div class="uc-meta__col">
            <p class="uc-meta__head">{c.powersHead}</p>
            <ul class="uc-taglist">{d.features.map((f: string) => (<li>{f}</li>))}</ul>
          </div>
        )}
        {d.roles?.length && (
          <div class="uc-meta__col">
            <p class="uc-meta__head">{c.rolesHead}</p>
            <ul class="uc-taglist">{d.roles.map((r: string) => (<li>{r}</li>))}</ul>
          </div>
        )}
      </div>
    )}
    <div class="uc-body"><Content /></div>
  </div>
</section>

{/* PROOF + WHAT TEAMS SAY */}
{(proof || stripQuotes.length > 0) && (
  <section class="sec sec--sand uc-proofwrap">
    <div class="wrap">
      {proof && (
        <aside class="uc-proof">
          <p class="eyebrow is-accent">{c.proofLabel}</p>
          {proofQuote && <blockquote class="uc-proof__quote">{proofQuote}</blockquote>}
          {proofMetrics.length > 0 && (
            <div class="uc-proof__metrics">
              {proofMetrics.map((r: any) => (
                <div class="uc-proof__metric">
                  <p class="uc-proof__num">{r.metric}</p>
                  <p class="uc-proof__lab">{r.label}</p>
                </div>
              ))}
            </div>
          )}
          <div class="uc-proof__by">
            <Avatar src={championPhoto} name={proof.data.champion} size={46} />
            <span class="uc-proof__bymeta">
              <span class="uc-proof__byname">{proof.data.champion}{proofRole ? `, ${proofRole}` : ''}</span>
              <a class="link" href={localizedHref(L, `/customerstories/${proof.slug}`)}>{c.storyPre}{proof.data.company}{c.storyPost}</a>
            </span>
          </div>
        </aside>
      )}
      {stripQuotes.length > 0 && (
        <div class="uc-strip">
          <TestimonialStrip quotes={stripQuotes} heading={c.stripHeading} />
        </div>
      )}
    </div>
  </section>
)}

{/* CTA */}
<section class="sec sec--navy uc-ctawrap">
  <div class="wrap">
    <div class="uc-cta">
      <h2 class="heading_secondary">{ctaHeading}</h2>
      <p class="uc-cta__text">{ctaText}</p>
      <div class="uc-cta-row uc-cta-row--center">
        <a class="button is-large" href={localizedHref(L, SIGNUP_URL)}>{c.ctaPrimary}</a>
        <a class="button is-large is-secondary" href={localizedHref(L, DEMO_URL)}>{c.ctaSecondary}</a>
      </div>
    </div>
  </div>
</section>

{/* RELATED */}
{related.length > 0 && (
  <section class="sec sec--paper uc-relwrap">
    <div class="wrap">
      <aside class="uc-related">
        <p class="eyebrow is-accent">{c.relatedLabel}</p>
        <div class="uc-related__grid">
          {related.map((u: any) => (
            <a class="uc-card" href={localizedHref(L, `/use-cases/${u.slug}`)}>
              <h3 class="uc-card__title">{u.data.label || u.data.title}</h3>
              {u.data.description && <p class="uc-card__desc">{u.data.description}</p>}
              <span class="uc-card__more">{c.explore}</span>
            </a>
          ))}
        </div>
      </aside>
    </div>
  </section>
)}

<style>
  /* Hero */
  .uc-hero { padding-bottom: clamp(30px,4vw,48px); }
  .uc-back { display:inline-block; margin-bottom:18px; font-size:14px; }
  .uc-title { font-family:var(--font-head); font-weight:600; font-size:clamp(2rem,4.2vw,2.6rem); line-height:1.12; letter-spacing:-.02em; color:var(--sec-tx); margin:8px 0 0; max-width:18ch; }
  .uc-sub { margin-top:16px; max-width:60ch; }
  .uc-cta-row { display:flex; gap:12px; flex-wrap:wrap; margin-top:24px; }
  .uc-cta-row--center { justify-content:center; }

  /* Product visual band */
  .uc-visual { padding-top: clamp(30px,4vw,48px); }
  .uc-visual__cap { font-family:var(--font-head); font-weight:500; font-size:clamp(1.05rem,2.2vw,1.4rem); line-height:1.3; letter-spacing:-.01em; color:var(--sec-tx); text-align:center; max-width:32ch; margin:0 auto clamp(24px,3vw,36px); }
  .uc-visual__frame { display:flex; justify-content:center; }

  /* Body */
  .uc-bodywrap { padding-top: clamp(34px,5vw,60px); }
  .uc-meta { display:flex; gap:48px; flex-wrap:wrap; margin:0 0 4px; padding:0 0 24px; border-bottom:1px solid var(--sec-bd); }
  .uc-meta__head { font-family:var(--font-body); font-weight:500; font-size:12px; text-transform:uppercase; letter-spacing:.08em; color:var(--sec-tx); opacity:.55; margin:0 0 11px; }
  .uc-taglist { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:8px; }
  .uc-taglist li { position:relative; padding-left:20px; font-family:var(--font-body); font-size:15px; line-height:1.4; color:var(--sec-tx); }
  .uc-taglist li::before { content:""; position:absolute; left:0; top:.5em; width:7px; height:7px; border-radius:50%; background:var(--accent-on); }

  .uc-body { max-width:720px; margin-top:30px; }
  .uc-body :global(h2) { font-family:var(--font-head); font-weight:600; font-size:1.5rem; line-height:1.2; letter-spacing:-.01em; color:var(--sec-tx); margin:36px 0 12px; }
  .uc-body :global(h2:first-child) { margin-top:0; }
  .uc-body :global(h3) { font-family:var(--font-head); font-weight:600; font-size:1.2rem; line-height:1.25; color:var(--sec-tx); margin:26px 0 10px; }
  .uc-body :global(p) { font-family:var(--font-body); font-size:1.0625rem; line-height:1.7; color:var(--sec-tx); margin:0 0 1.1em; }
  .uc-body :global(strong) { font-weight:600; color:var(--sec-tx); }
  .uc-body :global(ul) { margin:0 0 1.2em; padding-left:0; list-style:none; }
  .uc-body :global(li) { position:relative; padding-left:22px; margin:0 0 .6em; font-family:var(--font-body); font-size:1.0625rem; line-height:1.6; color:var(--sec-tx); }
  .uc-body :global(li)::before { content:""; position:absolute; left:2px; top:.62em; width:7px; height:7px; border-radius:50%; background:var(--accent-on); }
  .uc-body :global(a) { color:var(--accent-on); font-weight:500; text-decoration:none; border-bottom:1px solid transparent; transition:border-color .15s; }
  .uc-body :global(a):hover { border-bottom-color:var(--accent-on); }

  /* Proof (white card on the sand band) */
  .uc-proof { max-width:760px; margin:0 auto; padding:26px 28px; background:var(--sec-card); border:1px solid var(--sec-bd); border-left:3px solid var(--accent-on); border-radius:var(--radius-lg); }
  .uc-proof__quote { font-family:var(--font-body); font-weight:500; font-size:1.2rem; line-height:1.5; color:var(--sec-tx); margin:10px 0 18px; }
  .uc-proof__metrics { display:flex; gap:30px; flex-wrap:wrap; margin-bottom:16px; }
  .uc-proof__num { font-family:var(--font-head); font-weight:600; font-size:1.5rem; color:var(--accent-on); margin:0; }
  .uc-proof__lab { font-family:var(--font-body); font-size:13px; line-height:1.35; color:var(--sec-tx); opacity:.72; margin:4px 0 0; max-width:18ch; }
  .uc-proof__by { display:flex; align-items:center; gap:12px; margin:0; }
  .uc-proof__bymeta { display:flex; flex-direction:column; gap:2px; }
  .uc-proof__byname { font-family:var(--font-body); font-weight:600; font-size:14px; color:var(--sec-tx); }
  .uc-proof__by .link { font-size:13.5px; }
  .uc-strip { margin-top: clamp(28px,4vw,44px); }

  /* CTA (centered on the navy band) */
  .uc-cta { max-width:760px; margin:0 auto; text-align:center; }
  .uc-cta .heading_secondary { color:var(--sec-tx); }
  .uc-cta__text { font-family:var(--font-body); font-size:1.0625rem; line-height:1.6; color:var(--sec-tx); opacity:.82; max-width:54ch; margin:12px auto 0; }
  .uc-cta .uc-cta-row { margin-top:26px; }

  /* Related */
  .uc-related__grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:18px; margin-top:16px; }
  .uc-card { display:flex; flex-direction:column; background:var(--sec-card); border:1px solid var(--sec-bd); border-radius:var(--radius-lg); padding:24px; color:var(--sec-tx); text-decoration:none; transition:border-color .15s, transform .05s; }
  .uc-card:hover { border-color:color-mix(in srgb,var(--accent-on) 55%,var(--sec-bd)); }
  .uc-card:active { transform:translateY(1px); }
  .uc-card__title { font-family:var(--font-head); font-weight:600; font-size:1.15rem; line-height:1.25; color:var(--sec-tx); margin:0 0 10px; }
  .uc-card__desc { font-family:var(--font-body); font-size:14px; line-height:1.55; color:var(--sec-tx); opacity:.74; margin:0 0 16px; }
  .uc-card__more { margin-top:auto; font-family:var(--font-body); font-weight:500; font-size:14px; color:var(--accent-on); }
</style>
