---
// Section 7 — From sign-up to meeting set, in three steps (Espresso).
// Each step is a centered text block followed by its full-width product embed.
// The embeds (sourcing, multichannel flow, CRM sync) are the real hubsell UI:
// white cards popping on the dark section, green connective motion.
import { pipelineSteps } from '../data/home-content';
import { SIGNUP_URL } from '../data/site';
import SocialProspecting from './SocialProspecting.astro';
import MultichannelFlow from './MultichannelFlow.astro';
import CrmSyncTracker from './CrmSyncTracker.astro';

const EMBEDS: Record<string, any> = {
  '05-sp-widget': SocialProspecting,
  '06-multichannel-flow': MultichannelFlow,
  '07-crm-sync-tracker': CrmSyncTracker,
};
---
<section class="sec sec--esp" aria-labelledby="steps-title">
  <div class="wrap">
    <div class="sec-head is-center reveal">
      <p class="eyebrow">The three-step pipeline motion</p>
      <h2 id="steps-title" class="heading_primary" style="margin-top:8px">From <span class="accent">sign-up to meeting</span> set in three steps.</h2>
    </div>

    <div class="steps">
      {pipelineSteps.map((step) => {
        const Embed = EMBEDS[step.embed];
        return (
          <div class="step reveal">
            <div class="step__head">
              <p class="step__eyebrow">{step.label}</p>
              <h3 class="heading_secondary" style="margin-top:10px">{step.title}<span class="accent">{step.titleAccent}</span>{step.tail}</h3>
              <div class="step__points">
                {step.points.map((p) => <p class="paragraph" style="opacity:.84;margin:0">{p}</p>)}
              </div>
            </div>
            <div class="step__media">
              {Embed && <Embed />}
            </div>
            <a href={SIGNUP_URL} class="button is-secondary">{step.cta}</a>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .steps{ display:flex; flex-direction:column; gap:clamp(64px,9vw,112px); margin-top:clamp(36px,5vw,60px) }
  .step{ display:flex; flex-direction:column; align-items:center; text-align:center }
  .step__head{ max-width:60ch }
  .step__eyebrow{ font-family:var(--font-body); font-weight:600; font-size:13px; letter-spacing:.04em; text-transform:uppercase; color:var(--accent-on) }
  .step__points{ display:flex; flex-direction:column; gap:10px; margin-top:16px; max-width:62ch; margin-left:auto; margin-right:auto }
  .step__media{ width:100%; display:flex; justify-content:center; margin:clamp(28px,4vw,44px) 0 clamp(24px,3vw,32px) }
</style>
