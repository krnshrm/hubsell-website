---
// ============================= LEARNING NOTES =============================
// Page for the URL /faqs . THIN-SHELL PATTERN (see src/pages/contact.astro
// for the annotated exemplar): the page file only assembles imports, page
// meta and structured data, then hands rendering to a body component.
// Copy and data come from getFaqs() from src/data/faqs-i18n,
// looked up by locale so the same body serves en/de/nl.
// Body component(s): src/components/FaqsBody.astro.
// JsonLd emits schema.org structured data for search engines (breadcrumbs
// and similar); see src/data/seo.ts for the schema builders.
// ==========================================================================
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import FaqsBody from '../components/FaqsBody.astro';
import { getFaqs } from '../data/faqs-i18n';

const stripHtml = (s: string) => s.replace(/<[^>]+>/g, '').trim();
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: getFaqs('en').map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: stripHtml(f.answer) },
  })),
};
---
<BaseLayout
  title="Frequently asked questions | hubsell"
  description="Answers to the questions teams ask before switching to hubsell: live data sourcing, deliverability, LinkedIn outreach, CRM sync, GDPR, pricing, and more."
>
  <JsonLd slot="head" schema={faqSchema} />
  <FaqsBody />
</BaseLayout>
