---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import { faqs } from '../data/faqs';
import { SIGNUP_URL, DEMO_URL } from '../data/site';

// FAQPage structured data — every Q&A on this page, answers as plain text. Lets
// Google show FAQ rich results and lets AI answer engines quote hubsell
// directly. Kept on this page only (not the homepage subset) to avoid duplicate
// FAQ markup across URLs.
const stripHtml = (s: string) => s.replace(/<[^>]+>/g, '').trim();
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: stripHtml(f.answer) },
  })),
};
---
<BaseLayout
  title="Frequently asked questions | hubsell"
  description="Answers to the questions teams ask before switching to hubsell: live data sourcing, deliverability, LinkedIn outreach, CRM sync, GDPR, pricing, and more."
>
  <JsonLd slot="head" schema={faqSchema} />
  <section class="sec sec--paper" aria-labelledby="faqs-title">
    <div class="wrap" style="max-width:820px">
      <div class="sec-head">
        <p class="eyebrow is-accent">FAQ</p>
        <h1 id="faqs-title" class="heading_primary" style="margin-top:8px">Questions, answered.</h1>
        <p class="subheading" style="margin-top:14px">Everything teams ask before switching to hubsell. Still stuck? <a href={DEMO_URL} class="link">Book a 20-minute demo</a>.</p>
      </div>

      <div class="acc" data-accordion style="margin-top:30px">
        {faqs.map((f, idx) => (
          <div class={`acc__item${idx === 0 ? ' is-open' : ''}`} id={f.slug}>
            <h2 style="margin:0">
              <button class="acc__btn" type="button" aria-expanded={idx === 0 ? 'true' : 'false'}>
                {f.question}
              </button>
            </h2>
            <div class="acc__panel" style={idx === 0 ? 'max-height:600px' : ''} set:html={f.answer}></div>
          </div>
        ))}
      </div>

      <div class="faqs-cta">
        <p class="faqs-cta__title">Still weighing it up?</p>
        <p class="faqs-cta__text">Put hubsell on your own ICP and see the data and the outreach flow on real accounts.</p>
        <div class="faqs-cta__row">
          <a class="button is-large" href={SIGNUP_URL}>Start free trial</a>
          <a class="button is-large is-secondary" href={DEMO_URL}>Book a demo</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .faqs-cta{
    margin-top:clamp(40px,6vw,60px); padding-top:clamp(32px,4vw,44px);
    border-top:1px solid var(--sec-bd); text-align:center;
  }
  .faqs-cta__title{ font-family:var(--font-head); font-weight:600; font-size:clamp(1.4rem,2.6vw,1.8rem); letter-spacing:-.02em; color:var(--sec-tx); margin:0; }
  .faqs-cta__text{ font-family:var(--font-body); font-size:1.0625rem; line-height:1.6; color:var(--sec-tx); opacity:.78; max-width:50ch; margin:10px auto 22px; }
  .faqs-cta__row{ display:flex; flex-wrap:wrap; gap:12px; justify-content:center; }
</style>

<script>
  function initFaqAccordion() {
    document.querySelectorAll<HTMLElement>('[data-accordion]').forEach((acc) => {
      if (acc.dataset.ready) return;
      acc.dataset.ready = '1';
      acc.querySelectorAll<HTMLElement>('.acc__item').forEach((item) => {
        const btn = item.querySelector<HTMLButtonElement>('.acc__btn')!;
        const panel = item.querySelector<HTMLElement>('.acc__panel')!;
        // size any initially-open panel to its content
        if (item.classList.contains('is-open')) panel.style.maxHeight = panel.scrollHeight + 'px';
        btn.addEventListener('click', () => {
          const open = item.classList.toggle('is-open');
          btn.setAttribute('aria-expanded', String(open));
          panel.style.maxHeight = open ? panel.scrollHeight + 'px' : '';
        });
      });
    });
  }
  initFaqAccordion();
  document.addEventListener('astro:page-load', initFaqAccordion);
</script>
