---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import ReviewsBody from '../components/ReviewsBody.astro';
import { TESTIMONIALS } from '../data/testimonials';
import { getReviewsPage } from '../i18n/pages';
import { SITE_URL, breadcrumbSchema } from '../data/seo';

const c = getReviewsPage('en');

// Real customer testimonials marked up as Review objects so AI answer engines can
// cite what customers say. No invented star ratings: quotes carry no numeric score,
// and the per-platform scores (RatingsStrip) link out to their sources.
const reviewsSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'hubsell',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  url: SITE_URL,
  review: TESTIMONIALS.map((t) => ({
    '@type': 'Review',
    author: {
      '@type': 'Person',
      name: t.name,
      ...(t.company ? { worksFor: { '@type': 'Organization', name: t.company } } : {}),
    },
    reviewBody: t.quote,
  })),
};
const reviewCrumbs = breadcrumbSchema([
  { name: c.crumbHome, url: '/' },
  { name: c.crumbReviews, url: '/hubsell-reviews' },
]);
---
<BaseLayout title={c.metaTitle} description={c.metaDescription}>
  <JsonLd slot="head" schema={[reviewsSchema, reviewCrumbs]} />
  <ReviewsBody />
</BaseLayout>
