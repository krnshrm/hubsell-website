---
// ============================= LEARNING NOTES =============================
// Page for the URL /pricing . THIN-SHELL PATTERN (see src/pages/contact.astro
// for the annotated exemplar): the page file only assembles imports, page
// meta and structured data, then hands rendering to a body component.
// Copy and data come from getPricingPage() from src/data/pricing-page,
// looked up by locale so the same body serves en/de/nl.
// Body component(s): src/components/PricingPage.astro.
// JsonLd emits schema.org structured data for search engines (breadcrumbs
// and similar); see src/data/seo.ts for the schema builders.
// ==========================================================================
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import PricingPage from '../components/PricingPage.astro';
import { breadcrumbSchema } from '../data/seo';
import { getPricingPage } from '../data/pricing-page';
import { asLocale, localizeUrl } from '../i18n/utils';

const L = asLocale(Astro.currentLocale);
const d = getPricingPage(L);
const crumbs = breadcrumbSchema([
  { name: d.crumbHome, url: localizeUrl(L, '/') },
  { name: d.crumbSelf, url: localizeUrl(L, '/pricing') },
]);
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: d.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={d.title} description={d.metaDescription}>
  <JsonLd slot="head" schema={[crumbs, faqSchema]} />
  <PricingPage L={L} data={d} />
</BaseLayout>
