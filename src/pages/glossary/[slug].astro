---
// ============================= LEARNING NOTES =============================
// DYNAMIC ROUTE: this one file builds every page under /glossary/<slug> ,
// one per entry in the 'glossary' content collection (schema in
// src/content.config.ts). getStaticPaths() returns the list of pages to
// create; the pattern is explained line by line at the top of
// src/pages/insights/[slug].astro, which is the exemplar to study first.
// Body component(s): src/components/GlossaryTerm.astro.
// JsonLd emits schema.org structured data for search engines (breadcrumbs
// and similar); see src/data/seo.ts for the schema builders.
// ==========================================================================
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import GlossaryTerm from '../../components/GlossaryTerm.astro';
import { getCollection } from 'astro:content';
import { breadcrumbSchema, definedTermSchema } from '../../data/seo';
import { glossaryChrome } from '../../data/glossary-i18n';
import { asLocale, localizeUrl } from '../../i18n/utils';

export async function getStaticPaths() {
  const entries = await getCollection('glossary', (e) => !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const L = asLocale(Astro.currentLocale);
const c = glossaryChrome(L);
const url = localizeUrl(L, `/glossary/${entry.id}`);
const term = definedTermSchema({ name: entry.data.term, description: entry.data.definition, url });
const crumbs = breadcrumbSchema([
  { name: c.crumbHome, url: localizeUrl(L, '/') },
  { name: c.crumbGlossary, url: localizeUrl(L, '/glossary') },
  { name: entry.data.term, url },
]);
const title = `${entry.data.term} | ${c.crumbGlossary} | hubsell`;
---
<BaseLayout title={title} description={entry.data.definition}>
  <JsonLd slot="head" schema={term} />
  <JsonLd slot="head" schema={crumbs} />
  <GlossaryTerm L={L} entry={entry} />
</BaseLayout>
