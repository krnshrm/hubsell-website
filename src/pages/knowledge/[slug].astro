---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { SITE_URL, breadcrumbSchema } from '../../data/seo';

export async function getStaticPaths() {
  const articles = await getCollection('knowledge', (a) => !a.data.draft);
  return articles.map((article) => ({ params: { slug: article.id }, props: { article } }));
}

const { article } = Astro.props;
const {
  title, description, category, series, seriesStep, seriesTotal,
  estMinutes, stepCount, walkthroughUrl, updated, faqs, next,
} = article.data;

const articleUrl = `${SITE_URL}/knowledge/${article.id}`;

// A readable "Last updated" string, e.g. "18 July 2026".
const updatedLabel = updated
  ? updated.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;

// Article + breadcrumb structured data (rich results + AI answers).
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description,
  articleSection: category,
  ...(updated ? { dateModified: updated.toISOString().slice(0, 10) } : {}),
  author: { '@type': 'Organization', name: 'hubsell', url: SITE_URL },
  publisher: {
    '@type': 'Organization',
    name: 'hubsell',
    logo: { '@type': 'ImageObject', url: 'https://assets.hubsell.com/logo/hubsell-favicon.svg' },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
};
// FAQPage structured data, emitted only when the article carries FAQs. The same
// questions are rendered visibly below, so the markup matches the page (required
// for FAQ rich results).
const faqSchema = faqs.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
const crumbs = breadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Knowledge', url: '/knowledge' },
  { name: category, url: '/knowledge' },
  { name: title, url: `/knowledge/${article.id}` },
]);

// Series progress: build the segment list once, marking the current step.
const segs = series && seriesTotal
  ? Array.from({ length: seriesTotal }, (_, i) => i + 1 === seriesStep)
  : [];
---
<BaseLayout title={`${title} | hubsell Knowledge center`} description={description}>
  <JsonLd schema={articleSchema} />
  <JsonLd schema={crumbs} />
  {faqSchema && <JsonLd schema={faqSchema} />}

  <section class="sec sec--paper">
    <article class="kb-wrap">

      <nav class="kb-crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">/</span>
        <a href="/knowledge">Knowledge</a><span class="sep">/</span>
        <a href="/knowledge">{category}</a><span class="sep">/</span>
        <span class="here">{title}</span>
      </nav>

      <p class="kb-eyebrow">{category}</p>
      <h1 class="kb-title">{title}</h1>
      {description && <p class="kb-summary">{description}</p>}

      <div class="kb-meta">
        {estMinutes && (
          <span class="pip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>About {estMinutes} min</span>
        )}
        {stepCount && <><span class="mid">·</span><span class="pip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>{stepCount} steps</span></>}
        {series && seriesStep && seriesTotal && (
          <><span class="mid">·</span><span class="pip">{series} · Step {seriesStep} of {seriesTotal}</span></>
        )}
        {updatedLabel && <><span class="mid">·</span><span class="pip">Last updated {updatedLabel}</span></>}
      </div>

      {segs.length > 0 && (
        <div class="kb-series" aria-label={`Series progress, step ${seriesStep} of ${seriesTotal}`}>
          <span class="kb-series__track">
            {segs.map((isCurrent, i) => (
              <span class={`kb-series__seg${i + 1 < (seriesStep ?? 0) ? ' is-done' : ''}${isCurrent ? ' is-current' : ''}`}></span>
            ))}
          </span>
        </div>
      )}

      <div class="kb-body" set:html={article.body}></div>

      {walkthroughUrl && (
        <div class="kb-walk" id="kb-walk" data-url={walkthroughUrl}>
          <div class="kb-walk__head">
            <span class="kb-walk__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg></span>
            <div>
              <p class="kb-walk__t">Interactive walkthrough</p>
              <p class="kb-walk__d">Click through every step at your own pace.</p>
            </div>
            <span class="kb-walk__btn"><button class="kb-button" type="button" id="kb-walk-start">Start walkthrough</button></span>
          </div>
          <p class="kb-walk__note">The walkthrough loads from Scribe only after you click, so nothing third party runs on the page until then.</p>
        </div>
      )}

      {faqs.length > 0 && (
        <section class="kb-faq" aria-label="Common questions">
          <h2 class="kb-faq__h">Common questions</h2>
          {faqs.map((f) => (
            <details class="kb-faq__item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </section>
      )}

      {next && (
        <div class="kb-next">
          <a href={next.href}>
            <div>
              <p class="lbl">Next in this series</p>
              <p class="nt">{next.label}</p>
            </div>
            <span class="arw"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
          </a>
        </div>
      )}

    </article>
  </section>
</BaseLayout>

<script>
  // Click-to-load Scribe walkthrough: no third-party request until the reader asks.
  const host = document.getElementById('kb-walk');
  const start = document.getElementById('kb-walk-start');
  if (host && start) {
    start.addEventListener('click', () => {
      const url = host.getAttribute('data-url');
      const frame = document.createElement('iframe');
      frame.className = 'kb-walk__frame';
      frame.src = url;
      frame.loading = 'lazy';
      frame.allowFullscreen = true;
      frame.title = document.title + ', interactive walkthrough';
      const note = host.querySelector('.kb-walk__note');
      host.insertBefore(frame, note);
      note.innerHTML = 'If the walkthrough does not appear, <a href="' + url + '" target="_blank" rel="noopener">open it in a new tab</a>.';
      start.closest('.kb-walk__btn').remove();
    });
  }
</script>

<style is:global>
  /* Knowledge center article styles. Global (not scoped) because the article body
     is injected with set:html and would not receive Astro's scoped class hashes. */
  :root { --kb-card:#FFFFFF; }
  [data-theme="dark"] { --kb-card:#211B15; }

  .kb-wrap{max-width:820px;margin:0 auto;padding:0 clamp(20px,5vw,56px)}

  .kb-crumbs{display:flex;flex-wrap:wrap;align-items:center;gap:8px;font-size:13px;color:var(--text-3);margin:0 0 26px}
  .kb-crumbs a{text-decoration:none;color:var(--text-3)}
  .kb-crumbs a:hover{color:var(--accent-on)}
  .kb-crumbs .sep{opacity:.5}
  .kb-crumbs .here{color:var(--text-2)}

  .kb-eyebrow{font-family:var(--font-body);font-weight:500;font-size:.8125rem;text-transform:uppercase;letter-spacing:.08em;color:var(--accent-on);margin:0 0 12px}
  .kb-title{font-family:var(--font-head);font-weight:600;font-size:clamp(2rem,4vw,2.5rem);line-height:1.12;letter-spacing:-.02em;color:var(--text);margin:0 0 16px}
  .kb-summary{font-family:var(--font-body);font-weight:400;font-size:1.125rem;line-height:1.6;color:var(--text-2);margin:0 0 22px;max-width:60ch}

  .kb-meta{display:flex;flex-wrap:wrap;gap:8px;align-items:center;font-size:13px;color:var(--text-3);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:14px 0;margin:0}
  .kb-meta .pip{display:inline-flex;align-items:center;gap:7px}
  .kb-meta .pip svg{width:14px;height:14px;opacity:.7}
  .kb-meta .mid{opacity:.4}

  .kb-series{margin:26px 0 6px}
  .kb-series__track{display:flex;gap:5px}
  .kb-series__seg{height:5px;border-radius:999px;background:var(--border);flex:1}
  .kb-series__seg.is-done{background:var(--accent-on)}
  .kb-series__seg.is-current{background:var(--accent-on);opacity:.5}

  .kb-callout{background:var(--kb-card);border:1px solid var(--border);border-left:3px solid var(--positive);border-radius:var(--radius-lg);padding:18px 22px;margin:30px 0}
  .kb-callout--tip{border-left-color:var(--accent-on)}
  .kb-callout--warn{border-left-color:var(--amber)}
  .kb-callout p{margin:0;font-size:15px;line-height:1.6;color:var(--text-2)}
  .kb-callout b{color:var(--text);font-weight:600}
  .kb-callout ul{margin:10px 0 0;padding-left:20px}
  .kb-callout li{font-size:15px;line-height:1.6;color:var(--text-2);margin:0 0 6px}
  .kb-callout li:last-child{margin-bottom:0}
  .kb-callout__h{font-family:var(--font-head);font-weight:600;font-size:.95rem;color:var(--text);margin:0 0 8px}

  .kb-sub{font-family:var(--font-head);font-weight:600;font-size:1.15rem;color:var(--text);margin:44px 0 6px}
  .kb-body>p{font-size:1rem;line-height:1.65;color:var(--text);margin:14px 0 0}
  .kb-body>p a,.kb-callout a,.kb-steps a{color:var(--accent-on);text-decoration:none;border-bottom:1px solid transparent;transition:border-color .15s}
  .kb-body>p a:hover,.kb-callout a:hover,.kb-steps a:hover{border-bottom-color:var(--accent-on)}

  .kb-steps{list-style:none;counter-reset:step;margin:18px 0 0;padding:0}
  .kb-steps>li{counter-increment:step;position:relative;padding:0 0 26px 52px;margin:0}
  .kb-steps>li::before{content:counter(step);position:absolute;left:0;top:-2px;width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--font-head);font-weight:600;font-size:15px;color:var(--accent-on);background:color-mix(in srgb,var(--accent-on) 12%,transparent);border:1px solid color-mix(in srgb,var(--accent-on) 32%,transparent)}
  .kb-steps>li:not(:last-child)::after{content:"";position:absolute;left:17px;top:34px;bottom:2px;width:1px;background:var(--border)}
  .kb-steps>li>p{font-size:1rem;line-height:1.6;color:var(--text);margin:5px 0 0}
  .kb-steps>li>p b{font-weight:600}
  .kb-kbd{font-family:var(--font-head);font-weight:500;font-size:.9em;color:var(--text);background:color-mix(in srgb,var(--text) 7%,transparent);border:1px solid var(--border);border-radius:6px;padding:1px 7px}

  .kb-figure{margin:16px 0 4px;border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;background:var(--kb-card)}
  .kb-figure img{width:100%;display:block}
  .kb-figure figcaption{font-size:12.5px;color:var(--text-3);padding:10px 16px;border-top:1px solid var(--border)}
  .kb-figure.is-missing img{display:none}
  .kb-figure.is-missing::before{content:attr(data-ph);display:flex;align-items:center;justify-content:center;text-align:center;min-height:180px;padding:24px;color:var(--text-3);font-size:13px;line-height:1.5;background:repeating-linear-gradient(45deg,transparent,transparent 10px,color-mix(in srgb,var(--text) 3%,transparent) 10px,color-mix(in srgb,var(--text) 3%,transparent) 20px)}

  .kb-result{display:flex;gap:12px;align-items:flex-start;background:var(--positive-soft);border:1px solid color-mix(in srgb,var(--positive) 30%,transparent);border-radius:var(--radius-lg);padding:18px 20px;margin:30px 0}
  [data-theme="dark"] .kb-result{background:color-mix(in srgb,var(--positive) 14%,transparent)}
  .kb-result svg{flex:none;width:20px;height:20px;color:var(--positive-ink);margin-top:1px}
  [data-theme="dark"] .kb-result svg{color:var(--positive)}
  .kb-result p{margin:0;font-size:15px;line-height:1.55;color:var(--text)}
  .kb-result b{font-weight:600}

  .kb-walk{margin:36px 0 8px;border:1px solid var(--border);border-radius:var(--radius-lg);background:var(--kb-card);overflow:hidden}
  .kb-walk__head{display:flex;align-items:center;gap:14px;padding:20px 22px}
  .kb-walk__ic{flex:none;width:42px;height:42px;border-radius:10px;background:color-mix(in srgb,var(--accent-on) 12%,transparent);display:flex;align-items:center;justify-content:center;color:var(--accent-on)}
  .kb-walk__ic svg{width:22px;height:22px}
  .kb-walk__t{font-family:var(--font-head);font-weight:600;font-size:1rem;color:var(--text);margin:0}
  .kb-walk__d{font-size:13px;color:var(--text-3);margin:2px 0 0}
  .kb-walk__btn{margin-left:auto;flex:none}
  .kb-walk__frame{border-top:1px solid var(--border);aspect-ratio:16/10;width:100%;border:0;display:block}
  .kb-walk__note{font-size:12px;color:var(--text-3);padding:10px 22px;border-top:1px solid var(--border)}
  .kb-walk__note a{color:var(--accent-on)}

  .kb-button{font-family:var(--font-body);font-weight:500;font-size:.9375rem;line-height:1;cursor:pointer;display:inline-flex;align-items:center;gap:8px;padding:11px 18px;border-radius:var(--radius);border:1px solid transparent;background:var(--accent-on);color:#FBF4EA;text-decoration:none;transition:filter .15s}
  .kb-button:hover{filter:brightness(.93)}

  .kb-faq{border-top:1px solid var(--border);margin-top:44px;padding-top:28px}
  .kb-faq__h{font-family:var(--font-head);font-weight:600;font-size:1.15rem;color:var(--text);margin:0 0 14px}
  .kb-faq__item{border:1px solid var(--border);border-radius:var(--radius);background:var(--kb-card);margin:0 0 10px;overflow:hidden}
  .kb-faq__item summary{cursor:pointer;list-style:none;padding:15px 18px;font-family:var(--font-head);font-weight:500;font-size:.98rem;color:var(--text);display:flex;align-items:center;justify-content:space-between;gap:12px}
  .kb-faq__item summary::-webkit-details-marker{display:none}
  .kb-faq__item summary::after{content:"+";font-family:var(--font-head);font-weight:500;font-size:1.2rem;color:var(--accent-on);line-height:1}
  .kb-faq__item[open] summary::after{content:"\2013"}
  .kb-faq__item p{margin:0;padding:0 18px 16px;font-size:15px;line-height:1.6;color:var(--text-2)}

  .kb-toc{background:var(--kb-card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px 20px;margin:26px 0}
  .kb-toc p{font-size:12px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3);margin:0 0 8px}
  .kb-toc ul{list-style:none;margin:0;padding:0;display:flex;flex-wrap:wrap;gap:8px 20px}
  .kb-toc a{font-size:14px;color:var(--accent-on);text-decoration:none}
  .kb-toc a:hover{text-decoration:underline}

  .kb-next{margin-top:22px}
  .kb-next a{display:flex;align-items:center;gap:14px;text-decoration:none;background:var(--kb-card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:18px 20px;transition:border-color .15s}
  .kb-next a:hover{border-color:var(--accent-on)}
  .kb-next .lbl{font-size:12px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3);margin:0 0 3px}
  .kb-next .nt{font-family:var(--font-head);font-weight:600;font-size:1.05rem;color:var(--text);margin:0}
  .kb-next .arw{margin-left:auto;color:var(--accent-on)}
</style>
