---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { SITE_URL, breadcrumbSchema } from '../../data/seo';

// All non-draft articles, grouped by category. Within a category we sort by the
// `order` field, then title, so the onboarding path reads top to bottom.
const articles = await getCollection('knowledge', (a) => !a.data.draft);

// Category display order. Anything not listed here falls to the end, alphabetically.
const CATEGORY_ORDER = [
  'Getting started', 'Data', 'Campaigns', 'Integrations', 'Deliverability', 'Account and billing',
];
const rank = (c) => {
  const i = CATEGORY_ORDER.indexOf(c);
  return i === -1 ? CATEGORY_ORDER.length : i;
};

const byCategory = new Map();
for (const a of articles) {
  const list = byCategory.get(a.data.category) ?? [];
  list.push(a);
  byCategory.set(a.data.category, list);
}
const groups = [...byCategory.entries()]
  .sort((a, b) => rank(a[0]) - rank(b[0]) || a[0].localeCompare(b[0]))
  .map(([category, list]) => ({
    category,
    articles: list.sort((x, y) => (x.data.order - y.data.order) || x.data.title.localeCompare(y.data.title)),
  }));

const crumbs = breadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Knowledge', url: '/knowledge' },
]);
---
<BaseLayout
  title="Knowledge center | hubsell"
  description="Guides and step-by-step help for getting started with hubsell: set up your account, connect your channels, source data, and launch your first campaign."
>
  <JsonLd schema={crumbs} />

  <section class="sec sec--paper" aria-labelledby="kb-title">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow is-accent">Knowledge center</p>
        <h1 id="kb-title" class="heading_primary" style="margin-top:8px">Get up and running with hubsell</h1>
        <p class="subheading">Step-by-step help for setting up your account, connecting your channels, sourcing data, and launching your first campaign.</p>
      </div>

      <div class="kbhub__search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="search" id="kbSearch" placeholder="Search the knowledge center" aria-label="Search the knowledge center" autocomplete="off" />
      </div>
      <p class="kbhub__empty" id="kbEmpty" hidden>No articles match that search yet.</p>

      <div class="kbhub">
        {groups.map((group) => (
          <section class="kbhub__group" aria-label={group.category}>
            <h2 class="kbhub__cat">{group.category}</h2>
            <ul class="kbhub__list">
              {group.articles.map((a) => (
                <li class="kbhub__item" data-search={`${a.data.title} ${a.data.description ?? ''} ${a.data.category}`.toLowerCase()}>
                  <a class="kbhub__card" href={`/knowledge/${a.id}`}>
                    <div class="kbhub__txt">
                      <p class="kbhub__t">{a.data.title}</p>
                      {a.data.description && <p class="kbhub__d">{a.data.description}</p>}
                      <p class="kbhub__meta">
                        {a.data.series && a.data.seriesStep && a.data.seriesTotal
                          ? `Step ${a.data.seriesStep} of ${a.data.seriesTotal}` : a.data.category}
                        {a.data.estMinutes ? ` · ${a.data.estMinutes} min` : ''}
                      </p>
                    </div>
                    <span class="kbhub__arw"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Client-side filter for the knowledge hub. In-memory only, no storage.
  const input = document.getElementById('kbSearch');
  const empty = document.getElementById('kbEmpty');
  if (input) {
    const items = Array.from(document.querySelectorAll('.kbhub__item'));
    const groups = Array.from(document.querySelectorAll('.kbhub__group'));
    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      items.forEach((li) => {
        const hit = !q || (li.getAttribute('data-search') || '').includes(q);
        li.hidden = !hit;
      });
      let anyVisible = false;
      groups.forEach((g) => {
        const visible = g.querySelectorAll('.kbhub__item:not([hidden])').length > 0;
        g.hidden = !visible;
        if (visible) anyVisible = true;
      });
      empty.hidden = anyVisible;
    });
  }
</script>

<style is:global>
  :root { --kb-card:#FFFFFF; }
  [data-theme="dark"] { --kb-card:#211B15; }

  .kbhub{display:flex;flex-direction:column;gap:44px;margin-top:28px}

  .kbhub__search{display:flex;align-items:center;gap:10px;margin-top:32px;background:var(--kb-card);border:1px solid var(--border);border-radius:var(--radius);padding:0 14px;max-width:440px}
  .kbhub__search:focus-within{border-color:var(--accent-on);box-shadow:0 0 0 3px color-mix(in srgb,var(--accent-on) 20%,transparent)}
  .kbhub__search svg{width:17px;height:17px;color:var(--text-3);flex:none}
  .kbhub__search input{flex:1;border:0;background:transparent;color:var(--text);font-family:var(--font-body);font-size:.95rem;padding:12px 0;outline:none}
  .kbhub__search input::placeholder{color:var(--text-3)}
  .kbhub__empty{margin:20px 0 0;color:var(--text-2);font-size:15px}
  .kbhub__group[hidden]{display:none}
  .kbhub__item[hidden]{display:none}
  .kbhub__cat{font-family:var(--font-head);font-weight:600;font-size:1.15rem;color:var(--text);margin:0 0 16px;padding-bottom:10px;border-bottom:1px solid var(--border)}
  .kbhub__list{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:14px}
  .kbhub__card{display:flex;align-items:center;gap:14px;text-decoration:none;background:var(--kb-card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px 22px;height:100%;transition:border-color .15s,transform .05s}
  .kbhub__card:hover{border-color:var(--accent-on)}
  .kbhub__t{font-family:var(--font-head);font-weight:600;font-size:1.02rem;color:var(--text);margin:0 0 6px;line-height:1.3}
  .kbhub__d{font-size:14px;line-height:1.55;color:var(--text-2);margin:0 0 10px}
  .kbhub__meta{font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:var(--text-3);margin:0}
  .kbhub__arw{flex:none;color:var(--accent-on);opacity:0;transform:translateX(-4px);transition:opacity .15s,transform .15s}
  .kbhub__card:hover .kbhub__arw{opacity:1;transform:translateX(0)}
</style>
