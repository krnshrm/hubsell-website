---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SIGNUP_URL } from '../data/site';
---
<BaseLayout
  title="Page not found | hubsell"
  description="The page you were looking for isn't here."
  noindex={true}
>
  <section class="sec sec--paper nf">
    <div class="wrap nf__inner">
      <p class="nf__code">404</p>
      <h1 class="nf__title">We couldn't find that page.</h1>
      <p class="nf__text">The link might be broken, or the page may have moved. Here are some good places to pick back up.</p>

      <div class="nf__links">
        <a href="/">Home</a>
        <a href="/insights">Insights</a>
        <a href="/comparisons">Comparisons</a>
        <a href="/customerstories">Customer stories</a>
        <a href="/faqs">FAQ</a>
        <a href="/pricing">Pricing</a>
      </div>

      <div class="nf__cta">
        <a class="button is-large" href={SIGNUP_URL}>Book a demo</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf{ display:flex; align-items:center; min-height:min(72vh,640px); text-align:center; }
  .nf__inner{ max-width:620px; }
  .nf__code{
    font-family:var(--font-head); font-weight:600; font-size:clamp(4rem,12vw,7rem);
    line-height:1; letter-spacing:-.04em; color:var(--accent-on); margin:0;
  }
  .nf__title{
    font-family:var(--font-head); font-weight:600; font-size:clamp(1.6rem,4vw,2.4rem);
    letter-spacing:-.02em; color:var(--sec-tx); margin:14px 0 0;
  }
  .nf__text{
    font-family:var(--font-body); font-size:1.0625rem; line-height:1.6;
    color:var(--sec-tx); opacity:.78; max-width:48ch; margin:14px auto 0;
  }
  .nf__links{ display:flex; flex-wrap:wrap; gap:8px 22px; justify-content:center; margin:26px 0 0; }
  .nf__links a{
    font-family:var(--font-body); font-weight:500; font-size:15px; color:var(--accent-on);
    text-decoration:none; border-bottom:1px solid transparent; transition:border-color .15s;
  }
  .nf__links a:hover{ border-bottom-color:var(--accent-on); }
  .nf__cta{ display:flex; flex-wrap:wrap; gap:12px; justify-content:center; margin:30px 0 0; }
</style>
