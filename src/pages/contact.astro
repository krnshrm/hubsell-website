---
// ============================= LEARNING NOTES =============================
// The simplest page shape in the repo: import the layout, import one body
// component, pass title and description as PROPS (component attributes),
// done. /contact gets its URL from the filename. The real page lives in
// src/components/ContactBody.astro; splitting it out lets the German and
// Dutch pages (src/pages/de/contact.astro, src/pages/nl/contact.astro) reuse
// the exact same body while it translates itself via Astro.currentLocale.
// ==========================================================================
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactBody from '../components/ContactBody.astro';
---
<BaseLayout
  title="Contact | hubsell"
  description="Get in touch with hubsell. Questions about the platform, your account, partnerships, or press. Send a note and the right person will get back to you."
>
  <ContactBody />
</BaseLayout>
