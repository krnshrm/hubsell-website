---
// ============================= LEARNING NOTES =============================
// A DYNAMIC ROUTE, the most important page pattern to learn. The [slug] in
// the filename is a placeholder: this ONE file generates all 87 blog post
// pages, /insights/<slug> each. Two pieces make that work:
//
// 1. getStaticPaths() below. At build time Astro calls it and expects back a
//    list of { params, props }: one entry per page to create. `params.slug`
//    fills the [slug] placeholder (the URL); `props` is data handed to that
//    page's render. Here it loads the whole 'insights' content collection
//    (see src/content.config.ts), drops drafts, sorts, and returns one entry
//    per post, passing the post AND the full list (for related-post picks).
//
// 2. The rest of the frontmatter then runs ONCE PER PAGE with that entry's
//    props. `const { post, posts } = Astro.props` receives them.
//
// `async`/`await`: getCollection reads files from disk, which JavaScript
// treats as an operation you must wait for; `await` pauses until the result
// is ready and `async` marks the function as allowed to await.
//
// Everything else in this frontmatter is ordinary data shaping in plain
// JavaScript: .filter() keeps matching items, .map() transforms each item,
// .sort() orders them, Set/Map deduplicate. It is worth reading slowly; this
// is what "real" page logic usually looks like: gather, rank, slice.
// ==========================================================================
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import WaitlistForm from '../../components/WaitlistForm.astro';
import { SITE_URL, breadcrumbSchema } from '../../data/seo';
import { SIGNUP_URL } from '../../data/site';

export async function getStaticPaths() {
  const posts = (await getCollection('insights', (p) => !p.data.draft)).sort((a, b) => (a.id < b.id ? -1 : a.id > b.id ? 1 : 0));
  return posts.map((post) => ({ params: { slug: post.id }, props: { post, posts } }));
}

const { post, posts } = Astro.props;
const { title, description, coverImage, thumbnail, sources, readTime, summary, cta, publishedAt, topics } = post.data;

// post.body is the raw Webflow HTML (already image- and link-rewritten by the
// converter). If a post had an empty body in the export, fall back to its summary
// so the page is not blank.
const bodyHtml = post.body && post.body.trim() ? post.body : summary ? `<p>${summary}</p>` : '';
const heroImage = coverImage || thumbnail;

// Two related posts: prefer ones that share a topic with this post (and have an
// image), then fall back to the previous image-preferred rotation so every post
// still gets two picks.
const cardImg = (p) => p.data.thumbnail || p.data.coverImage;
const myTopics = new Set(post.data.topics || []);
const others = posts.filter((p) => p.id !== post.id);
const sharedCount = (p) => (p.data.topics || []).filter((t) => myTopics.has(t)).length;
const byTopic = others
  .filter((p) => sharedCount(p) > 0)
  .sort((a, b) => (sharedCount(b) - sharedCount(a)) || ((cardImg(b) ? 1 : 0) - (cardImg(a) ? 1 : 0)));
const withImg = others.filter((p) => cardImg(p));
const pool = withImg.length >= 2 ? withImg : others;
const off = pool.length ? [...post.id].reduce((a, c) => a + c.charCodeAt(0), 0) % pool.length : 0;
const rotation = pool.length ? [pool[off], pool[(off + 1) % pool.length]] : [];
const related = [...new Map([...byTopic, ...rotation].filter(Boolean).map((p) => [p.id, p])).values()].slice(0, 2);

// A few relevant hubsell pages for this post's topics. Kept in the template as
// internal links to product pages, so the migrated post body stays untouched.
// LEARNING: a plain object used as a lookup table, topic name -> list of
// internal links. Data-as-object beats a chain of if/else and is a pattern
// you will see across src/data/.
const HUB_LINKS = {
  'Outbound sales': [{ label: 'Outbound sales', href: '/use-cases/outbound-sales' }],
  'Cold email': [{ label: 'Multichannel outreach', href: '/platform/multichannel-outreach' }, { label: 'Deliverability', href: '/platform/deliverability' }],
  'Email deliverability': [{ label: 'Deliverability', href: '/platform/deliverability' }, { label: 'Inbox placement', href: '/glossary/inbox-placement' }],
  'Prospect data': [{ label: 'Live-sourced data', href: '/platform/live-data' }],
  'Data enrichment': [{ label: 'Data enrichment', href: '/platform/enrichment' }],
  'LinkedIn': [{ label: 'Multichannel outreach', href: '/platform/multichannel-outreach' }],
  'Lead generation': [{ label: 'Lead generation', href: '/use-cases/lead-generation' }],
  'Multichannel outreach': [{ label: 'Multichannel outreach', href: '/platform/multichannel-outreach' }, { label: 'Multichannel use case', href: '/use-cases/multichannel-outreach' }],
  'Sales operations': [{ label: 'CRM sync', href: '/platform/crm-sync' }, { label: 'What is RevOps', href: '/glossary/revops' }],
  'Personalization': [{ label: 'Personalization', href: '/platform/personalization' }],
  'Industry guides': [{ label: 'Account-based outreach', href: '/use-cases/account-based-outreach' }],
  'Sales skills': [],
};
const hubSeen = new Set();
const hubLinksAll = [];
for (const t of (post.data.topics || [])) {
  for (const l of (HUB_LINKS[t] || [])) {
    if (!hubSeen.has(l.href)) { hubSeen.add(l.href); hubLinksAll.push(l); }
  }
}
const hubLinks = hubLinksAll.slice(0, 3);

// Trial CTA copy: a per-post override (frontmatter `cta`) if set, otherwise a
// default that references this post by title so it never reads as generic.
const ctaText = cta || `You just read "${title}". hubsell gives you the verified contact data, multichannel outreach, and CRM sync to act on it. Book a demo and see it run on your own pipeline.`;

// Article + breadcrumb structured data for this post (rich results + AI answers).
const postUrl = `${SITE_URL}/insights/${post.id}`;
// LEARNING: structured data (schema.org) built as a JavaScript object and
// rendered by <JsonLd> in the template. The three-dot `...` is the SPREAD
// operator: `...(coverImage ? { image: [coverImage] } : {})` merges in the
// image field only when a cover image exists, otherwise merges nothing.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  ...(coverImage ? { image: [coverImage] } : {}),
  ...(publishedAt ? { datePublished: publishedAt.toISOString().slice(0, 10) } : {}),
  author: { '@type': 'Organization', name: 'hubsell', url: SITE_URL },
  publisher: {
    '@type': 'Organization',
    name: 'hubsell',
    logo: { '@type': 'ImageObject', url: 'https://assets.hubsell.com/logo/hubsell-favicon.svg' },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
};
const articleCrumbs = breadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Insights', url: '/insights' },
  { name: title, url: `/insights/${post.id}` },
]);
---
<BaseLayout title={`${title} | hubsell`} description={description} ogImage={coverImage} ogType="article">
{/* LEARNING: template for every post. Three things to study here:
    1. <link slot="head"> loads the serif blog font only on posts.
    2. set:html={bodyHtml} injects a string AS RAW HTML. Astro normally
       escapes {values} so injected text cannot run code; set:html turns
       that protection off, so only use it with content YOU control (here:
       the migrated post bodies from our own repo).
    3. {related.map(...)} renders a card per related post; a .map() that
       returns markup is THE loop pattern in Astro templates. */}
  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap"
  />
  <JsonLd slot="head" schema={[articleSchema, articleCrumbs]} />

  <article class="sec sec--paper post-page">
    <div class="wrap">
      <a class="post-page__back link" href="/insights">&larr; All insights</a>

      <div class="post-page__grid">
        <div class="post-page__main">
          <header class="post-page__head">
            <p class="eyebrow is-accent">B2B sales</p>
            <h1 class="post-page__title">{title}</h1>
            {readTime && <p class="post-page__meta">{readTime}</p>}
          </header>

          {heroImage && (
            <img class="post-page__cover" src={heroImage} alt={title} width="1200" height="675" />
          )}

          <div class="prose" set:html={bodyHtml} />

          {sources && (
            <aside class="post-sources">
              <p class="eyebrow">Sources</p>
              <div class="post-sources__body" set:html={sources} />
            </aside>
          )}
        </div>

        <aside class="post-page__aside">
          <div class="post-aside-card">
            <p class="post-aside-card__title">Get the next one in your inbox</p>
            <p class="post-aside-card__text">New posts on outbound, deliverability, and B2B data. No noise, unsubscribe anytime.</p>
            <WaitlistForm
              form="newsletter"
              buttonLabel="Subscribe"
              placeholder="Your email"
              help=""
            />
          </div>
        </aside>
      </div>

      {related.length > 0 && (
        <aside class="post-related">
          <p class="eyebrow is-accent">Keep reading</p>
          <div class="post-related__grid">
            {related.map((p) => (
              <a class="post" href={`/insights/${p.id}`}>
                {cardImg(p) && (
                  <img class="post__img" src={cardImg(p)} alt={p.data.title} loading="lazy" width="400" height="225" />
                )}
                <div class="post__body">
                  <p class="eyebrow is-accent" style="font-size:.72rem">{(p.data.topics && p.data.topics[0]) || 'B2B sales'}</p>
                  <h3 class="post__title">{p.data.title}</h3>
                  {p.data.readTime && <p class="post__meta">{p.data.readTime}</p>}
                </div>
              </a>
            ))}
          </div>
        </aside>
      )}

      {hubLinks.length > 0 && (
        <aside class="post-hub">
          <p class="eyebrow is-accent">Related on hubsell</p>
          <ul class="post-hub__list">
            {hubLinks.map((l) => (
              <li><a class="link" href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </aside>
      )}

      <aside class="post-cta sec--navy">
        <h2 class="post-cta__title">Put this into practice</h2>
        <p class="post-cta__text">{ctaText}</p>
        <a class="button is-large" href={SIGNUP_URL}>Book a demo</a>
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .post-page__back { display:inline-block; font-size:14px; margin-bottom:28px; }

  /* Article sits left; the freed right-hand space holds a sticky subscribe card. */
  .post-page__grid { display:grid; grid-template-columns: minmax(0, 680px) 1fr; gap:56px; align-items:stretch; }
  .post-page__main { min-width:0; }

  .post-page__head { margin:0 0 28px; }
  .post-page__title {
    font-family:var(--font-head); font-weight:600;
    font-size:clamp(1.9rem,4vw,2.75rem); line-height:1.12; letter-spacing:-.02em;
    color:var(--sec-tx); margin:10px 0 0;
  }
  .post-page__meta { font-family:var(--font-body); font-size:14px; color:var(--sec-tx); opacity:.6; margin:12px 0 0; }
  .post-page__cover {
    display:block; width:100%; max-width:100%; margin:0 0 8px;
    height:auto; border-radius:var(--radius-lg);
    border:1px solid var(--sec-bd); background:color-mix(in srgb,var(--sec-tx) 6%,transparent);
  }

  /* Sticky subscribe card in the right column. */
  .post-aside-card {
    position:sticky; top:92px;
    background:var(--sec-card); border:1px solid var(--sec-bd); border-radius:var(--radius-lg); padding:24px;
  }
  .post-aside-card__title { font-family:var(--font-head); font-weight:600; font-size:1.15rem; line-height:1.3; color:var(--sec-tx); margin:0 0 8px; }
  .post-aside-card__text { font-family:var(--font-body); font-size:14px; line-height:1.55; color:var(--sec-tx); opacity:.72; margin:0 0 16px; }
  .post-aside-card .button { width:100%; justify-content:center; }

  /* Reading column: serif body (Newsreader), brand headings (Lexend). */
  .prose {
    max-width:none; margin:32px 0 0;
    font-family:'Newsreader', Georgia, 'Times New Roman', serif;
    font-size:1.1875rem; line-height:1.75; color:var(--sec-tx);
  }
  .prose > :first-child { margin-top:0; }
  .prose :is(h2,h3,h4,h5,h6) {
    font-family:var(--font-head); font-weight:600; color:var(--sec-tx);
    line-height:1.2; letter-spacing:-.01em;
  }
  .prose h2 { font-size:1.6rem; margin:1.7em 0 .5em; }
  .prose h3 { font-size:1.3rem; margin:1.5em 0 .45em; }
  .prose h4 { font-size:1.1rem; margin:1.4em 0 .4em; }
  .prose h5, .prose h6 { font-size:1rem; margin:1.3em 0 .35em; }
  .prose p { margin:0 0 1.1em; }
  .prose a { color:var(--accent-on); text-decoration:none; border-bottom:1px solid transparent; transition:border-color .15s; overflow-wrap:anywhere; }
  .prose a:hover { border-bottom-color:var(--accent-on); }
  .prose strong { font-weight:600; }
  .prose em { font-style:italic; }
  .prose ul, .prose ol { margin:0 0 1.1em; padding-left:1.3em; }
  .prose li { margin:0 0 .5em; }
  .prose li::marker { color:var(--accent-on); }
  .prose blockquote {
    margin:1.5em 0; padding:.2em 0 .2em 1.1em;
    border-left:3px solid var(--accent-on); font-weight:500; color:var(--sec-tx);
  }
  .prose img { max-width:100%; height:auto; border-radius:var(--radius); margin:1.4em 0; display:block; }
  .prose figure { margin:1.6em 0; }
  .prose figure img { margin:0 auto; }
  .prose figcaption { font-family:var(--font-body); font-size:13px; color:var(--sec-tx); opacity:.6; text-align:center; margin-top:8px; }
  .prose iframe { width:100%; aspect-ratio:16/9; height:auto; border:0; border-radius:var(--radius-lg); margin:1.6em 0; }
  .prose hr { border:0; border-top:1px solid var(--sec-bd); margin:2em 0; }
  .prose code { font-family:ui-monospace,SFMono-Regular,Menlo,monospace; font-size:.9em; background:color-mix(in srgb,var(--sec-tx) 8%,transparent); padding:.1em .35em; border-radius:5px; }
  .prose pre { background:color-mix(in srgb,var(--sec-tx) 8%,transparent); padding:16px 18px; border-radius:var(--radius); overflow:auto; margin:1.4em 0; }
  .prose pre code { background:none; padding:0; }

  .post-sources { max-width:none; margin:40px 0 0; padding-top:20px; border-top:1px solid var(--sec-bd); }
  .post-sources__body { font-family:var(--font-body); font-size:13.5px; line-height:1.6; color:var(--sec-tx); opacity:.7; }
  .post-sources__body p { margin:0 0 .5em; }
  .post-sources__body a { color:var(--accent-on); text-decoration:none; overflow-wrap:anywhere; }
  .post-sources__body a:hover { text-decoration:underline; }

  /* Full-width blocks below the article. */
  .post-related { margin:56px 0 0; }
  .post-related__grid { display:grid; grid-template-columns:repeat(2,1fr); gap:20px; margin-top:16px; }
  .post-related .post__meta { font-family:var(--font-body); font-size:12.5px; color:var(--sec-tx); opacity:.55; margin:10px 0 0; }
  .post-hub { margin:40px 0 0; }
  .post-hub__list { list-style:none; padding:0; margin:12px 0 0; display:flex; flex-wrap:wrap; gap:10px 22px; }
  .post-hub__list a { font-weight:500; }

  .post-cta {
    margin:48px 0 0; padding:clamp(28px,4vw,44px);
    border-radius:var(--radius-lg); text-align:center;
    background:var(--sec-bg); color:var(--sec-tx); border:1px solid var(--sec-bd);
  }
  .post-cta__title { font-family:var(--font-head); font-weight:600; font-size:clamp(1.5rem,3vw,2rem); letter-spacing:-.02em; color:var(--sec-tx); margin:0; }
  .post-cta__text { font-family:var(--font-body); font-size:1.0625rem; line-height:1.6; color:var(--sec-tx); opacity:.82; max-width:52ch; margin:12px auto 22px; }

  @media (max-width: 980px){
    .post-page__grid { grid-template-columns:1fr; gap:40px; }
    .post-aside-card { position:static; }
  }
  @media (max-width: 600px){
    .prose { font-size:1.0625rem; }
    .post-related__grid { grid-template-columns:1fr; }
  }
</style>
