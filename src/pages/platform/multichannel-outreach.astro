---
// ============================= LEARNING NOTES =============================
// Page for the URL /platform/multichannel-outreach . THIN-SHELL PATTERN (see src/pages/contact.astro
// for the annotated exemplar): the page file only assembles imports, page
// meta and structured data, then hands rendering to a body component.
// Copy and data come from getPlatformDetail() from src/data/platform-i18n,
// looked up by locale so the same body serves en/de/nl.
// Body component(s): src/components/PlatformDetail.astro.
// JsonLd emits schema.org structured data for search engines (breadcrumbs
// and similar); see src/data/seo.ts for the schema builders.
// ==========================================================================
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import PlatformDetail from '../../components/PlatformDetail.astro';
import { breadcrumbSchema } from '../../data/seo';
import { getPlatformDetail } from '../../data/platform-i18n';
import { asLocale, localizeUrl } from '../../i18n/utils';

const L = asLocale(Astro.currentLocale);
const d = getPlatformDetail(L, '/platform/multichannel-outreach');
const crumbs = breadcrumbSchema([
  { name: 'Home', url: localizeUrl(L, '/') },
  { name: 'Platform', url: localizeUrl(L, '/platform') },
  { name: d.eyebrow, url: localizeUrl(L, '/platform/multichannel-outreach') },
]);
---
<BaseLayout title={d.title} description={d.metaDescription}>
  <JsonLd slot="head" schema={crumbs} />
  <PlatformDetail L={L} data={d} />
</BaseLayout>
