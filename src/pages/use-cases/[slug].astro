---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import UseCaseDetail from '../../components/UseCaseDetail.astro';
import JsonLd from '../../components/JsonLd.astro';
import { breadcrumbSchema } from '../../data/seo';
import { asLocale, localizeUrl } from '../../i18n/utils';

export async function getStaticPaths() {
  const items = await getCollection('usecases', (u) => !u.data.draft);
  return items.map((entry) => ({ params: { slug: entry.slug }, props: { entry, items } }));
}
const { entry, items } = Astro.props;
const d = entry.data;
const metaTitle = d.metaTitle ? `${d.metaTitle} | hubsell` : `${d.title} | hubsell`;
const L = asLocale(Astro.currentLocale);
const crumbs = breadcrumbSchema([
  { name: 'Home', url: localizeUrl(L, '/') },
  { name: 'Use cases', url: localizeUrl(L, '/use-cases') },
  { name: d.title, url: localizeUrl(L, `/use-cases/${entry.slug}`) },
]);
---
<BaseLayout title={metaTitle} description={d.description}>
  <JsonLd slot="head" schema={crumbs} />
  <UseCaseDetail entry={entry} items={items} />
</BaseLayout>
