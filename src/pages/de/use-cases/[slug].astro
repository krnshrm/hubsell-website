---
// ============================= LEARNING NOTES =============================
// German copy of src/pages/use-cases/[slug].astro, serving the URL /de/use-cases/[slug] .
// LOCALE PAGE PATTERN: see the full explanation at the top of
// src/pages/de/index.astro. In short: same components as the English page,
// import paths one level deeper, translated meta text; the components
// translate themselves because Astro.currentLocale is 'de' under /de/.
// ==========================================================================
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import UseCaseDetail from '../../../components/UseCaseDetail.astro';
import JsonLd from '../../../components/JsonLd.astro';
import { breadcrumbSchema } from '../../../data/seo';
import { asLocale, localizeUrl } from '../../../i18n/utils';

export async function getStaticPaths() {
  const items = await getCollection('usecasesDe', (u) => !u.data.draft);
  return items.map((entry) => ({ params: { slug: entry.id }, props: { entry, items } }));
}
const { entry, items } = Astro.props;
const d = entry.data;
const metaTitle = d.metaTitle ? `${d.metaTitle} | hubsell` : `${d.title} | hubsell`;
const L = asLocale(Astro.currentLocale);
const crumbs = breadcrumbSchema([
  { name: 'Startseite', url: localizeUrl(L, '/') },
  { name: 'Anwendungsfälle', url: localizeUrl(L, '/use-cases') },
  { name: d.title, url: localizeUrl(L, `/use-cases/${entry.id}`) },
]);
---
<BaseLayout title={metaTitle} description={d.description}>
  <JsonLd slot="head" schema={crumbs} />
  <UseCaseDetail entry={entry} items={items} />
</BaseLayout>
