---
// ============================= LEARNING NOTES =============================
// German copy of src/pages/glossary/index.astro, serving the URL /de/glossary/ .
// LOCALE PAGE PATTERN: see the full explanation at the top of
// src/pages/de/index.astro. In short: same components as the English page,
// import paths one level deeper, translated meta text; the components
// translate themselves because Astro.currentLocale is 'de' under /de/.
// ==========================================================================
import BaseLayout from '../../../layouts/BaseLayout.astro';
import JsonLd from '../../../components/JsonLd.astro';
import GlossaryIndex from '../../../components/GlossaryIndex.astro';
import { getCollection } from 'astro:content';
import { breadcrumbSchema, definedTermSetSchema } from '../../../data/seo';
import { glossaryChrome } from '../../../data/glossary-i18n';
import { asLocale, localizeUrl } from '../../../i18n/utils';

const L = asLocale(Astro.currentLocale);
const c = glossaryChrome(L);
const entries0 = await getCollection('glossaryDe', (e) => !e.data.draft);
const entries = entries0.sort((a, b) => (a.id < b.id ? -1 : a.id > b.id ? 1 : 0));
const termSet = definedTermSetSchema(entries.map((e) => ({
  name: e.data.term, description: e.data.definition, url: localizeUrl(L, `/glossary/${e.id}`),
})));
const crumbs = breadcrumbSchema([
  { name: c.crumbHome, url: localizeUrl(L, '/') },
  { name: c.crumbGlossary, url: localizeUrl(L, '/glossary') },
]);
const title = L === 'de' ? 'Glossar f\u00fcr B2B-Vertrieb und Daten | hubsell'
  : L === 'nl' ? 'Woordenlijst voor B2B-sales en data | hubsell'
  : 'B2B sales and data glossary | hubsell';
---
<BaseLayout title={title} description={c.intro}>
  <JsonLd slot="head" schema={termSet} />
  <JsonLd slot="head" schema={crumbs} />
  <GlossaryIndex L={L} />
</BaseLayout>
