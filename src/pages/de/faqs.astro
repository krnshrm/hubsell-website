---
// ============================= LEARNING NOTES =============================
// German copy of src/pages/faqs.astro, serving the URL /de/faqs .
// LOCALE PAGE PATTERN: see the full explanation at the top of
// src/pages/de/index.astro. In short: same components as the English page,
// import paths one level deeper, translated meta text; the components
// translate themselves because Astro.currentLocale is 'de' under /de/.
// ==========================================================================
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import FaqsBody from '../../components/FaqsBody.astro';
import { getFaqs } from '../../data/faqs-i18n';
import { getFaqsPage } from '../../i18n/pages';

const c = getFaqsPage('de');
const stripHtml = (s: string) => s.replace(/<[^>]+>/g, '').trim();
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: getFaqs('de').map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: stripHtml(f.answer) },
  })),
};
---
<BaseLayout title={c.metaTitle} description={c.metaDescription}>
  <JsonLd slot="head" schema={faqSchema} />
  <FaqsBody />
</BaseLayout>
