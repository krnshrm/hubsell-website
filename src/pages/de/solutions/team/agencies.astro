---
// ============================= LEARNING NOTES =============================
// German copy of src/pages/solutions/team/agencies.astro, serving the URL /de/solutions/team/agencies .
// LOCALE PAGE PATTERN: see the full explanation at the top of
// src/pages/de/index.astro. In short: same components as the English page,
// import paths one level deeper, translated meta text; the components
// translate themselves because Astro.currentLocale is 'de' under /de/.
// ==========================================================================
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import JsonLd from '../../../../components/JsonLd.astro';
import SolutionDetail from '../../../../components/SolutionDetail.astro';
import { breadcrumbSchema } from '../../../../data/seo';
import { getSolutionDetail } from '../../../../data/solutions-i18n';
import { asLocale, localizeUrl } from '../../../../i18n/utils';

const L = asLocale(Astro.currentLocale);
const d = getSolutionDetail(L, '/solutions/team/agencies');
const crumbs = breadcrumbSchema([
  { name: 'Startseite', url: localizeUrl(L, '/') },
  { name: 'Lösungen', url: localizeUrl(L, '/solutions') },
  { name: d.eyebrow, url: localizeUrl(L, '/solutions/team/agencies') },
]);
---
<BaseLayout title={d.title} description={d.metaDescription}>
  <JsonLd slot="head" schema={crumbs} />
  <SolutionDetail L={L} data={d} />
</BaseLayout>
