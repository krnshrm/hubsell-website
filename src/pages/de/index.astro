---
// ============================= LEARNING NOTES =============================
// THE LOCALE PAGE PATTERN, explained once here for every file under
// src/pages/de/ and src/pages/nl/. Because routing is file-based, a file at
// src/pages/de/index.astro creates the URL /de/. The trick: it imports THE
// SAME components as the English page. Inside each component,
// `Astro.currentLocale` reports 'de' (Astro derives it from the /de/ URL
// prefix configured in astro.config.mjs), and the component looks up its
// German strings in the src/data/*-i18n.ts dictionaries. So a locale page is
// mostly a copy of the English page file with:
//   1. import paths one folder deeper (../../ instead of ../), and
//   2. its own translated <BaseLayout title description> meta text.
// Pages NOT copied into de/ still get a /de/ URL from the i18n fallback in
// astro.config.mjs, but that stub just redirects to English.
// ==========================================================================
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { softwareApplicationSchema } from '../../data/seo';
import Hero from '../../components/Hero.astro';
import CustomerLogos from '../../components/CustomerLogos.astro';
import Comparison from '../../components/Comparison.astro';
import FragmentedStack from '../../components/FragmentedStack.astro';
import ZeroDaySourcing from '../../components/ZeroDaySourcing.astro';
import RatingsStrip from '../../components/RatingsStrip.astro';
import PipelineSteps from '../../components/PipelineSteps.astro';
import Pricing from '../../components/Pricing.astro';
// import UseCases from '../../components/UseCases.astro';  // hidden until its pages ship
// import Features from '../../components/Features.astro';  // hidden until its pages ship
import Testimonials from '../../components/Testimonials.astro';
// import PublishTrackBeta from '../../components/PublishTrackBeta.astro';  // hidden until its pages ship
import Faq from '../../components/Faq.astro';
import Insights from '../../components/Insights.astro';

// German homepage. Same section rhythm as the English home; each section reads
// Astro.currentLocale (='de' from the /de/ path) and renders its German copy via
// src/data/home-i18n.ts. The pricing table and the animated product embeds still
// render English until PR 2b.
---
<BaseLayout title="hubsell | Live recherchierte Daten, E-Mail- und LinkedIn-Outreach, eine Plattform" description="hubsell recherchiert B2B-Kontakte live, betreibt E-Mail und LinkedIn in einem Ablauf und synchronisiert Ihr CRM automatisch. Eine Plattform, die Ihren Outbound-Stack ersetzt.">
  <JsonLd slot="head" schema={softwareApplicationSchema} />
  {/*  1 */}<Hero />
  {/*  2 */}<CustomerLogos />
  {/*  3 */}<Comparison />
  {/*  4 */}<FragmentedStack />
  {/*  5 */}<ZeroDaySourcing />
  {/*  6 */}<RatingsStrip />
  {/*  7 */}<PipelineSteps />
  {/*  8 */}<Pricing />
  {/*  9 <UseCases /> hidden until its pages ship */}
  {/* 10 <Features /> hidden until its pages ship */}
  {/* 11 */}<Testimonials />
  {/* 12 <PublishTrackBeta /> hidden until its pages ship */}
  {/* 13 */}<Faq />
  {/* 14 */}<Insights />
</BaseLayout>
