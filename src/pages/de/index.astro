import Insights from '../../components/Insights.astro';

// German homepage. Same section rhythm as the English home; each section reads
// Astro.currentLocale (='de' from the /de/ path) and renders its German copy via
// src/data/home-i18n.ts. The pricing table and the animated product embeds still
// render English until PR 2b.
---
<BaseLayout title="hubsell | Live recherchierte Daten, E-Mail- und LinkedIn-Outreach, eine Plattform" description="hubsell recherchiert B2B-Kontakte live, betreibt E-Mail und LinkedIn in einem Ablauf und synchronisiert Ihr CRM automatisch. Eine Plattform, die Ihren Outbound-Stack ersetzt.">
  <JsonLd slot="head" schema={softwareApplicationSchema} />
  {/*  1 */}<Hero />
  {/*  2 */}<CustomerLogos />
  {/*  3 */}<Comparison />
  {/*  4 */}<FragmentedStack />
  {/*  5 */}<ZeroDaySourcing />
  {/*  6 */}<RatingsStrip />
  {/*  7 */}<PipelineSteps />
  {/*  8 */}<Pricing />
  {/*  9 */}<UseCases />
  {/* 10 */}<Features />
  {/* 11 */}<Testimonials />
  {/* 12 */}<PublishTrackBeta />
  {/* 13 */}<Faq />
  {/* 14 */}<Insights />
</BaseLayout>
