---
// ============================= LEARNING NOTES =============================
// Dutch copy of src/pages/contact.astro, serving the URL /nl/contact .
// LOCALE PAGE PATTERN: see the full explanation at the top of
// src/pages/de/index.astro. In short: same components as the English page,
// import paths one level deeper, translated meta text; the components
// translate themselves because Astro.currentLocale is 'nl' under /nl/.
// ==========================================================================
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactBody from '../../components/ContactBody.astro';
import { getContact } from '../../i18n/pages';
const c = getContact('nl');
---
<BaseLayout title={c.metaTitle} description={c.metaDescription}>
  <ContactBody />
</BaseLayout>
