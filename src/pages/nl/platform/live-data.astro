---
// ============================= LEARNING NOTES =============================
// Dutch copy of src/pages/platform/live-data.astro, serving the URL /nl/platform/live-data .
// LOCALE PAGE PATTERN: see the full explanation at the top of
// src/pages/de/index.astro. In short: same components as the English page,
// import paths one level deeper, translated meta text; the components
// translate themselves because Astro.currentLocale is 'nl' under /nl/.
// ==========================================================================
import BaseLayout from '../../../layouts/BaseLayout.astro';
import JsonLd from '../../../components/JsonLd.astro';
import PlatformDetail from '../../../components/PlatformDetail.astro';
import { breadcrumbSchema } from '../../../data/seo';
import { getPlatformDetail } from '../../../data/platform-i18n';
import { asLocale, localizeUrl } from '../../../i18n/utils';

const L = asLocale(Astro.currentLocale);
const d = getPlatformDetail(L, '/platform/live-data');
const crumbs = breadcrumbSchema([
  { name: 'Home', url: localizeUrl(L, '/') },
  { name: 'Platform', url: localizeUrl(L, '/platform') },
  { name: d.eyebrow, url: localizeUrl(L, '/platform/live-data') },
]);
---
<BaseLayout title={d.title} description={d.metaDescription}>
  <JsonLd slot="head" schema={crumbs} />
  <PlatformDetail L={L} data={d} />
</BaseLayout>
