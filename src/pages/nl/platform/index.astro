---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import JsonLd from '../../../components/JsonLd.astro';
import PlatformOverviewBody from '../../../components/PlatformOverviewBody.astro';
import { breadcrumbSchema } from '../../../data/seo';
import { getPlatformOverview } from '../../../data/platform-i18n';
import { asLocale, localizeUrl } from '../../../i18n/utils';

const L = asLocale(Astro.currentLocale);
const d = getPlatformOverview(L);
const crumbs = breadcrumbSchema([
  { name: 'Home', url: localizeUrl(L, '/') },
  { name: 'Platform', url: localizeUrl(L, '/platform') },
]);
---
<BaseLayout title={d.title} description={d.metaDescription}>
  <JsonLd slot="head" schema={crumbs} />
  <PlatformOverviewBody L={L} data={d} />
</BaseLayout>
