---
// ============================= LEARNING NOTES =============================
// THE HOMEPAGE. FILE-BASED ROUTING is Astro's core idea: the file path under
// src/pages/ IS the URL. index.astro = "/", pricing.astro = "/pricing",
// insights/[slug].astro = "/insights/<anything>" (see that file for dynamic
// routes). Nothing to configure; create a file, get a page.
//
// Notice how thin this file is: the homepage is just a stack of section
// COMPONENTS. Each import at the top brings in one .astro component, and the
// template below simply lists them in order inside <BaseLayout>. All copy,
// markup and styling live inside the components, which keeps this file a
// readable table of contents for the page. To reorder the homepage you
// reorder the tags; to hide a section you comment its tag out (see the
// UseCases lines for exactly that).
// ==========================================================================
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import { softwareApplicationSchema } from '../data/seo';
import Hero from '../components/Hero.astro';
import CustomerLogos from '../components/CustomerLogos.astro';
import Comparison from '../components/Comparison.astro';
import FragmentedStack from '../components/FragmentedStack.astro';
import ZeroDaySourcing from '../components/ZeroDaySourcing.astro';
import RatingsStrip from '../components/RatingsStrip.astro';
import PipelineSteps from '../components/PipelineSteps.astro';
import Pricing from '../components/Pricing.astro';
// import UseCases from '../components/UseCases.astro';  // hidden until its pages ship
// import Features from '../components/Features.astro';  // hidden until its pages ship
import Testimonials from '../components/Testimonials.astro';
// import PublishTrackBeta from '../components/PublishTrackBeta.astro';  // hidden until its pages ship
import Faq from '../components/Faq.astro';
import Insights from '../components/Insights.astro';

// Home page — full section rhythm. Colors alternate so a dark lands early and
// navy/espresso never repeat back to back. Book a demo is the CTA
// throughout; the old waitlist section has been removed.
---
<BaseLayout title="hubsell | Live-Sourced Data, Email and LinkedIn Outreach, One Platform" description="hubsell sources B2B contacts live, runs email and LinkedIn from one flow, and syncs your CRM automatically. One platform to replace your outbound stack.">
  <JsonLd slot="head" schema={softwareApplicationSchema} />
  {/* LEARNING: JsonLd renders a <script type="application/ld+json"> block of
      structured data for search engines. slot="head" sends it into
      BaseLayout's named head slot so it lands inside <head>, not the body. */}
  {/*  1 */}<Hero />
  {/*  2 */}<CustomerLogos />
  {/*  3 */}<Comparison />
  {/*  4 */}<FragmentedStack />
  {/*  5 */}<ZeroDaySourcing />
  {/*  6 */}<RatingsStrip />
  {/*  7 */}<PipelineSteps />
  {/*  8 */}<Pricing />
  {/*  9 <UseCases /> hidden until its pages ship */}
  {/* 10 <Features /> hidden until its pages ship */}
  {/* 11 */}<Testimonials />
  {/* 12 <PublishTrackBeta /> hidden until its pages ship */}
  {/* 13 */}<Faq />
  {/* 14 */}<Insights />
</BaseLayout>
