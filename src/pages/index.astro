---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CustomerLogos from '../components/CustomerLogos.astro';
import FragmentedStack from '../components/FragmentedStack.astro';
import ZeroDaySourcing from '../components/ZeroDaySourcing.astro';
import RatingsStrip from '../components/RatingsStrip.astro';
import PipelineSteps from '../components/PipelineSteps.astro';
import Pricing from '../components/Pricing.astro';
import UseCases from '../components/UseCases.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import PublishTrackBeta from '../components/PublishTrackBeta.astro';
import Faq from '../components/Faq.astro';
import Insights from '../components/Insights.astro';

// Home page — full section rhythm. Colors alternate so a dark lands early and
// navy/espresso never repeat back to back. Sign-up (free trial) is the CTA
// throughout; the old waitlist section has been removed.
---
<BaseLayout>
  {/*  1 */}<Hero />
  {/*  2 */}<CustomerLogos />
  {/*  3 */}<FragmentedStack />
  {/*  4 */}<ZeroDaySourcing />
  {/*  5 */}<RatingsStrip />
  {/*  6 */}<PipelineSteps />
  {/*  7 */}<Pricing />
  {/*  8 */}<UseCases />
  {/*  9 */}<Features />
  {/* 10 */}<Testimonials />
  {/* 11 */}<PublishTrackBeta />
  {/* 12 */}<Faq />
  {/* 13 */}<Insights />
</BaseLayout>
