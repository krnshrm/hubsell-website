---
// ============================= LEARNING NOTES =============================
// Page for the URL /solutions/team/agencies . THIN-SHELL PATTERN (see src/pages/contact.astro
// for the annotated exemplar): the page file only assembles imports, page
// meta and structured data, then hands rendering to a body component.
// Copy and data come from getSolutionDetail() from src/data/solutions-i18n,
// looked up by locale so the same body serves en/de/nl.
// Body component(s): src/components/SolutionDetail.astro.
// JsonLd emits schema.org structured data for search engines (breadcrumbs
// and similar); see src/data/seo.ts for the schema builders.
// ==========================================================================
import BaseLayout from '../../../layouts/BaseLayout.astro';
import JsonLd from '../../../components/JsonLd.astro';
import SolutionDetail from '../../../components/SolutionDetail.astro';
import { breadcrumbSchema } from '../../../data/seo';
import { getSolutionDetail } from '../../../data/solutions-i18n';
import { asLocale, localizeUrl } from '../../../i18n/utils';

const L = asLocale(Astro.currentLocale);
const d = getSolutionDetail(L, '/solutions/team/agencies');
const crumbs = breadcrumbSchema([
  { name: 'Home', url: localizeUrl(L, '/') },
  { name: 'Solutions', url: localizeUrl(L, '/solutions') },
  { name: d.eyebrow, url: localizeUrl(L, '/solutions/team/agencies') },
]);
---
<BaseLayout title={d.title} description={d.metaDescription}>
  <JsonLd slot="head" schema={crumbs} />
  <SolutionDetail L={L} data={d} />
</BaseLayout>
