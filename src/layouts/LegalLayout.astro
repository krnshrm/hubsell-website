---
// Layout for the trust/legal pages (Legal Notice, Privacy, DPA, Terms).
// Markdown pages set `layout: ../layouts/LegalLayout.astro` and provide
// `title`, `description`, and optional `lastUpdated` in frontmatter.
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const { title, description, lastUpdated } = frontmatter;
---
<BaseLayout title={`${title} | hubsell`} description={description}>
  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap"
  />

  <section class="sec sec--esp legal-hero">
    <div class="wrap">
      <p class="eyebrow">Legal</p>
      <h1 class="heading_primary" style="margin-top:8px">{title}</h1>
      {lastUpdated && <p class="legal-hero__meta">Last updated: {lastUpdated}</p>}
    </div>
  </section>

  <section class="sec sec--paper">
    <div class="wrap">
      <article class="legal">
        <slot />
      </article>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* Legal document body: serif, small, dense, high-contrast. Left-aligned and
     flush with the headings (no auto-centering). Theme-aware so dark mode reads. */
  .legal{
    --legal-ink:#0B0F1E;     /* headings / strong — near-black navy */
    --legal-body:#171C2E;    /* body — darker than the muted default */
    --legal-rule:#D6C6AC;    /* hairline between sections */
    max-width:620px; margin:0;
    font-family:'Newsreader', Georgia, 'Times New Roman', serif;
    color:var(--legal-body);
    font-size:14px; line-height:1.58;
  }
  [data-theme="dark"] .legal{
    --legal-ink:#F3EDE3; --legal-body:#D8D2C8; --legal-rule:#352A20;
  }

  .legal > :first-child{ margin-top:0 }

  .legal h2{
    font-family:'Newsreader', Georgia, serif; font-weight:600;
    font-size:1.0625rem; line-height:1.3; color:var(--legal-ink);
    margin:1.85em 0 .45em; padding-top:1em; border-top:1px solid var(--legal-rule);
  }
  .legal h2:first-of-type{ margin-top:.1em; padding-top:0; border-top:0 }
  .legal h3{
    font-family:'Newsreader', Georgia, serif; font-weight:600;
    font-size:.9375rem; line-height:1.35; color:var(--legal-ink); margin:1.45em 0 .3em;
  }
  .legal h4{
    font-family:'Newsreader', Georgia, serif; font-weight:600;
    font-size:.875rem; line-height:1.4; color:var(--legal-ink); margin:1.15em 0 .25em;
  }
  .legal p{ margin:0 0 .75em; color:var(--legal-body) }
  .legal a{ color:var(--accent-on); text-decoration:none; border-bottom:1px solid transparent; transition:border-color .15s; overflow-wrap:anywhere }
  .legal a:hover{ border-bottom-color:var(--accent-on) }
  .legal strong{ font-weight:600; color:var(--legal-ink) }
  .legal ul,.legal ol{ margin:0 0 .75em; padding-left:1.15em }
  .legal li{ margin:0 0 .28em; color:var(--legal-body) }
  .legal li::marker{ color:var(--legal-ink) }
  .legal hr{ border:0; border-top:1px solid var(--legal-rule); margin:1.5em 0 }

  .legal-hero{ padding-bottom:clamp(22px,3.5vw,34px) }
  .legal-hero__meta{ font-family:var(--font-body); font-size:13px; color:var(--sec-tx); opacity:.7; margin:10px 0 0 }
