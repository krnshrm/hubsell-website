---
// Layout for the trust/legal pages (Legal Notice, Privacy, DPA, Terms).
// Markdown pages set `layout: ../layouts/LegalLayout.astro` and provide
// `title`, `description`, and optional `lastUpdated` in frontmatter.
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const { title, description, lastUpdated } = frontmatter;
---
<BaseLayout title={`${title} | hubsell`} description={description}>
  <section class="sec sec--sand legal-hero">
    <div class="wrap">
      <p class="eyebrow">Legal</p>
      <h1 class="heading_primary" style="margin-top:8px">{title}</h1>
      {lastUpdated && <p class="legal-hero__meta">Last updated: {lastUpdated}</p>}
    </div>
  </section>

  <section class="sec sec--paper">
    <div class="wrap">
      <article class="legal">
        <slot />
      </article>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .legal-hero{ padding-bottom:clamp(26px,4vw,40px) }
  .legal-hero__meta{ font-family:var(--font-body); font-size:14px; color:var(--sec-tx); opacity:.6; margin:12px 0 0 }

  .legal{ max-width:760px; margin:0 auto; color:var(--sec-tx) }
  .legal > :first-child{ margin-top:0 }
  .legal h2{ font-family:var(--font-head); font-weight:600; font-size:clamp(1.3rem,2.4vw,1.6rem); line-height:1.25; letter-spacing:-.01em; color:var(--sec-tx); margin:2.4em 0 .6em; padding-top:1.4em; border-top:1px solid var(--sec-bd) }
  .legal h2:first-of-type{ margin-top:.2em; padding-top:0; border-top:0 }
  .legal h3{ font-family:var(--font-head); font-weight:600; font-size:1.15rem; line-height:1.3; color:var(--sec-tx); margin:1.8em 0 .5em }
  .legal h4{ font-family:var(--font-body); font-weight:600; font-size:1rem; line-height:1.4; color:var(--sec-tx); margin:1.4em 0 .4em }
  .legal p{ font-family:var(--font-body); font-size:1rem; line-height:1.75; color:var(--sec-tx); opacity:.9; margin:0 0 1.05em }
  .legal a{ color:var(--accent-on); text-decoration:none; border-bottom:1px solid transparent; transition:border-color .15s; overflow-wrap:anywhere }
  .legal a:hover{ border-bottom-color:var(--accent-on) }
  .legal strong{ font-weight:600; color:var(--sec-tx); opacity:1 }
  .legal ul,.legal ol{ margin:0 0 1.05em; padding-left:1.35em }
  .legal li{ font-family:var(--font-body); font-size:1rem; line-height:1.75; color:var(--sec-tx); opacity:.9; margin:0 0 .4em }
  .legal hr{ border:0; border-top:1px solid var(--sec-bd); margin:2em 0 }
</style>
