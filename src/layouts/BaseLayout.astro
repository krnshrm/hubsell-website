---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// Import the Webflow stylesheet here once it has been added to src/styles/.
// This is the Phase-1 parity baseline; we refactor to clean CSS later.
// import '../styles/webflow.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'hubsell | Replace Your Outbound Stack with One Platform',
  description = 'hubsell replaces your sales intelligence, sales engagement, and LinkedIn outreach tools with one platform — real-time data, email + LinkedIn sequences, and automatic CRM sync.',
  canonical = new URL(Astro.url.pathname, Astro.site).href,
  ogImage,
  noindex = false,
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- TODO(phase-1): add the exact fonts + favicon from the Webflow export. -->
    <slot name="head" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
