---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'hubsell | Replace Your Outbound Stack with One Platform',
  description = 'hubsell replaces your sales intelligence, sales engagement, and LinkedIn outreach tools with one platform — real-time data, email + LinkedIn sequences, and automatic CRM sync.',
  canonical = new URL(Astro.url.pathname, Astro.site).href,
  ogImage,
  noindex = false,
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <meta name="theme-color" content="#EADBC2" />
    <link rel="icon" type="image/svg+xml" href="https://assets.hubsell.com/logo/hubsell-favicon.svg" />

    <!-- Brand fonts. Lexend (display) + Instrument Sans (body) for the whole site.
         Newsreader is loaded only on blog/long-form templates (Phase 3). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&family=Lexend:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Pre-paint guard: only opt into scroll-reveal hiding when motion is allowed,
         so reduced-motion users (and the no-JS case) never see hidden content. -->
    <script is:inline>
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('has-anim');
      }
    </script>

    <slot name="head" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import '../scripts/motion.ts';
    </script>
  </body>
</html>
